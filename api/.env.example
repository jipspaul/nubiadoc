# === Nubia API — variables d'environnement ===
# Copier en .env (non commité). Voir docs/10 pour le mapping POC/prod.

NODE_ENV=development
MODE=api                      # api | worker
PORT=3000

# --- Base de données (POC: Postgres en conteneur Podman / prod: Scaleway Managed) ---
DATABASE_URL=postgresql://app:app@localhost:5432/nubia?schema=public

# --- Redis (cache + BullMQ) ---
REDIS_URL=redis://localhost:6379

# --- Drivers interchangeables (POC <-> prod), cf. docs/10 ---
STORAGE_DRIVER=minio          # minio | scaleway
S3_ENDPOINT=http://localhost:9000
S3_REGION=fr-par
S3_BUCKET=nubia-poc
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

MAIL_DRIVER=mailpit           # mailpit | brevo
SMS_DRIVER=log                # log | octopush
SIGN_DRIVER=yousign_sandbox   # yousign_sandbox | yousign
KMS_DRIVER=local              # local | scaleway
KMS_MASTER_KEY=change-me-32-bytes-base64   # POC uniquement
ANALYTICS_DRIVER=noop         # noop | posthog

# --- SaaS sandbox (POC) ---
STRIPE_SECRET_KEY=sk_test_xxx
YOUSIGN_API_KEY=sandbox_xxx
