# db/.env.example — connexions de la base Nubia.
# Copier en .env (NON versionné) et adapter. Aucune valeur sensible ici :
#   - en local/CI : auth `trust` (pas de mot de passe) ;
#   - en staging/prod : les secrets + sslmode sont injectés HORS-BANDE (db/README §3, §12),
#     jamais commités.

# --- Paramètres communs (utilisés par le Makefile) ---
PGHOST=localhost
PGPORT=5432
DB_NAME=nubia
ADMIN_USER=postgres        # superuser, UNIQUEMENT pour `make reset` (jamais l'app)

# --- Les DEUX URL applicatives (cf. db/SCHEMA.md) ---
# Migrations (DDL) — rôle propriétaire, séparé, HORS application :
DATABASE_URL=postgres://nubia_owner@localhost:5432/nubia
# Runtime API + tests RLS — rôle applicatif (NOSUPERUSER, NOBYPASSRLS) : TOUJOURS celui-ci côté app
APP_DATABASE_URL=postgres://nubia_app@localhost:5432/nubia
# Chargement du seed démo (données fictives) :
SEED_DATABASE_URL=postgres://nubia_seed@localhost:5432/nubia

# Exemple prod (forme — secrets injectés par l'orchestrateur, pas ici) :
# APP_DATABASE_URL=postgres://nubia_app:${NUBIA_APP_PASSWORD}@db.internal:5432/nubia?sslmode=require
