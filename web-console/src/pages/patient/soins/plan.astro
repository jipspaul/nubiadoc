---
import AppShell from '../../../layouts/AppShell.astro';
---
<AppShell title="Plan de traitement — Nubia" role="patient">
  <nav aria-label="Fil d'Ariane">
    <a href="/patient/accueil">Accueil</a>
    <span aria-hidden="true"> / </span>
    <a href="/patient/soins/passeport">Mes soins</a>
    <span aria-hidden="true"> / </span>
    <span aria-current="page">Plan de traitement</span>
  </nav>

  <header>
    <h1>Plan de traitement</h1>
    <p>Suivi de vos plans de soins établis par votre praticien.</p>
  </header>

  <section aria-labelledby="h-plans">
    <h2 id="h-plans">Mes plans</h2>

    <div id="plans-loading" aria-live="polite">Chargement…</div>

    <ul id="plans-list" hidden aria-label="Liste des plans de traitement"></ul>

    <p id="plans-empty" hidden>Aucun plan de traitement enregistré.</p>

    <p id="plans-error" hidden role="alert"></p>
  </section>

  <section id="plan-detail" hidden aria-labelledby="h-detail">
    <nav aria-label="Retour à la liste">
      <button type="button" id="btn-back">← Retour à la liste</button>
    </nav>
    <h2 id="h-detail">Détail du plan</h2>
    <div id="detail-loading" aria-live="polite" hidden>Chargement…</div>
    <dl id="detail-content" hidden></dl>
    <p id="detail-error" hidden role="alert"></p>
  </section>
</AppShell>

<style>
  nav { margin-bottom: var(--space-3); font-size: var(--font-size-sm); color: var(--color-muted); }
  nav a { color: var(--color-muted); text-decoration: none; }
  nav a:hover { text-decoration: underline; }

  header { margin-bottom: var(--space-6); }
  h1 { margin-bottom: var(--space-1); }
  header > p { color: var(--color-muted); font-size: var(--font-size-sm); }

  h2 { font-size: var(--font-size-lg); margin-bottom: var(--space-4); }

  #plans-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .plan-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-3) var(--space-4);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-surface);
    cursor: pointer;
    text-align: left;
    width: 100%;
    color: var(--color-text);
    font-size: var(--font-size-base);
  }
  .plan-item:hover { background: var(--color-border); }

  .plan-title { font-weight: 600; }
  .plan-meta { font-size: var(--font-size-sm); color: var(--color-muted); }

  .plan-status {
    font-size: var(--font-size-xs);
    font-weight: 700;
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-full);
    white-space: nowrap;
    background: var(--color-border);
    color: var(--color-muted);
  }
  .plan-status[data-active] {
    background: var(--color-success);
    color: var(--color-success-fg);
  }

  #btn-back {
    background: transparent;
    border: 1px solid var(--color-border);
    color: var(--color-muted);
    padding: var(--space-2) var(--space-3);
    border-radius: var(--radius-sm);
    cursor: pointer;
    font-size: var(--font-size-sm);
    margin-bottom: var(--space-4);
  }
  #btn-back:hover { background: var(--color-border); color: var(--color-text); }

  #plan-detail { margin-top: var(--space-6); }

  dl {
    display: grid;
    grid-template-columns: max-content 1fr;
    gap: var(--space-2) var(--space-4);
    font-size: var(--font-size-sm);
  }
  dt { font-weight: 600; color: var(--color-muted); }
  dd { margin: 0; }
</style>

<script>
  import { patientTreatmentPlans, type TreatmentPlan } from '../../../lib/endpoints.ts';

  const plansSection = document.querySelector('section[aria-labelledby="h-plans"]') as HTMLElement;
  const detailSection = document.getElementById('plan-detail') as HTMLElement;

  const loading = document.getElementById('plans-loading') as HTMLElement;
  const list = document.getElementById('plans-list') as HTMLUListElement;
  const empty = document.getElementById('plans-empty') as HTMLParagraphElement;
  const plansError = document.getElementById('plans-error') as HTMLParagraphElement;

  const detailLoading = document.getElementById('detail-loading') as HTMLElement;
  const detailContent = document.getElementById('detail-content') as HTMLElement;
  const detailError = document.getElementById('detail-error') as HTMLParagraphElement;
  const detailHeading = document.getElementById('h-detail') as HTMLHeadingElement;
  const btnBack = document.getElementById('btn-back') as HTMLButtonElement;

  function escHtml(s: string): string {
    return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }

  function showList(): void {
    plansSection.hidden = false;
    detailSection.hidden = true;
  }

  function renderPlans(plans: TreatmentPlan[]): void {
    list.innerHTML = '';
    if (plans.length === 0) {
      empty.hidden = false;
      return;
    }
    for (const plan of plans) {
      const title = plan.title ?? 'Plan sans titre';
      const createdAt = plan.created_at
        ? new Date(plan.created_at).toLocaleDateString('fr-FR')
        : '';
      const isActive = plan.status === 'active' || plan.status === 'en_cours';

      const li = document.createElement('li');
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'plan-item';
      btn.setAttribute('data-plan-id', plan.id);
      btn.innerHTML = `
        <span class="plan-info">
          <span class="plan-title">${escHtml(title)}</span>
          ${createdAt ? `<span class="plan-meta">Créé le ${escHtml(createdAt)}</span>` : ''}
        </span>
        <span class="plan-status"${isActive ? ' data-active' : ''}>${escHtml(plan.status ?? 'inconnu')}</span>`;
      btn.addEventListener('click', () => openDetail(plan.id, title));
      li.appendChild(btn);
      list.appendChild(li);
    }
    list.hidden = false;
  }

  async function openDetail(planId: string, planTitle: string): Promise<void> {
    plansSection.hidden = true;
    detailSection.hidden = false;
    detailHeading.textContent = planTitle;
    detailContent.hidden = true;
    detailContent.innerHTML = '';
    detailError.hidden = true;
    detailLoading.hidden = false;

    const { status, data } = await patientTreatmentPlans.get(planId);
    detailLoading.hidden = true;

    if (status < 300 && data !== null && typeof data === 'object') {
      const plan = data as TreatmentPlan & Record<string, unknown>;
      const rows: Array<[string, string]> = [
        ['Identifiant', plan.id],
        ['Titre', plan.title ?? '—'],
        ['Statut', plan.status ?? '—'],
        ['Créé le', plan.created_at ? new Date(plan.created_at).toLocaleDateString('fr-FR') : '—'],
      ];
      detailContent.innerHTML = rows
        .map(([k, v]) => `<dt>${escHtml(k)}</dt><dd>${escHtml(v)}</dd>`)
        .join('');
      detailContent.hidden = false;
    } else {
      detailError.textContent = 'Impossible de charger le détail du plan.';
      detailError.hidden = false;
    }
  }

  btnBack.addEventListener('click', showList);

  // Load list on mount
  (async () => {
    const { status, data } = await patientTreatmentPlans.list();
    loading.hidden = true;
    if (status < 300 && Array.isArray(data)) {
      renderPlans(data as TreatmentPlan[]);
    } else {
      plansError.textContent = 'Impossible de charger les plans de traitement.';
      plansError.hidden = false;
    }
  })();
</script>
