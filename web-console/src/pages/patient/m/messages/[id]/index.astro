---
import MobileShell from '../../../../../layouts/MobileShell.astro';

const { id } = Astro.params;
---
<MobileShell title="Conversation — Nubia">
  <nav aria-label="Retour" class="mobile-back">
    <a href="/patient/m/messages">← Mes messages</a>
  </nav>

  <header class="mobile-header" style="margin-bottom:var(--space-4);">
    <h1 class="mobile-title" id="conv-subject">Conversation</h1>
    <p id="conv-meta" class="mobile-conv-meta"></p>
  </header>

  <section aria-labelledby="h-messages">
    <h2 id="h-messages" class="sr-only">Messages</h2>

    <div id="msg-loading" class="mobile-loading" aria-live="polite">Chargement…</div>

    <ul id="msg-list" class="mobile-msg-list" hidden aria-label="Messages de la conversation"></ul>

    <p id="msg-empty" class="mobile-empty" hidden>Aucun message dans cette conversation.</p>
  </section>

  <section aria-labelledby="h-reply" style="margin-top:var(--space-4);">
    <h2 id="h-reply" class="sr-only">Répondre</h2>
    <form id="reply-form" class="mobile-reply-form" hidden novalidate>
      <label for="reply-body" class="mobile-label">Votre message</label>
      <textarea id="reply-body" name="body" rows="3" required class="mobile-input"
        placeholder="Écrivez votre message…"></textarea>
      <div style="display:flex;align-items:center;gap:var(--space-3);margin-top:var(--space-2);">
        <button type="submit" id="reply-submit" class="mobile-btn mobile-btn-primary" style="flex:1;">Envoyer</button>
        <span id="reply-status" class="mobile-reply-status" aria-live="polite" role="status"></span>
      </div>
    </form>
  </section>

  <span id="conv-id-data" data-id={id} hidden></span>
</MobileShell>

<style>
  .mobile-back {
    margin-bottom: var(--space-3);
  }
  .mobile-back a {
    font-size: var(--font-size-sm);
    color: var(--color-accent);
    text-decoration: none;
  }

  .mobile-title {
    font-size: var(--font-size-xl);
    font-weight: 700;
    margin-bottom: var(--space-1);
  }

  .mobile-conv-meta {
    color: var(--color-muted);
    font-size: var(--font-size-sm);
  }

  .mobile-loading,
  .mobile-empty {
    font-size: var(--font-size-sm);
    color: var(--color-muted);
    padding: var(--space-3) 0;
  }

  .sr-only {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden;
    clip: rect(0,0,0,0);
    white-space: nowrap;
    border: 0;
  }

  .mobile-msg-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .mobile-msg-bubble {
    padding: var(--space-3) var(--space-4);
    border-radius: var(--radius-lg);
    max-width: 80%;
  }
  .mobile-msg-bubble[data-sender="patient"] {
    align-self: flex-end;
    background: var(--color-accent);
    color: var(--color-accent-fg);
    margin-left: auto;
    border-bottom-right-radius: var(--radius-sm);
  }
  .mobile-msg-bubble[data-sender="pro"] {
    align-self: flex-start;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    color: var(--color-text);
    border-bottom-left-radius: var(--radius-sm);
  }
  .mobile-msg-body { white-space: pre-wrap; word-break: break-word; font-size: var(--font-size-sm); }
  .mobile-msg-date { font-size: var(--font-size-xs); opacity: 0.75; margin-top: var(--space-1); }

  .mobile-reply-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-3);
  }

  .mobile-label {
    font-size: var(--font-size-xs);
    font-weight: 600;
  }

  .mobile-input {
    width: 100%;
    padding: var(--space-2) var(--space-3);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    font-size: var(--font-size-sm);
    background: var(--color-bg);
    color: var(--color-text);
    box-sizing: border-box;
    font-family: inherit;
  }
  .mobile-input:focus { outline: 2px solid var(--color-accent); outline-offset: 1px; }

  .mobile-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-2) var(--space-4);
    border: none;
    border-radius: var(--radius-sm);
    font-size: var(--font-size-sm);
    font-weight: 600;
    cursor: pointer;
    min-height: 44px;
    -webkit-tap-highlight-color: transparent;
  }
  .mobile-btn-primary { background: var(--color-accent); color: var(--color-accent-fg); }
  .mobile-btn-secondary { background: var(--color-surface); color: var(--color-text); border: 1px solid var(--color-border); }
  .mobile-btn:disabled { opacity: 0.6; cursor: not-allowed; }

  .mobile-reply-status {
    font-size: var(--font-size-sm);
  }
  .mobile-reply-status:global(.error) { color: var(--color-error); }
</style>

<script define:vars={{ conversationId: id }}>
  import { patientConversations, type Message } from '../../../../../lib/endpoints.ts';

  function escHtml(s: string): string {
    return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }

  const convId = conversationId as string;
  const msgLoading = document.getElementById('msg-loading') as HTMLElement;
  const msgList = document.getElementById('msg-list') as HTMLUListElement;
  const msgEmpty = document.getElementById('msg-empty') as HTMLParagraphElement;
  const replyForm = document.getElementById('reply-form') as HTMLFormElement;
  const replySubmit = document.getElementById('reply-submit') as HTMLButtonElement;
  const replyStatus = document.getElementById('reply-status') as HTMLSpanElement;

  function renderMessages(messages: Message[]): void {
    msgList.innerHTML = '';
    if (messages.length === 0) {
      msgEmpty.hidden = false;
      return;
    }
    for (const msg of messages) {
      const sender = msg.sender
        ?? ((msg as Record<string, unknown>).sender_type as string | undefined)
        ?? 'pro';
      const sentAt = msg.sent_at ?? msg.created_at;
      const dateStr = sentAt ? new Date(sentAt).toLocaleString('fr-FR') : '';

      const li = document.createElement('li');
      li.className = 'mobile-msg-bubble';
      li.setAttribute('data-message-id', msg.id);
      li.setAttribute('data-sender', sender);
      li.innerHTML = `
        <p class="mobile-msg-body">${escHtml(msg.body)}</p>
        <p class="mobile-msg-date">${escHtml(dateStr)}</p>`;
      msgList.appendChild(li);
    }
    msgList.hidden = false;
    msgList.lastElementChild?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }

  async function loadMessages(): Promise<void> {
    const { status, data } = await patientConversations.getMessages(convId);
    msgLoading.hidden = true;
    const payload = data as Message[] | { data?: Message[] } | null;
    const messages = Array.isArray(payload)
      ? payload
      : (payload && Array.isArray(payload.data) ? payload.data : null);
    if (status < 300 && messages) {
      renderMessages([...messages].reverse());
      replyForm.hidden = false;
      patientConversations.markRead(convId).catch(() => {/* best-effort */});
    } else {
      msgLoading.textContent = 'Impossible de charger les messages.';
      msgLoading.hidden = false;
    }
  }

  loadMessages();

  replyForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(replyForm);
    const body = (fd.get('body') as string).trim();
    if (!body) return;

    replySubmit.disabled = true;
    replyStatus.textContent = '';
    replyStatus.className = '';

    const { status } = await patientConversations.postMessage(convId, { body });
    replySubmit.disabled = false;

    if (status < 300) {
      (replyForm.elements.namedItem('body') as HTMLTextAreaElement).value = '';
      msgLoading.hidden = false;
      msgLoading.textContent = 'Chargement…';
      msgList.hidden = true;
      msgList.innerHTML = '';
      msgEmpty.hidden = true;
      await loadMessages();
    } else {
      replyStatus.textContent = 'Erreur lors de l\'envoi.';
      replyStatus.className = 'error';
    }
  });
</script>
