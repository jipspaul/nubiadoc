---
import AppShell from '../../layouts/AppShell.astro';
import type { Dashboard } from '../../lib/endpoints.ts';

const API_BASE: string =
  (import.meta.env.API_BASE as string | undefined) ??
  (import.meta.env.PUBLIC_API_BASE as string | undefined) ??
  'http://localhost:38030';

const jwt  = Astro.cookies.get('nubia_jwt')?.value;
const role = Astro.cookies.get('nubia_role')?.value;

if (!jwt) {
  return Astro.redirect(`/auth/login?next=${encodeURIComponent(Astro.url.pathname)}`);
}
if (role !== 'patient') {
  return Astro.redirect(`/auth/login?next=${encodeURIComponent(Astro.url.pathname)}`);
}

// ── Server-side fetch ────────────────────────────────────────────────────────

let dashboard: Dashboard | null = null;
let fetchError: string | null = null;

try {
  const res = await fetch(`${API_BASE}/v1/dashboard`, {
    headers: { Authorization: `Bearer ${jwt}` },
  });

  if (res.status === 401) {
    return Astro.redirect(`/auth/login?next=${encodeURIComponent(Astro.url.pathname)}`);
  }

  if (res.ok) {
    const text = await res.text();
    dashboard = text ? (JSON.parse(text) as Dashboard) : null;
  } else {
    fetchError = `Erreur serveur (HTTP ${res.status}).`;
  }
} catch (err) {
  fetchError = `Erreur réseau : ${err instanceof Error ? err.message : String(err)}`;
}

// ── Derived display values ───────────────────────────────────────────────────

function formatDate(iso: string): string {
  return new Date(iso).toLocaleString('fr-FR', {
    weekday: 'long', day: 'numeric', month: 'long', year: 'numeric',
    hour: '2-digit', minute: '2-digit',
  });
}

const nextAppt = dashboard?.next_appointment ?? null;
const nextApptDate = nextAppt?.scheduled_at ? formatDate(nextAppt.scheduled_at) : null;
const nextApptId   = nextAppt?.id ?? null;
const nextApptProv = nextAppt?.provider_name ?? null;

const unreadMessages = dashboard?.unread_messages ?? 0;

const pendingQuotes = dashboard?.to_sign?.length
  ?? dashboard?.pending_quotes
  ?? 0;

const pendingPayments = dashboard?.to_pay?.length ?? 0;
---

<AppShell title="Accueil — Espace patient" role="patient">
  <header>
    <h1>Accueil</h1>
    <p>Bienvenue dans votre espace patient.</p>
  </header>

  {fetchError && (
    <p role="alert" class="fetch-error">{fetchError}</p>
  )}

  {!fetchError && (
    <>
      <!-- ── Prochain rendez-vous ──────────────────────────────────────────── -->
      <section aria-labelledby="h-next-rdv">
        <h2 id="h-next-rdv">Prochain rendez-vous</h2>
        {nextApptDate ? (
          <article aria-label="Prochain rendez-vous">
            <p class="rdv-date">{nextApptDate}</p>
            {nextApptProv && <p class="rdv-provider">{nextApptProv}</p>}
            <a href={nextApptId ? `/patient/rdv/${encodeURIComponent(nextApptId)}` : '/patient/rdv'} class="link-action">
              Voir le détail
            </a>
          </article>
        ) : (
          <p class="empty-hint">Aucun rendez-vous à venir.</p>
        )}
      </section>

      <!-- ── Messages non lus ─────────────────────────────────────────────── -->
      <section aria-labelledby="h-messages">
        <h2 id="h-messages">Messages non lus</h2>
        <p class="counter">
          {unreadMessages === 0
            ? 'Aucun message non lu.'
            : `${unreadMessages} message${unreadMessages > 1 ? 's' : ''} non lu${unreadMessages > 1 ? 's' : ''}.`}
        </p>
        <a href="/patient/messages" class="link-action">Voir les messages</a>
      </section>

      <!-- ── Devis en attente ──────────────────────────────────────────────── -->
      <section aria-labelledby="h-devis">
        <h2 id="h-devis">Devis en attente</h2>
        <p class="counter">
          {pendingQuotes === 0
            ? 'Aucun devis en attente.'
            : `${pendingQuotes} devis en attente.`}
        </p>
        <a href="/patient/devis" class="link-action">Voir les devis</a>
      </section>

      <!-- ── Paiements à régler ────────────────────────────────────────────── -->
      <section aria-labelledby="h-payments">
        <h2 id="h-payments">Paiements à régler</h2>
        <p class="counter">
          {pendingPayments === 0
            ? 'Aucun paiement en attente.'
            : `${pendingPayments} paiement${pendingPayments > 1 ? 's' : ''} à régler.`}
        </p>
        <a href="/patient/devis" class="link-action">Voir les devis</a>
      </section>
    </>
  )}
</AppShell>

<style>
  header { margin-bottom: var(--space-6); }
  h1 { margin-bottom: var(--space-1); }
  header > p { color: var(--color-muted); font-size: var(--font-size-sm); }

  .fetch-error {
    padding: var(--space-3) var(--space-4);
    background: var(--color-error, #fef2f2);
    color: var(--color-error-fg, #991b1b);
    border-radius: var(--radius-md);
    margin-bottom: var(--space-6);
    font-size: var(--font-size-sm);
  }

  section {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-6);
    margin-bottom: var(--space-6);
  }

  h2 {
    margin: 0 0 var(--space-4);
    font-size: var(--font-size-base);
    font-weight: 600;
  }

  .empty-hint {
    color: var(--color-muted);
    font-size: var(--font-size-sm);
    margin: 0 0 var(--space-2);
  }

  .rdv-date {
    font-weight: 600;
    margin: 0 0 var(--space-1);
  }

  .rdv-provider {
    color: var(--color-muted);
    font-size: var(--font-size-sm);
    margin: 0 0 var(--space-2);
  }

  .counter {
    font-size: var(--font-size-lg);
    font-weight: 700;
    margin: 0 0 var(--space-2);
    color: var(--color-text);
  }

  .link-action {
    font-size: var(--font-size-sm);
    color: var(--color-accent);
  }
</style>
