---
import AppShell from '../../../layouts/AppShell.astro';

const { id } = Astro.params;
---
<AppShell title="Conversation — Nubia" role="patient">
  <nav aria-label="Fil d'Ariane">
    <a href="/patient/messages">← Retour aux messages</a>
  </nav>

  <header id="conv-header" style="margin-top:var(--space-4);">
    <h1 id="conv-subject">Conversation</h1>
    <p id="conv-meta" class="conv-meta-line"></p>
  </header>

  <section aria-labelledby="h-messages">
    <h2 id="h-messages" class="sr-only">Messages</h2>

    <div id="msg-loading" aria-live="polite">Chargement…</div>

    <ul id="msg-list" hidden aria-label="Messages de la conversation"></ul>

    <p id="msg-empty" hidden>Aucun message dans cette conversation.</p>
  </section>

  <section aria-labelledby="h-reply" style="margin-top:var(--space-6);">
    <h2 id="h-reply" class="sr-only">Répondre</h2>
    <form id="reply-form" hidden novalidate>
      <label for="reply-body">Votre message</label>
      <textarea id="reply-body" name="body" rows="4" required
        placeholder="Écrivez votre message…"></textarea>
      <div style="display:flex;align-items:center;gap:var(--space-3);margin-top:var(--space-3);">
        <button type="submit" id="reply-submit">Envoyer</button>
        <span id="reply-status" aria-live="polite" role="status"></span>
      </div>
    </form>
  </section>
</AppShell>

<style>
  nav { margin-bottom: var(--space-2); }
  nav a { font-size: var(--font-size-sm); color: var(--color-muted); text-decoration: none; }
  nav a:hover { text-decoration: underline; }

  header { margin-bottom: var(--space-6); }
  h1 { margin-bottom: var(--space-1); }
  .conv-meta-line { color: var(--color-muted); font-size: var(--font-size-sm); }

  .sr-only {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden;
    clip: rect(0,0,0,0);
    white-space: nowrap;
    border: 0;
  }

  #msg-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .msg-item {
    padding: var(--space-3) var(--space-4);
    border-radius: var(--radius-md);
    max-width: 75%;
  }
  .msg-item[data-sender="patient"] {
    align-self: flex-end;
    background: var(--color-accent);
    color: var(--color-accent-fg);
    margin-left: auto;
  }
  .msg-item[data-sender="pro"] {
    align-self: flex-start;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    color: var(--color-text);
  }
  .msg-body { white-space: pre-wrap; word-break: break-word; }
  .msg-meta { font-size: var(--font-size-xs); opacity: 0.75; margin-top: var(--space-1); }

  #reply-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  #reply-form label {
    font-size: var(--font-size-sm);
    font-weight: 500;
  }
  textarea {
    padding: var(--space-2);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    color: var(--color-text);
    border-radius: var(--radius-sm);
    font-size: var(--font-size-sm);
    resize: vertical;
    width: 100%;
    box-sizing: border-box;
  }
  textarea:focus { outline: 2px solid var(--color-accent); outline-offset: 1px; }

  #reply-submit {
    padding: var(--space-2) var(--space-4);
    background: var(--color-accent);
    color: var(--color-accent-fg);
    border: none;
    border-radius: var(--radius-sm);
    cursor: pointer;
    font-size: var(--font-size-sm);
    font-weight: 600;
  }
  #reply-submit:hover { background: var(--color-accent-hover); }
  #reply-submit:disabled { opacity: 0.6; cursor: not-allowed; }

  #reply-status { font-size: var(--font-size-sm); }
  #reply-status.error { color: var(--color-error-fg, red); }
</style>

<script define:vars={{ conversationId: id }}>
  import { patientConversations, type Message } from '../../../lib/endpoints.ts';

  const convId = conversationId as string;
  const msgLoading = document.getElementById('msg-loading') as HTMLElement;
  const msgList = document.getElementById('msg-list') as HTMLUListElement;
  const msgEmpty = document.getElementById('msg-empty') as HTMLParagraphElement;
  const replyForm = document.getElementById('reply-form') as HTMLFormElement;
  const replySubmit = document.getElementById('reply-submit') as HTMLButtonElement;
  const replyStatus = document.getElementById('reply-status') as HTMLSpanElement;

  function renderMessages(messages: Message[]): void {
    msgList.innerHTML = '';
    if (messages.length === 0) {
      msgEmpty.hidden = false;
      return;
    }
    for (const msg of messages) {
      const sender = (msg as Record<string, unknown>).sender_type as string | undefined ?? 'pro';
      const sentAt = msg.sent_at ?? (msg as Record<string, unknown>).created_at as string | undefined;
      const dateStr = sentAt ? new Date(sentAt).toLocaleString('fr-FR') : '';

      const li = document.createElement('li');
      li.className = 'msg-item';
      li.setAttribute('data-message-id', msg.id);
      li.setAttribute('data-sender', sender);
      li.innerHTML = `
        <p class="msg-body">${escHtml(msg.body)}</p>
        <p class="msg-meta">${escHtml(dateStr)}</p>`;
      msgList.appendChild(li);
    }
    msgList.hidden = false;
    // scroll to bottom
    msgList.lastElementChild?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }

  async function loadMessages(): Promise<void> {
    const { status, data } = await patientConversations.getMessages(convId);
    msgLoading.hidden = true;
    if (status < 300 && Array.isArray(data)) {
      renderMessages(data as Message[]);
      replyForm.hidden = false;
      // Mark conversation as read
      patientConversations.markRead(convId).catch(() => {/* best-effort */});
    } else {
      msgLoading.textContent = 'Impossible de charger les messages.';
      msgLoading.hidden = false;
    }
  }

  loadMessages();

  replyForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(replyForm);
    const body = (fd.get('body') as string).trim();
    if (!body) return;

    replySubmit.disabled = true;
    replyStatus.textContent = '';
    replyStatus.className = '';

    const { status } = await patientConversations.postMessage(convId, { body });
    replySubmit.disabled = false;

    if (status < 300) {
      (replyForm.elements.namedItem('body') as HTMLTextAreaElement).value = '';
      // Reload messages to show the new one
      msgLoading.hidden = false;
      msgLoading.textContent = 'Chargement…';
      msgList.hidden = true;
      msgList.innerHTML = '';
      msgEmpty.hidden = true;
      await loadMessages();
    } else {
      replyStatus.textContent = 'Erreur lors de l\'envoi.';
      replyStatus.className = 'error';
    }
  });

  function escHtml(s: string): string {
    return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }
</script>
