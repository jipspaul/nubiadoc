---
import AppShell from '../../../layouts/AppShell.astro';
---
<AppShell title="Consentements — Nubia" role="patient">
  <header>
    <h1>Mon profil</h1>
    <p>Consultez et modifiez vos informations personnelles.</p>
  </header>

  <nav aria-label="Sous-navigation profil">
    <ul>
      <li><a href="/patient/profil">Informations</a></li>
      <li><a href="/patient/profil/couverture">Couverture</a></li>
      <li><a href="/patient/profil/proches">Proches</a></li>
      <li><a href="/patient/profil/consentements" aria-current="page">Consentements</a></li>
      <li><a href="/patient/profil/notifications">Notifications</a></li>
    </ul>
  </nav>

  <section aria-labelledby="h-consentements">
    <h2 id="h-consentements">Gestion des consentements</h2>
    <p class="section-desc">Activez ou désactivez vos consentements par finalité.</p>

    <div id="consents-loading" aria-live="polite">Chargement…</div>

    <ul id="consents-list" hidden aria-label="Liste des consentements"></ul>

    <p id="consents-error" aria-live="polite" hidden>Impossible de charger les consentements.</p>
    <p id="consents-toast" aria-live="polite" role="status" hidden></p>
  </section>
</AppShell>

<style>
  header { margin-bottom: var(--space-6); }
  h1 { margin-bottom: var(--space-1); }
  header > p { color: var(--color-muted); font-size: var(--font-size-sm); }

  nav { margin-bottom: var(--space-6); }
  nav ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }
  nav a {
    display: inline-block;
    padding: var(--space-1) var(--space-3);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    color: var(--color-text);
    text-decoration: none;
    font-size: var(--font-size-sm);
  }
  nav a[aria-current="page"] {
    background: var(--color-accent);
    color: var(--color-accent-fg);
    border-color: var(--color-accent);
  }
  nav a:hover:not([aria-current="page"]) { background: var(--color-border); }

  section {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-6);
    max-width: 480px;
  }
  h2 { margin: 0 0 var(--space-2); font-size: var(--font-size-lg); }

  .section-desc {
    color: var(--color-muted);
    font-size: var(--font-size-sm);
    margin: 0 0 var(--space-4);
  }

  #consents-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .consent-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    padding: var(--space-3);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
  }

  .consent-info {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .consent-purpose {
    font-size: var(--font-size-sm);
    font-weight: 600;
  }

  .consent-date {
    font-size: var(--font-size-xs, 0.75rem);
    color: var(--color-muted);
  }

  .consent-toggle {
    position: relative;
    display: inline-block;
    width: 2.5rem;
    height: 1.25rem;
    flex-shrink: 0;
  }

  .consent-toggle input {
    opacity: 0;
    width: 0;
    height: 0;
    position: absolute;
  }

  .toggle-track {
    position: absolute;
    inset: 0;
    background: var(--color-border);
    border-radius: 9999px;
    cursor: pointer;
    transition: background 0.2s;
  }

  .toggle-track::after {
    content: '';
    position: absolute;
    left: 2px;
    top: 2px;
    width: 1rem;
    height: 1rem;
    background: white;
    border-radius: 50%;
    transition: transform 0.2s;
  }

  .consent-toggle input:checked + .toggle-track {
    background: var(--color-accent);
  }

  .consent-toggle input:checked + .toggle-track::after {
    transform: translateX(1.25rem);
  }

  .consent-toggle input:focus-visible + .toggle-track {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  #consents-toast {
    margin-top: var(--space-3);
    padding: var(--space-2) var(--space-3);
    border-radius: var(--radius-sm);
    font-size: var(--font-size-sm);
    font-weight: 600;
  }
  #consents-toast.success {
    background: var(--color-success);
    color: var(--color-success-fg);
  }
  #consents-toast.error {
    background: var(--color-error);
    color: var(--color-error-fg);
  }
</style>

<script>
  import { patientAccount, type Consent } from '../../../lib/endpoints.ts';

  const loading = document.getElementById('consents-loading') as HTMLElement;
  const list = document.getElementById('consents-list') as HTMLUListElement;
  const errorEl = document.getElementById('consents-error') as HTMLParagraphElement;
  const toast = document.getElementById('consents-toast') as HTMLParagraphElement;

  function showToast(message: string, type: 'success' | 'error'): void {
    toast.textContent = message;
    toast.className = type;
    toast.hidden = false;
    setTimeout(() => { toast.hidden = true; }, 4000);
  }

  function formatDate(iso?: string): string {
    if (!iso) return '';
    return new Date(iso).toLocaleDateString('fr-FR');
  }

  function renderConsents(consents: Consent[]): void {
    list.innerHTML = '';
    for (const consent of consents) {
      const li = document.createElement('li');
      li.className = 'consent-item';

      const info = document.createElement('div');
      info.className = 'consent-info';

      const purpose = document.createElement('span');
      purpose.className = 'consent-purpose';
      purpose.textContent = consent.purpose;

      const date = document.createElement('span');
      date.className = 'consent-date';
      date.textContent = consent.updated_at ? `Mis à jour le ${formatDate(consent.updated_at)}` : '';

      info.append(purpose);
      if (consent.updated_at) info.append(date);

      const label = document.createElement('label');
      label.className = 'consent-toggle';
      label.setAttribute('aria-label', `Consentement : ${consent.purpose}`);

      const checkbox = document.createElement('input');
      checkbox.type = 'checkbox';
      checkbox.checked = consent.granted;
      checkbox.dataset['purpose'] = consent.purpose;

      const track = document.createElement('span');
      track.className = 'toggle-track';
      track.setAttribute('aria-hidden', 'true');

      label.append(checkbox, track);
      li.append(info, label);
      list.append(li);

      checkbox.addEventListener('change', async () => {
        checkbox.disabled = true;
        const { status, data } = await patientAccount.putConsent(consent.purpose, { granted: checkbox.checked });
        checkbox.disabled = false;
        if (status < 300 && data) {
          const updated = data as Consent;
          if (updated.updated_at) {
            date.textContent = `Mis à jour le ${formatDate(updated.updated_at)}`;
            if (!consent.updated_at) info.append(date);
          }
          consent.granted = checkbox.checked;
          showToast('Consentement mis à jour.', 'success');
        } else {
          checkbox.checked = !checkbox.checked;
          showToast('Erreur lors de la mise à jour.', 'error');
        }
      });
    }
  }

  (async () => {
    const { status, data } = await patientAccount.getConsents();
    loading.hidden = true;
    if (status < 300 && Array.isArray(data)) {
      renderConsents(data as Consent[]);
      list.hidden = false;
    } else {
      errorEl.hidden = false;
    }
  })();
</script>
