---
import AppShell from '../../../layouts/AppShell.astro';
---
<AppShell title="Couverture santé — Nubia" role="patient">
  <header>
    <h1>Mon profil</h1>
    <p>Consultez et modifiez vos informations personnelles.</p>
  </header>

  <nav aria-label="Sous-navigation profil">
    <ul>
      <li><a href="/patient/profil">Informations</a></li>
      <li><a href="/patient/profil/couverture" aria-current="page">Couverture</a></li>
      <li><a href="/patient/profil/proches">Proches</a></li>
      <li><a href="/patient/profil/consentements">Consentements</a></li>
      <li><a href="/patient/profil/notifications">Notifications</a></li>
    </ul>
  </nav>

  <section aria-labelledby="h-couverture">
    <h2 id="h-couverture">Couverture santé</h2>

    <div id="couverture-loading" aria-live="polite">Chargement…</div>

    <form id="couverture-form" novalidate hidden>
      <label>
        Régime obligatoire
        <input type="text" name="regime" placeholder="Ex: Sécurité sociale générale" autocomplete="off" />
      </label>

      <label>
        Mutuelle
        <input type="text" name="mutual" placeholder="Ex: MGEN, Harmonie Mutuelle…" autocomplete="off" />
      </label>

      <label>
        Numéro d'adhérent mutuelle
        <input type="text" name="mutual_number" placeholder="Numéro figurant sur votre carte" autocomplete="off" />
      </label>

      <button type="submit">Enregistrer</button>
    </form>

    <p id="couverture-toast" aria-live="polite" role="status" hidden></p>
  </section>

  <section aria-labelledby="h-carte-mutuelle">
    <h2 id="h-carte-mutuelle">Carte mutuelle</h2>
    <p class="section-desc">Ajoutez une photo de votre carte mutuelle (JPEG, PNG, PDF — 5 Mo max).</p>

    <form id="card-form" novalidate>
      <label>
        Fichier
        <input type="file" name="file" accept="image/jpeg,image/png,application/pdf" required />
      </label>

      <button type="submit">Ajouter la carte</button>
    </form>

    <p id="card-toast" aria-live="polite" role="status" hidden></p>
  </section>
</AppShell>

<style>
  header { margin-bottom: var(--space-6); }
  h1 { margin-bottom: var(--space-1); }
  header > p { color: var(--color-muted); font-size: var(--font-size-sm); }

  nav { margin-bottom: var(--space-6); }
  nav ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }
  nav a {
    display: inline-block;
    padding: var(--space-1) var(--space-3);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    color: var(--color-text);
    text-decoration: none;
    font-size: var(--font-size-sm);
  }
  nav a[aria-current="page"] {
    background: var(--color-accent);
    color: var(--color-accent-fg);
    border-color: var(--color-accent);
  }
  nav a:hover:not([aria-current="page"]) { background: var(--color-border); }

  section {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-6);
    max-width: 480px;
    margin-bottom: var(--space-6);
  }
  h2 { margin: 0 0 var(--space-4); font-size: var(--font-size-lg); }

  .section-desc {
    color: var(--color-muted);
    font-size: var(--font-size-sm);
    margin: 0 0 var(--space-4);
  }

  form {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  label {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    font-size: var(--font-size-sm);
    font-weight: 500;
  }

  input[type="text"],
  input[type="file"] {
    padding: var(--space-2);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    color: var(--color-text);
    border-radius: var(--radius-sm);
    font-size: var(--font-size-sm);
    width: 100%;
  }
  input[type="text"]:focus,
  input[type="file"]:focus {
    outline: 2px solid var(--color-accent);
    outline-offset: 1px;
  }

  button[type="submit"] {
    padding: var(--space-2) var(--space-4);
    background: var(--color-accent);
    color: var(--color-accent-fg);
    border: none;
    border-radius: var(--radius-sm);
    cursor: pointer;
    font-size: var(--font-size-sm);
    font-weight: 600;
    align-self: flex-start;
    margin-top: var(--space-1);
  }
  button[type="submit"]:hover { background: var(--color-accent-hover); }

  #couverture-toast,
  #card-toast {
    margin-top: var(--space-3);
    padding: var(--space-2) var(--space-3);
    border-radius: var(--radius-sm);
    font-size: var(--font-size-sm);
    font-weight: 600;
  }
  #couverture-toast.success,
  #card-toast.success {
    background: var(--color-success);
    color: var(--color-success-fg);
  }
  #couverture-toast.error,
  #card-toast.error {
    background: var(--color-error);
    color: var(--color-error-fg);
  }
</style>

<script>
  import { patientAccount, type Coverage } from '../../../lib/endpoints.ts';

  const loading = document.getElementById('couverture-loading') as HTMLElement;
  const form = document.getElementById('couverture-form') as HTMLFormElement;
  const toast = document.getElementById('couverture-toast') as HTMLParagraphElement;
  const cardForm = document.getElementById('card-form') as HTMLFormElement;
  const cardToast = document.getElementById('card-toast') as HTMLParagraphElement;

  function showToast(el: HTMLParagraphElement, message: string, type: 'success' | 'error'): void {
    el.textContent = message;
    el.className = type;
    el.hidden = false;
    setTimeout(() => { el.hidden = true; }, 4000);
  }

  function fillForm(coverage: Coverage): void {
    (form.elements.namedItem('regime') as HTMLInputElement).value = coverage.regime ?? '';
    (form.elements.namedItem('mutual') as HTMLInputElement).value = coverage.mutual ?? '';
    (form.elements.namedItem('mutual_number') as HTMLInputElement).value = coverage.mutual_number ?? '';
  }

  // Load coverage data
  (async () => {
    const { status, data } = await patientAccount.getCoverage();
    loading.hidden = true;
    if (status < 300 && data) {
      fillForm(data as Coverage);
      form.hidden = false;
    } else {
      loading.textContent = 'Impossible de charger la couverture.';
      loading.hidden = false;
    }
  })();

  // Submit PATCH coverage
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(form);
    const body: Partial<Coverage> = {
      regime: (fd.get('regime') as string).trim() || undefined,
      mutual: (fd.get('mutual') as string).trim() || undefined,
      mutual_number: (fd.get('mutual_number') as string).trim() || undefined,
    };

    const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    btn.disabled = true;

    const { status, data } = await patientAccount.patchCoverage(body);
    btn.disabled = false;

    if (status < 300 && data) {
      fillForm(data as Coverage);
      showToast(toast, 'Couverture mise à jour.', 'success');
    } else {
      showToast(toast, 'Erreur lors de la mise à jour.', 'error');
    }
  });

  // Submit POST card
  cardForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(cardForm);
    const file = fd.get('file') as File | null;
    if (!file || file.size === 0) {
      showToast(cardToast, 'Veuillez sélectionner un fichier.', 'error');
      return;
    }

    const btn = cardForm.querySelector('button[type="submit"]') as HTMLButtonElement;
    btn.disabled = true;

    const uploadData = new FormData();
    uploadData.append('file', file);

    const { status } = await patientAccount.postCoverageCard(uploadData);
    btn.disabled = false;

    if (status < 300) {
      cardForm.reset();
      showToast(cardToast, 'Carte ajoutée.', 'success');
    } else {
      showToast(cardToast, 'Erreur lors de l\'ajout de la carte.', 'error');
    }
  });
</script>
