---
import PublicLayout from '../layouts/PublicLayout.astro';
---
<PublicLayout title="Bienvenue sur Nubia">
  <h1>Bienvenue sur Nubia</h1>
  <div id="cta-guest" style="display:flex;gap:1rem;margin-top:1.5rem;">
    <a href="/login">Se connecter</a>
    <a href="/register">Créer un compte</a>
  </div>
  <p id="cta-auth" hidden style="margin-top:1.5rem;">
    Vous êtes connecté → <a href="/app">Mon espace</a>
  </p>
</PublicLayout>

<script>
  import { isAuthenticated } from '../lib/session.ts';
  const guest = document.getElementById('cta-guest');
  const auth = document.getElementById('cta-auth');
  if (isAuthenticated()) {
    if (guest) guest.hidden = true;
    if (auth) auth.hidden = false;
  }
</script>
