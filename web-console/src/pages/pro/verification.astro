---
import Default from '../../layouts/Default.astro';
---
<Default title="Vérification RPPS/ADELI — Nubia Console">
  <h1 style="margin-bottom:0.5rem;">POST /v1/pro/verification</h1>
  <p style="color:var(--muted);margin-bottom:1.5rem;">Soumet l'identifiant RPPS ou ADELI pour vérification ANS. Rôle requis : <code>pro</code> (admin cabinet)</p>

  <form id="verification-form" style="display:flex;flex-direction:column;gap:0.75rem;max-width:480px;">
    <label>
      Access token (Bearer, rôle pro)
      <input type="text" name="access_token" required
        style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
    </label>

    <label>
      Type d'identifiant
      <select name="id_type" required
        style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;">
        <option value="rpps">RPPS (11 chiffres)</option>
        <option value="adeli">ADELI (9 chiffres)</option>
      </select>
    </label>

    <label>
      Identifiant
      <input type="text" name="identifier" required placeholder="ex : 10003456789"
        style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
    </label>

    <button type="submit"
      style="padding:0.5rem 1rem;background:var(--accent);color:#fff;border:none;border-radius:4px;cursor:pointer;align-self:flex-start;">
      Soumettre
    </button>
  </form>

  <p id="status-badge" style="margin-top:1rem;display:none;"></p>
  <pre id="result" style="margin-top:0.5rem;padding:1rem;background:var(--surface);border:1px solid var(--border);border-radius:4px;white-space:pre-wrap;font-size:0.875rem;min-height:3rem;"></pre>
</Default>

<style>
  pre.success { border-left: 4px solid green; }
  pre.error   { border-left: 4px solid red; }
  .badge { display:inline-block;padding:0.25rem 0.6rem;border-radius:4px;font-size:0.85rem;font-weight:600; }
  .badge-ok  { background:#166534;color:#bbf7d0; }
  .badge-err { background:#7f1d1d;color:#fecaca; }
  .status-pending { display:inline-block;padding:0.25rem 0.75rem;border-radius:4px;font-weight:600;background:#78350f;color:#fef3c7; }
</style>

<script>
  import { apiFetch } from '../../lib/api.ts';

  const form = document.getElementById('verification-form') as HTMLFormElement;
  const statusBadge = document.getElementById('status-badge') as HTMLParagraphElement;
  const result = document.getElementById('result') as HTMLPreElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(form);
    const access_token = fd.get('access_token') as string;
    const id_type = fd.get('id_type') as string;
    const identifier = fd.get('identifier') as string;

    result.className = '';
    result.textContent = 'Chargement…';
    statusBadge.style.display = 'none';

    try {
      const { status: httpStatus, data } = await apiFetch('/v1/pro/verification', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Authorization': `Bearer ${access_token}`,
        },
        body: JSON.stringify({ id_type, identifier }),
      });

      result.className = httpStatus < 300 ? 'success' : 'error';
      result.textContent = `HTTP ${httpStatus}\n${data !== null ? JSON.stringify(data, null, 2) : '(aucun contenu)'}`;
      statusBadge.innerHTML = `<span class="badge ${httpStatus < 300 ? 'badge-ok' : 'badge-err'}">HTTP ${httpStatus}</span>`;
      statusBadge.style.display = 'block';

      if (httpStatus === 202 && data !== null && typeof data === 'object') {
        const verif = data as { status?: string };
        if (verif.status === 'pending') {
          statusBadge.innerHTML += ` <span class="status-pending">En attente</span>`;
        }
      }
    } catch (err) {
      result.className = 'error';
      result.textContent = `Erreur réseau : ${err instanceof Error ? err.message : String(err)}`;
    }
  });
</script>
