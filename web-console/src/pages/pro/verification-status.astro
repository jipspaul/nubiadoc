---
import Default from '../../layouts/Default.astro';
---
<Default title="Statut vérification RPPS/ADELI — Nubia Console">
  <h1 style="margin-bottom:0.5rem;">GET /v1/pro/verification</h1>
  <p style="color:var(--muted);margin-bottom:1.5rem;">Consulte le statut de vérification RPPS/ADELI du praticien connecté. Rôle requis : <code>pro</code></p>

  <section aria-labelledby="verification-status-heading">
    <h2 id="verification-status-heading" style="margin-bottom:1rem;">Statut de vérification</h2>
    <form id="verification-status-form" style="display:flex;flex-direction:column;gap:0.75rem;max-width:480px;">
      <label>
        Access token (Bearer, rôle pro)
        <input type="text" name="access_token" required
          style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
      </label>
      <button type="submit"
        style="padding:0.5rem 1rem;background:var(--accent);color:#fff;border:none;border-radius:4px;cursor:pointer;align-self:flex-start;">
        GET
      </button>
    </form>

    <p id="status-badge" style="margin-top:1rem;display:none;"></p>
    <pre id="status-result" style="margin-top:0.5rem;padding:1rem;background:var(--surface);border:1px solid var(--border);border-radius:4px;white-space:pre-wrap;font-size:0.875rem;min-height:3rem;"></pre>
  </section>

  <section id="help-rejected" aria-labelledby="help-heading" style="margin-top:1.5rem;display:none;">
    <h2 id="help-heading" style="margin-bottom:0.5rem;font-size:1rem;">Vérification rejetée</h2>
    <p style="color:var(--muted);font-size:0.875rem;">
      Votre RPPS ou ADELI n'a pas pu être validé par l'ANS. Vérifiez vos informations et relancez une vérification via
      <a href="/pro/verification">/pro/verification</a>.
    </p>
  </section>
</Default>

<style>
  pre.success { border-left: 4px solid green; }
  pre.error   { border-left: 4px solid red; }
  .badge { display:inline-block;padding:0.25rem 0.6rem;border-radius:4px;font-size:0.85rem;font-weight:600; }
  .badge-ok  { background:#166534;color:#bbf7d0; }
  .badge-err { background:#7f1d1d;color:#fecaca; }
  .status-pending  { display:inline-block;padding:0.25rem 0.75rem;border-radius:4px;font-weight:600;background:#78350f;color:#fef3c7; }
  .status-verified { display:inline-block;padding:0.25rem 0.75rem;border-radius:4px;font-weight:600;background:#14532d;color:#bbf7d0; }
  .status-rejected { display:inline-block;padding:0.25rem 0.75rem;border-radius:4px;font-weight:600;background:#7f1d1d;color:#fecaca; }
</style>

<script>
  import { apiFetch } from '../../lib/api.ts';

  const form = document.getElementById('verification-status-form') as HTMLFormElement;
  const statusBadge = document.getElementById('status-badge') as HTMLParagraphElement;
  const statusResult = document.getElementById('status-result') as HTMLPreElement;
  const helpRejected = document.getElementById('help-rejected') as HTMLElement;

  const STATUS_LABELS: Record<string, string> = {
    pending: 'En attente',
    verified: 'Vérifié',
    rejected: 'Rejeté',
  };
  const STATUS_CSS: Record<string, string> = {
    pending: 'status-pending',
    verified: 'status-verified',
    rejected: 'status-rejected',
  };

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(form);
    const access_token = fd.get('access_token') as string;

    statusResult.className = '';
    statusResult.textContent = 'Chargement…';
    statusBadge.style.display = 'none';
    helpRejected.style.display = 'none';

    try {
      const { status: httpStatus, data } = await apiFetch('/v1/pro/verification', {
        method: 'GET',
        headers: { 'Authorization': `Bearer ${access_token}` },
      });

      statusResult.className = httpStatus < 300 ? 'success' : 'error';
      statusResult.textContent = `HTTP ${httpStatus}\n${data !== null ? JSON.stringify(data, null, 2) : '(aucun contenu)'}`;
      statusBadge.innerHTML = `<span class="badge ${httpStatus < 300 ? 'badge-ok' : 'badge-err'}">HTTP ${httpStatus}</span>`;
      statusBadge.style.display = 'block';

      if (httpStatus === 200 && data !== null && typeof data === 'object') {
        const verif = data as { status?: string };
        const s = verif.status ?? '';
        if (s in STATUS_LABELS) {
          statusBadge.innerHTML += ` <span class="${STATUS_CSS[s]}">${STATUS_LABELS[s]}</span>`;
        }
        if (s === 'rejected') {
          helpRejected.style.display = 'block';
        }
      }
    } catch (err) {
      statusResult.className = 'error';
      statusResult.textContent = `Erreur réseau : ${err instanceof Error ? err.message : String(err)}`;
    }
  });
</script>
