---
import DefaultAuth from '../../layouts/DefaultAuth.astro';
---
<DefaultAuth title="Ma mutuelle — Nubia">
  <h1>Ma mutuelle</h1>

  <section aria-live="polite" style="margin-top:1.5rem;">
    <p id="loading-msg">Chargement…</p>

    <div id="coverage-info" hidden>
      <p>Statut : <strong id="coverage-status"></strong></p>
    </div>

    <div id="no-coverage" hidden>
      <p>Aucune mutuelle enregistrée.</p>
      <button type="button"
        style="margin-top:1rem;padding:0.5rem 1rem;background:var(--accent);color:#fff;border:none;border-radius:4px;cursor:pointer;">
        Ajouter
      </button>
    </div>
  </section>

  <section style="margin-top:2.5rem;">
    <h2>Ma carte</h2>
    <label style="display:block;margin-top:0.75rem;">
      Importer votre carte mutuelle (PDF ou image)
      <input type="file" accept="image/*,.pdf" style="display:block;margin-top:0.5rem;" />
    </label>
  </section>
</DefaultAuth>

<script>
  import { apiFetch } from '../../lib/api.ts';

  const loadingMsg = document.getElementById('loading-msg') as HTMLParagraphElement;
  const coverageInfo = document.getElementById('coverage-info') as HTMLDivElement;
  const noCoverage = document.getElementById('no-coverage') as HTMLDivElement;
  const coverageStatus = document.getElementById('coverage-status') as HTMLElement;

  const jwt = localStorage.getItem('nubia_jwt');
  if (!jwt) {
    loadingMsg.hidden = true;
    noCoverage.hidden = false;
  } else {
    apiFetch('/v1/account/coverage', {
      method: 'GET',
      headers: { 'Authorization': `Bearer ${jwt}` },
    }).then(({ status, data }) => {
      loadingMsg.hidden = true;
      if (status === 404 || !data) {
        noCoverage.hidden = false;
      } else {
        const cov = data as Record<string, unknown>;
        coverageStatus.textContent = String(cov.status ?? '—');
        coverageInfo.hidden = false;
      }
    }).catch(() => {
      loadingMsg.hidden = true;
      noCoverage.hidden = false;
    });
  }
</script>
