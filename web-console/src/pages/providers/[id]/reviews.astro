---
import PublicLayout from '../../../layouts/PublicLayout.astro';

const { id } = Astro.params;
---
<PublicLayout title={`Avis praticien ${id} — Nubia`}>
  <header style="margin-bottom:1.5rem;">
    <h1>GET /v1/providers/<span id="provider-id-display">{id}</span>/reviews</h1>
    <p style="color:var(--muted);font-size:0.875rem;margin-top:0.25rem;">Avis publiés + note moyenne</p>
  </header>

  <section aria-label="Note moyenne" style="margin-bottom:1.5rem;">
    <p id="avg-rating" style="font-size:1.25rem;font-weight:600;"></p>
  </section>

  <section aria-label="Navigation pagination" style="margin-bottom:0.75rem;display:flex;gap:0.5rem;align-items:center;">
    <button id="btn-prev" type="button" disabled
      style="padding:0.375rem 0.75rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;cursor:pointer;font-size:0.875rem;"
      aria-label="Page précédente">← Préc.</button>
    <span id="page-info" style="font-size:0.875rem;color:var(--muted);"></span>
    <button id="btn-next" type="button" disabled
      style="padding:0.375rem 0.75rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;cursor:pointer;font-size:0.875rem;"
      aria-label="Page suivante">Suiv. →</button>
  </section>

  <p id="error-msg" role="alert" style="display:none;color:#fca5a5;margin-bottom:1rem;"></p>

  <section aria-label="Liste des avis">
    <table style="width:100%;border-collapse:collapse;font-size:0.875rem;">
      <thead>
        <tr>
          <th style="text-align:left;padding:0.5rem;border-bottom:1px solid var(--border);">review_id</th>
          <th style="text-align:left;padding:0.5rem;border-bottom:1px solid var(--border);">note</th>
          <th style="text-align:left;padding:0.5rem;border-bottom:1px solid var(--border);">commentaire</th>
          <th style="text-align:left;padding:0.5rem;border-bottom:1px solid var(--border);">date</th>
        </tr>
      </thead>
      <tbody id="reviews-tbody">
        <tr id="loading-row">
          <td colspan="4" style="padding:0.5rem;color:var(--muted);">Chargement…</td>
        </tr>
      </tbody>
    </table>
  </section>
</PublicLayout>

<style>
  #reviews-tbody td { padding: 0.5rem; border-bottom: 1px solid var(--border); }
</style>

<script>
  import { apiFetch } from '../../../lib/api.ts';

  const tbody = document.getElementById('reviews-tbody') as HTMLTableSectionElement;
  const errorMsg = document.getElementById('error-msg') as HTMLParagraphElement;
  const avgRating = document.getElementById('avg-rating') as HTMLParagraphElement;
  const pageInfo = document.getElementById('page-info') as HTMLSpanElement;
  const btnPrev = document.getElementById('btn-prev') as HTMLButtonElement;
  const btnNext = document.getElementById('btn-next') as HTMLButtonElement;

  const providerId = document.getElementById('provider-id-display')?.textContent ?? '';

  let currentPage = 1;
  let totalPages = 1;

  async function load(page: number) {
    tbody.innerHTML = '<tr><td colspan="4" style="padding:0.5rem;color:var(--muted);">Chargement…</td></tr>';
    errorMsg.style.display = 'none';
    avgRating.textContent = '';

    try {
      const { status, data } = await apiFetch(
        `/v1/providers/${encodeURIComponent(providerId)}/reviews?page=${page}&per_page=20`,
      );

      if (status === 404) {
        tbody.innerHTML = '';
        errorMsg.textContent = 'Praticien introuvable (404).';
        errorMsg.style.display = 'block';
        btnPrev.disabled = true;
        btnNext.disabled = true;
        pageInfo.textContent = '';
        return;
      }

      if (status >= 300) {
        tbody.innerHTML = '';
        errorMsg.textContent = `Erreur HTTP ${status} : ${JSON.stringify(data)}`;
        errorMsg.style.display = 'block';
        return;
      }

      const result = data as {
        data?: Array<Record<string, unknown>>;
        page?: { current: number; total: number; per_page: number };
        rating_avg?: number;
      };

      const reviews = result.data ?? (Array.isArray(data) ? (data as Array<Record<string, unknown>>) : []);

      if (result.rating_avg != null) {
        avgRating.textContent = `Note moyenne : ${result.rating_avg} / 5`;
      }

      if (result.page) {
        currentPage = result.page.current ?? page;
        totalPages = result.page.total ?? 1;
      } else {
        currentPage = page;
        totalPages = page;
      }
      pageInfo.textContent = `Page ${currentPage} / ${totalPages}`;
      btnPrev.disabled = currentPage <= 1;
      btnNext.disabled = currentPage >= totalPages;

      tbody.innerHTML = '';
      if (reviews.length === 0) {
        tbody.innerHTML = '<tr><td colspan="4" style="color:var(--muted);padding:0.5rem;">Aucun avis publié.</td></tr>';
      } else {
        for (const r of reviews) {
          const tr = document.createElement('tr');
          const stars = r.rating != null ? '★'.repeat(Number(r.rating)) + '☆'.repeat(5 - Number(r.rating)) : '—';
          tr.innerHTML = [
            String(r.review_id ?? r.id ?? '—'),
            stars,
            String(r.comment ?? r.commentaire ?? ''),
            String(r.created_at ?? r.date ?? '—'),
          ].map(v => `<td>${v}</td>`).join('');
          tbody.appendChild(tr);
        }
      }
    } catch (err) {
      tbody.innerHTML = '';
      errorMsg.textContent = `Erreur réseau : ${err instanceof Error ? err.message : String(err)}`;
      errorMsg.style.display = 'block';
    }
  }

  btnPrev.addEventListener('click', () => { if (currentPage > 1) load(currentPage - 1); });
  btnNext.addEventListener('click', () => { if (currentPage < totalPages) load(currentPage + 1); });

  load(1);
</script>
