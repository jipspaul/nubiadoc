---
import PublicLayout from '../../layouts/PublicLayout.astro';
---
<PublicLayout title="Spécialités — Nubia Marketplace">
  <h1 style="margin-bottom:1rem;">GET /v1/specialties</h1>
  <form id="filter-form" style="display:flex;gap:0.5rem;margin-bottom:1rem;align-items:center;">
    <label for="profession-id-input" style="font-size:0.875rem;">profession_id</label>
    <input
      id="profession-id-input"
      type="text"
      name="profession_id"
      placeholder="(optionnel)"
      style="background:var(--surface);border:1px solid var(--border);color:var(--text);padding:0.375rem 0.5rem;border-radius:4px;font-size:0.875rem;"
    />
    <button
      type="submit"
      style="background:var(--accent);color:#fff;border:none;padding:0.375rem 0.75rem;border-radius:4px;cursor:pointer;font-size:0.875rem;"
    >Charger</button>
  </form>
  <p id="error-msg" role="alert" style="display:none;color:#fca5a5;margin-bottom:1rem;"></p>
  <table style="width:100%;border-collapse:collapse;font-size:0.875rem;">
    <thead>
      <tr>
        <th style="text-align:left;padding:0.5rem;border-bottom:1px solid var(--border);">id</th>
        <th style="text-align:left;padding:0.5rem;border-bottom:1px solid var(--border);">profession_id</th>
        <th style="text-align:left;padding:0.5rem;border-bottom:1px solid var(--border);">label</th>
      </tr>
    </thead>
    <tbody id="specialties-tbody">
      <tr id="loading-row">
        <td colspan="3" style="padding:0.5rem;color:var(--muted);">Chargement…</td>
      </tr>
    </tbody>
  </table>
</PublicLayout>

<style>
  td { padding: 0.5rem; border-bottom: 1px solid var(--border); }
</style>

<script>
  import { apiFetch } from '../../lib/api.ts';

  const tbody = document.getElementById('specialties-tbody') as HTMLTableSectionElement;
  const errorMsg = document.getElementById('error-msg') as HTMLParagraphElement;
  const form = document.getElementById('filter-form') as HTMLFormElement;
  const input = document.getElementById('profession-id-input') as HTMLInputElement;

  async function load(professionId?: string) {
    tbody.innerHTML = '<tr><td colspan="3" style="padding:0.5rem;color:var(--muted);">Chargement…</td></tr>';
    errorMsg.style.display = 'none';
    const path = professionId ? `/v1/specialties?profession_id=${encodeURIComponent(professionId)}` : '/v1/specialties';
    try {
      const { status, data } = await apiFetch(path);
      tbody.innerHTML = '';
      if (status >= 300) {
        errorMsg.textContent = `Erreur HTTP ${status} : ${JSON.stringify(data)}`;
        errorMsg.style.display = 'block';
        return;
      }
      if (Array.isArray(data) && data.length > 0) {
        for (const s of data as Array<Record<string, unknown>>) {
          const tr = document.createElement('tr');
          tr.innerHTML = `<td>${s.id ?? ''}</td><td>${s.profession_id ?? ''}</td><td>${s.label ?? ''}</td>`;
          tbody.appendChild(tr);
        }
      } else {
        tbody.innerHTML = '<tr><td colspan="3" style="color:var(--muted);">Aucune spécialité.</td></tr>';
      }
    } catch (err) {
      tbody.innerHTML = '';
      errorMsg.textContent = `Erreur réseau : ${err instanceof Error ? err.message : String(err)}`;
      errorMsg.style.display = 'block';
    }
  }

  form.addEventListener('submit', (e) => {
    e.preventDefault();
    load(input.value.trim() || undefined);
  });

  load();
</script>
