---
import AppShell from '../../layouts/AppShell.astro';

const jwt  = Astro.cookies.get('nubia_jwt')?.value;
const role = Astro.cookies.get('nubia_role')?.value;

if (!jwt) {
  return Astro.redirect(`/auth/login?next=${encodeURIComponent(Astro.url.pathname)}`);
}
if (role !== 'practitioner' && role !== 'admin') {
  return new Response('Accès interdit', { status: 403 });
}
---
<AppShell title="Mes secrétariats — Nubia" role="practitioner">
  <header>
    <h1>Mes secrétariats</h1>
    <p>Assignation de votre agenda et de vos patients à un secrétariat de l'établissement actif.</p>
  </header>

  <!-- ── 1. Secrétariats de l'établissement — GET /v1/cabinet/secretariats ── -->
  <section aria-labelledby="h-all">
    <h2 id="h-all">Secrétariats de l'établissement — <code>GET /v1/cabinet/secretariats</code></h2>
    <div id="all-status" role="status" aria-live="polite"></div>
    <ul id="all-list" aria-label="Liste des secrétariats"></ul>
  </section>

  <!-- ── 2. Mes assignations actuelles — GET /v1/cabinet/providers/:id/secretariats ── -->
  <section aria-labelledby="h-mine">
    <h2 id="h-mine">Mes assignations actuelles — <code>GET /v1/cabinet/providers/:id/secretariats</code></h2>
    <p id="mine-provider-info" class="provider-info"></p>
    <div id="mine-status" role="status" aria-live="polite"></div>
    <ul id="mine-list" aria-label="Secrétariats assignés au praticien connecté"></ul>
  </section>

  <!-- ── 3. Modifier l'assignation — PUT /v1/cabinet/providers/:id/secretariats ── -->
  <section aria-labelledby="h-assign">
    <h2 id="h-assign">Modifier l'assignation — <code>PUT /v1/cabinet/providers/:id/secretariats</code></h2>
    <form id="form-assign" method="dialog">
      <label>
        Provider ID <span aria-hidden="true">*</span>
        <input type="text" id="assign-provider-id" name="provider_id" required placeholder="uuid du praticien" />
        <span class="field-hint">Rempli automatiquement depuis <code>/v1/me</code></span>
      </label>
      <label>
        IDs des secrétariats (un par ligne) <span aria-hidden="true">*</span>
        <textarea
          id="assign-secretariat-ids"
          name="secretariat_ids"
          rows="4"
          required
          placeholder="uuid-secrétariat-1&#10;uuid-secrétariat-2"
          aria-describedby="assign-ids-hint"
        ></textarea>
        <span class="field-hint" id="assign-ids-hint">Un UUID par ligne. Laisser vide pour désassigner tous les secrétariats.</span>
      </label>
      <button type="submit">Assigner</button>
    </form>
    <p id="badge-assign" aria-live="polite"></p>
    <pre id="result-assign" aria-label="Résultat PUT /v1/cabinet/providers/:id/secretariats"></pre>
  </section>
</AppShell>

<style>
  header { margin-bottom: var(--space-6); }
  h1 { margin-bottom: var(--space-1); }
  header > p { color: var(--color-muted); font-size: var(--font-size-sm); }

  section {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-6);
    max-width: 560px;
    margin-bottom: var(--space-6);
  }

  h2 {
    margin: 0 0 var(--space-4);
    font-size: var(--font-size-base);
    font-weight: 600;
  }

  ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  li {
    padding: var(--space-2) var(--space-3);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    font-size: var(--font-size-sm);
  }

  .secretariat-name { font-weight: 600; }
  .secretariat-id { color: var(--color-muted); font-family: ui-monospace, monospace; font-size: var(--font-size-xs); }

  .provider-info {
    font-size: var(--font-size-sm);
    color: var(--color-muted);
    margin: 0 0 var(--space-3);
  }

  form {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  label {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    font-size: var(--font-size-sm);
    font-weight: 500;
  }

  .field-hint {
    font-size: var(--font-size-xs);
    color: var(--color-muted);
    font-weight: 400;
  }

  input[type="text"],
  textarea {
    padding: var(--space-2);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    color: var(--color-text);
    border-radius: var(--radius-sm);
    font-size: var(--font-size-sm);
    width: 100%;
    font-family: inherit;
  }

  textarea { resize: vertical; font-family: ui-monospace, monospace; }

  button[type="submit"] {
    padding: var(--space-2) var(--space-4);
    background: var(--color-accent);
    color: var(--color-accent-fg);
    border: none;
    border-radius: var(--radius-sm);
    cursor: pointer;
    font-size: var(--font-size-sm);
    font-weight: 600;
    align-self: flex-start;
  }

  button[type="submit"]:hover { opacity: 0.9; }

  pre {
    margin-top: var(--space-3);
    padding: var(--space-3);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    white-space: pre-wrap;
    font-size: var(--font-size-sm);
    min-height: 2.5rem;
  }

  pre.success { border-left: 4px solid green; }
  pre.error   { border-left: 4px solid red; }

  .badge {
    display: inline-block;
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-sm);
    font-size: var(--font-size-sm);
    font-weight: 600;
  }
  .badge-ok  { background: #166534; color: #bbf7d0; }
  .badge-err { background: #7f1d1d; color: #fecaca; }

  [role="status"] {
    font-size: var(--font-size-sm);
    min-height: 1.25rem;
    margin-bottom: var(--space-2);
    color: var(--color-muted);
  }

  [role="status"].error { color: var(--color-error-fg); }

  .empty-hint {
    color: var(--color-muted);
    font-size: var(--font-size-sm);
    margin: 0;
    padding: var(--space-3) 0;
  }
</style>

<script>
  import { auth, proSecretariats } from '../../lib/endpoints.ts';
  import type { Secretariat } from '../../lib/endpoints.ts';

  // ── Resolve current provider ID via GET /v1/me ────────────────────────────
  let currentProviderId = '';

  async function resolveProviderId(): Promise<string> {
    try {
      const { status, data } = await auth.me();
      if (status === 200 && data) {
        const me = data as { id?: string; account_id?: string };
        return (me.id ?? me.account_id ?? '').toString();
      }
    } catch {
      // ignore — user can fill manually
    }
    return '';
  }

  function renderSecretariatItem(s: Secretariat): HTMLLIElement {
    const li = document.createElement('li');
    const name = document.createElement('span');
    name.className = 'secretariat-name';
    name.textContent = s.name ?? '(sans nom)';
    const id = document.createElement('span');
    id.className = 'secretariat-id';
    id.textContent = ` — ${s.id}`;
    li.appendChild(name);
    li.appendChild(id);
    return li;
  }

  // ── 1. GET /v1/cabinet/secretariats ───────────────────────────────────────
  const allStatus = document.getElementById('all-status') as HTMLElement;
  const allList   = document.getElementById('all-list')   as HTMLUListElement;

  async function loadAllSecretariats(): Promise<void> {
    allStatus.textContent = 'Chargement…';
    allStatus.className = '';
    try {
      const { status, data } = await proSecretariats.list();
      if (status === 401) { window.location.href = '/auth/login?next=/praticien/secretariats'; return; }
      if (status === 403) { allStatus.textContent = 'Accès refusé (403).'; allStatus.className = 'error'; return; }
      if (status !== 200) { allStatus.textContent = `Erreur serveur (HTTP ${status}).`; allStatus.className = 'error'; return; }

      allStatus.textContent = '';
      allList.innerHTML = '';
      const list = (data as Secretariat[]) ?? [];

      if (list.length === 0) {
        const p = document.createElement('p');
        p.className = 'empty-hint';
        p.textContent = 'Aucun secrétariat trouvé pour cet établissement.';
        allList.appendChild(p);
      } else {
        list.forEach((s) => allList.appendChild(renderSecretariatItem(s)));
      }
    } catch (err) {
      allStatus.textContent = `Erreur réseau : ${err instanceof Error ? err.message : String(err)}`;
      allStatus.className = 'error';
    }
  }

  // ── 2. GET /v1/cabinet/providers/:id/secretariats ─────────────────────────
  const mineStatus      = document.getElementById('mine-status')       as HTMLElement;
  const mineList        = document.getElementById('mine-list')          as HTMLUListElement;
  const mineProviderInfo = document.getElementById('mine-provider-info') as HTMLParagraphElement;
  const assignProviderInput = document.getElementById('assign-provider-id') as HTMLInputElement;

  async function loadMySecretariats(providerId: string): Promise<void> {
    mineStatus.textContent = 'Chargement…';
    mineStatus.className = '';
    mineList.innerHTML = '';
    try {
      const { status, data } = await proSecretariats.getForProvider(providerId);
      if (status === 401) { window.location.href = '/auth/login?next=/praticien/secretariats'; return; }
      if (status === 403) { mineStatus.textContent = 'Accès refusé (403).'; mineStatus.className = 'error'; return; }
      if (status !== 200) { mineStatus.textContent = `Erreur serveur (HTTP ${status}).`; mineStatus.className = 'error'; return; }

      mineStatus.textContent = '';
      const list = (data as Secretariat[]) ?? [];

      if (list.length === 0) {
        const p = document.createElement('p');
        p.className = 'empty-hint';
        p.textContent = 'Aucun secrétariat assigné.';
        mineList.appendChild(p);
      } else {
        list.forEach((s) => mineList.appendChild(renderSecretariatItem(s)));
      }
    } catch (err) {
      mineStatus.textContent = `Erreur réseau : ${err instanceof Error ? err.message : String(err)}`;
      mineStatus.className = 'error';
    }
  }

  // ── 3. PUT /v1/cabinet/providers/:id/secretariats ─────────────────────────
  const formAssign   = document.getElementById('form-assign')    as HTMLFormElement;
  const badgeAssign  = document.getElementById('badge-assign')   as HTMLParagraphElement;
  const resultAssign = document.getElementById('result-assign')  as HTMLPreElement;
  const secretariatIdsInput = document.getElementById('assign-secretariat-ids') as HTMLTextAreaElement;

  formAssign.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(formAssign);
    const providerId = (fd.get('provider_id') as string).trim();
    const rawIds = (fd.get('secretariat_ids') as string)
      .split('\n')
      .map((l) => l.trim())
      .filter(Boolean);

    resultAssign.className = '';
    resultAssign.textContent = 'Enregistrement…';

    try {
      const { status, data } = await proSecretariats.putForProvider(providerId, {
        secretariat_ids: rawIds,
      });
      resultAssign.className = status < 300 ? 'success' : 'error';
      resultAssign.textContent = `HTTP ${status}\n${data !== null ? JSON.stringify(data, null, 2) : '(aucun contenu)'}`;
      badgeAssign.innerHTML = `<span class="badge ${status < 300 ? 'badge-ok' : 'badge-err'}">HTTP ${status}</span>`;

      if (status < 300) {
        void loadMySecretariats(providerId);
      }
    } catch (err) {
      resultAssign.className = 'error';
      resultAssign.textContent = `Erreur réseau : ${err instanceof Error ? err.message : String(err)}`;
    }
  });

  // ── Init ──────────────────────────────────────────────────────────────────
  async function init(): Promise<void> {
    currentProviderId = await resolveProviderId();

    if (currentProviderId) {
      mineProviderInfo.textContent = `Provider ID détecté : ${currentProviderId}`;
      assignProviderInput.value = currentProviderId;
      secretariatIdsInput.placeholder = 'uuid-secrétariat-1\nuuid-secrétariat-2';
    } else {
      mineProviderInfo.textContent = 'Provider ID non détecté — renseignez-le manuellement ci-dessous.';
    }

    void loadAllSecretariats();

    if (currentProviderId) {
      void loadMySecretariats(currentProviderId);
    } else {
      mineStatus.textContent = 'Entrez votre provider_id dans la section "Modifier l\'assignation" pour voir vos assignations actuelles.';
    }
  }

  void init();
</script>
