---
import AppShell from '../../layouts/AppShell.astro';
---
<AppShell title="Agenda — Nubia" role="practitioner">
  <header>
    <h1>Agenda praticien</h1>
    <p>Visualisation et gestion des créneaux de disponibilité.</p>
  </header>

  <!-- ── 1. GET /v1/cabinet/agenda ──────────────────────────────────── -->
  <section aria-labelledby="h-agenda">
    <h2 id="h-agenda">Consulter l'agenda — <code>GET /v1/cabinet/agenda</code></h2>
    <form id="form-agenda" method="dialog">
      <label>
        Date <span aria-hidden="true">*</span>
        <input type="date" name="date" required />
      </label>
      <label>
        Vue
        <select name="view">
          <option value="day">day</option>
          <option value="week">week</option>
        </select>
      </label>
      <label>
        Praticien ID (optionnel)
        <input type="text" name="practitioner_id" placeholder="uuid" />
      </label>
      <button type="submit">Consulter</button>
    </form>
    <p id="badge-agenda" aria-live="polite"></p>
    <pre id="result-agenda" aria-label="Résultat GET /v1/cabinet/agenda"></pre>
  </section>

  <!-- ── 2. POST /v1/cabinet/slots ──────────────────────────────────── -->
  <section aria-labelledby="h-create">
    <h2 id="h-create">Créer un créneau — <code>POST /v1/cabinet/slots</code></h2>
    <form id="form-create" method="dialog">
      <label>
        Praticien ID <span aria-hidden="true">*</span>
        <input type="text" name="practitioner_id" required placeholder="uuid" />
      </label>
      <label>
        Début <span aria-hidden="true">*</span>
        <input type="datetime-local" name="starts_at" required />
      </label>
      <label>
        Fin <span aria-hidden="true">*</span>
        <input type="datetime-local" name="ends_at" required />
      </label>
      <label>
        Statut
        <select name="status">
          <option value="open">open</option>
          <option value="blocked">blocked</option>
        </select>
      </label>
      <label>
        Motif (optionnel)
        <input type="text" name="motif" placeholder="consultation, urgence…" />
      </label>
      <button type="submit">Créer</button>
    </form>
    <p id="badge-create" aria-live="polite"></p>
    <pre id="result-create" aria-label="Résultat POST /v1/cabinet/slots"></pre>
  </section>

  <!-- ── 3. PATCH /v1/cabinet/slots/:id ─────────────────────────────── -->
  <section aria-labelledby="h-patch">
    <h2 id="h-patch">Modifier un créneau — <code>PATCH /v1/cabinet/slots/:id</code></h2>
    <form id="form-patch" method="dialog">
      <label>
        Slot ID <span aria-hidden="true">*</span>
        <input type="text" name="slot_id" required placeholder="uuid du créneau" />
      </label>
      <label>
        Début (optionnel)
        <input type="datetime-local" name="starts_at" />
      </label>
      <label>
        Fin (optionnel)
        <input type="datetime-local" name="ends_at" />
      </label>
      <label>
        Motif (optionnel)
        <input type="text" name="motif" placeholder="consultation, urgence…" />
      </label>
      <button type="submit">Modifier</button>
    </form>
    <p id="badge-patch" aria-live="polite"></p>
    <pre id="result-patch" aria-label="Résultat PATCH /v1/cabinet/slots/:id"></pre>
  </section>

  <!-- ── 4. DELETE /v1/cabinet/slots/:id ────────────────────────────── -->
  <section aria-labelledby="h-delete">
    <h2 id="h-delete">Supprimer un créneau — <code>DELETE /v1/cabinet/slots/:id</code></h2>
    <form id="form-delete" method="dialog">
      <label>
        Slot ID <span aria-hidden="true">*</span>
        <input type="text" name="slot_id" required placeholder="uuid du créneau" />
      </label>
      <button type="submit" class="btn-danger">Supprimer</button>
    </form>
    <p id="badge-delete" aria-live="polite"></p>
    <pre id="result-delete" aria-label="Résultat DELETE /v1/cabinet/slots/:id"></pre>
  </section>

  <!-- ── 5. PUT /v1/cabinet/slots/:id/online ────────────────────────── -->
  <section aria-labelledby="h-online">
    <h2 id="h-online">Listing en ligne — <code>PUT /v1/cabinet/slots/:id/online</code></h2>
    <form id="form-online" method="dialog">
      <label>
        Slot ID <span aria-hidden="true">*</span>
        <input type="text" name="slot_id" required placeholder="uuid du créneau" />
      </label>
      <fieldset>
        <legend>Exposé en ligne</legend>
        <label>
          <input type="radio" name="online" value="true" required /> Activer
        </label>
        <label>
          <input type="radio" name="online" value="false" required /> Désactiver
        </label>
      </fieldset>
      <button type="submit">Mettre à jour</button>
    </form>
    <p id="badge-online" aria-live="polite"></p>
    <pre id="result-online" aria-label="Résultat PUT /v1/cabinet/slots/:id/online"></pre>
  </section>
</AppShell>

<style>
  header { margin-bottom: var(--space-6); }
  h1 { margin-bottom: var(--space-1); }
  header > p { color: var(--color-muted); font-size: var(--font-size-sm); }

  section {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-6);
    max-width: 520px;
    margin-bottom: var(--space-6);
  }

  h2 {
    margin: 0 0 var(--space-4);
    font-size: var(--font-size-base);
  }

  form {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  label {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    font-size: var(--font-size-sm);
    font-weight: 500;
  }

  input[type="text"],
  input[type="date"],
  input[type="datetime-local"],
  select {
    padding: var(--space-2);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    color: var(--color-text);
    border-radius: var(--radius-sm);
    font-size: var(--font-size-sm);
    width: 100%;
  }

  fieldset {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  legend { font-size: var(--font-size-sm); font-weight: 600; padding: 0 var(--space-1); }

  fieldset label {
    flex-direction: row;
    align-items: center;
    gap: var(--space-2);
    font-weight: 400;
    cursor: pointer;
  }

  button[type="submit"] {
    padding: var(--space-2) var(--space-4);
    background: var(--color-accent);
    color: var(--color-accent-fg);
    border: none;
    border-radius: var(--radius-sm);
    cursor: pointer;
    font-size: var(--font-size-sm);
    font-weight: 600;
    align-self: flex-start;
  }

  button[type="submit"]:hover { opacity: 0.9; }

  button.btn-danger {
    background: var(--color-error);
    color: var(--color-error-fg);
  }

  pre {
    margin-top: var(--space-3);
    padding: var(--space-3);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    white-space: pre-wrap;
    font-size: var(--font-size-sm);
    min-height: 2.5rem;
  }

  pre.success { border-left: 4px solid green; }
  pre.error   { border-left: 4px solid red; }

  .badge {
    display: inline-block;
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-sm);
    font-size: var(--font-size-sm);
    font-weight: 600;
  }
  .badge-ok  { background: #166534; color: #bbf7d0; }
  .badge-err { background: #7f1d1d; color: #fecaca; }
</style>

<script>
  import { apiFetch } from '../../lib/api.ts';

  function showResult(
    resultEl: HTMLPreElement,
    badgeEl: HTMLParagraphElement,
    httpStatus: number,
    data: unknown,
  ): void {
    resultEl.className = httpStatus < 300 ? 'success' : 'error';
    resultEl.textContent = `HTTP ${httpStatus}\n${data !== null ? JSON.stringify(data, null, 2) : '(aucun contenu)'}`;
    badgeEl.innerHTML = `<span class="badge ${httpStatus < 300 ? 'badge-ok' : 'badge-err'}">HTTP ${httpStatus}</span>`;
  }

  // ── 1. GET /v1/cabinet/agenda ─────────────────────────────────────────
  const formAgenda = document.getElementById('form-agenda') as HTMLFormElement;
  const resultAgenda = document.getElementById('result-agenda') as HTMLPreElement;
  const badgeAgenda = document.getElementById('badge-agenda') as HTMLParagraphElement;

  formAgenda.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(formAgenda);
    const date = fd.get('date') as string;
    const view = fd.get('view') as string;
    const practitioner_id = fd.get('practitioner_id') as string;

    resultAgenda.className = '';
    resultAgenda.textContent = 'Chargement…';

    const params = new URLSearchParams({ date, view });
    if (practitioner_id) params.set('practitioner_id', practitioner_id);

    try {
      const { status, data } = await apiFetch(`/v1/cabinet/agenda?${params.toString()}`);
      showResult(resultAgenda, badgeAgenda, status, data);
    } catch (err) {
      resultAgenda.className = 'error';
      resultAgenda.textContent = `Erreur réseau : ${err instanceof Error ? err.message : String(err)}`;
    }
  });

  // ── 2. POST /v1/cabinet/slots ─────────────────────────────────────────
  const formCreate = document.getElementById('form-create') as HTMLFormElement;
  const resultCreate = document.getElementById('result-create') as HTMLPreElement;
  const badgeCreate = document.getElementById('badge-create') as HTMLParagraphElement;

  formCreate.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(formCreate);
    const body: Record<string, unknown> = {
      practitioner_id: fd.get('practitioner_id') as string,
      starts_at: new Date(fd.get('starts_at') as string).toISOString(),
      ends_at: new Date(fd.get('ends_at') as string).toISOString(),
      status: fd.get('status') as string,
    };
    const motif = fd.get('motif') as string;
    if (motif) body.motif = motif;

    resultCreate.className = '';
    resultCreate.textContent = 'Chargement…';

    try {
      const { status, data } = await apiFetch('/v1/cabinet/slots', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });
      showResult(resultCreate, badgeCreate, status, data);
    } catch (err) {
      resultCreate.className = 'error';
      resultCreate.textContent = `Erreur réseau : ${err instanceof Error ? err.message : String(err)}`;
    }
  });

  // ── 3. PATCH /v1/cabinet/slots/:id ───────────────────────────────────
  const formPatch = document.getElementById('form-patch') as HTMLFormElement;
  const resultPatch = document.getElementById('result-patch') as HTMLPreElement;
  const badgePatch = document.getElementById('badge-patch') as HTMLParagraphElement;

  formPatch.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(formPatch);
    const slot_id = fd.get('slot_id') as string;
    const body: Record<string, unknown> = {};
    const starts_at = fd.get('starts_at') as string;
    const ends_at = fd.get('ends_at') as string;
    const motif = fd.get('motif') as string;
    if (starts_at) body.starts_at = new Date(starts_at).toISOString();
    if (ends_at) body.ends_at = new Date(ends_at).toISOString();
    if (motif) body.motif = motif;

    resultPatch.className = '';
    resultPatch.textContent = 'Chargement…';

    try {
      const { status, data } = await apiFetch(`/v1/cabinet/slots/${slot_id}`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });
      showResult(resultPatch, badgePatch, status, data);
    } catch (err) {
      resultPatch.className = 'error';
      resultPatch.textContent = `Erreur réseau : ${err instanceof Error ? err.message : String(err)}`;
    }
  });

  // ── 4. DELETE /v1/cabinet/slots/:id ──────────────────────────────────
  const formDelete = document.getElementById('form-delete') as HTMLFormElement;
  const resultDelete = document.getElementById('result-delete') as HTMLPreElement;
  const badgeDelete = document.getElementById('badge-delete') as HTMLParagraphElement;

  formDelete.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(formDelete);
    const slot_id = fd.get('slot_id') as string;

    resultDelete.className = '';
    resultDelete.textContent = 'Chargement…';

    try {
      const { status, data } = await apiFetch(`/v1/cabinet/slots/${slot_id}`, {
        method: 'DELETE',
      });
      showResult(resultDelete, badgeDelete, status, data);
    } catch (err) {
      resultDelete.className = 'error';
      resultDelete.textContent = `Erreur réseau : ${err instanceof Error ? err.message : String(err)}`;
    }
  });

  // ── 5. PUT /v1/cabinet/slots/:id/online ──────────────────────────────
  const formOnline = document.getElementById('form-online') as HTMLFormElement;
  const resultOnline = document.getElementById('result-online') as HTMLPreElement;
  const badgeOnline = document.getElementById('badge-online') as HTMLParagraphElement;

  formOnline.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(formOnline);
    const slot_id = fd.get('slot_id') as string;
    const online = fd.get('online') === 'true';

    resultOnline.className = '';
    resultOnline.textContent = 'Chargement…';

    try {
      const { status, data } = await apiFetch(`/v1/cabinet/slots/${slot_id}/online`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ online }),
      });
      showResult(resultOnline, badgeOnline, status, data);
    } catch (err) {
      resultOnline.className = 'error';
      resultOnline.textContent = `Erreur réseau : ${err instanceof Error ? err.message : String(err)}`;
    }
  });
</script>
