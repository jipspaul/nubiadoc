---
import AppShell from '../../layouts/AppShell.astro';

const jwt  = Astro.cookies.get('nubia_jwt')?.value;
const role = Astro.cookies.get('nubia_role')?.value;

if (!jwt) {
  return Astro.redirect(`/auth/login?next=${encodeURIComponent(Astro.url.pathname)}`);
}
if (role !== 'practitioner' && role !== 'admin') {
  return new Response('Accès interdit', { status: 403 });
}
---
<AppShell title="Tableau de bord — Espace praticien" role="practitioner">
  <header>
    <h1>Tableau de bord praticien</h1>
    <p>Vue journée clinique : agenda du jour, rendez-vous et salle d'attente.</p>
  </header>

  <!-- ── Agenda du jour — GET /v1/cabinet/agenda ──────────────────────── -->
  <section aria-labelledby="h-agenda">
    <h2 id="h-agenda">Agenda du jour</h2>
    <div id="agenda-status" role="status" aria-live="polite"></div>
    <div id="agenda-content" hidden>
      <table id="agenda-table" aria-label="Créneaux et rendez-vous du jour">
        <thead>
          <tr>
            <th scope="col">Horaire</th>
            <th scope="col">Type</th>
            <th scope="col">Statut</th>
            <th scope="col">Info</th>
          </tr>
        </thead>
        <tbody id="agenda-tbody"></tbody>
      </table>
    </div>
  </section>

  <!-- ── Rendez-vous du jour — GET /v1/cabinet/appointments ─────────────── -->
  <section aria-labelledby="h-appointments">
    <h2 id="h-appointments">Rendez-vous du jour</h2>
    <div id="appointments-status" role="status" aria-live="polite"></div>
    <div id="appointments-content" hidden>
      <table id="appointments-table" aria-label="Liste des rendez-vous du jour">
        <thead>
          <tr>
            <th scope="col">Horaire</th>
            <th scope="col">Patient</th>
            <th scope="col">Statut</th>
          </tr>
        </thead>
        <tbody id="appointments-tbody"></tbody>
      </table>
      <p id="appointments-empty" hidden class="empty-hint">Aucun rendez-vous pour aujourd'hui.</p>
    </div>
  </section>

  <!-- ── Salle d'attente — GET /v1/cabinet/waiting-room ────────────────── -->
  <section aria-labelledby="h-waiting">
    <h2 id="h-waiting">Salle d'attente</h2>
    <div id="waiting-status" role="status" aria-live="polite"></div>
    <div id="waiting-content" hidden>
      <p id="waiting-next" class="next-patient" hidden></p>
      <p id="waiting-empty" hidden class="empty-hint">Salle d'attente vide.</p>
    </div>
  </section>
</AppShell>

<style>
  header { margin-bottom: var(--space-6); }
  h1 { margin-bottom: var(--space-1); }
  header > p { color: var(--color-muted); font-size: var(--font-size-sm); }

  section {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-6);
    margin-bottom: var(--space-6);
  }

  h2 {
    margin: 0 0 var(--space-4);
    font-size: var(--font-size-base);
    font-weight: 600;
  }

  table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--font-size-sm);
  }

  th, td {
    padding: var(--space-2) var(--space-3);
    text-align: left;
    border-bottom: 1px solid var(--color-border);
  }

  th {
    color: var(--color-muted);
    font-weight: 600;
  }

  tr:last-child td { border-bottom: none; }

  .empty-hint {
    color: var(--color-muted);
    font-size: var(--font-size-sm);
    margin: 0;
    padding: var(--space-4) 0;
  }

  .next-patient {
    font-size: var(--font-size-base);
    font-weight: 600;
    color: var(--color-accent);
    margin: 0;
    padding: var(--space-3);
    background: var(--color-surface);
    border: 1px solid var(--color-accent);
    border-radius: var(--radius-sm);
  }

  [role="status"] {
    font-size: var(--font-size-sm);
    min-height: 1.25rem;
    margin-bottom: var(--space-2);
    color: var(--color-muted);
  }

  [role="status"].error { color: var(--color-error-fg); }
</style>

<script>
  import { proAgenda } from '../../lib/endpoints.ts';
  import type { AgendaEntry, Appointment, WaitingRoomEntry } from '../../lib/endpoints.ts';

  const todayIso = new Date().toISOString().slice(0, 10);

  // ── Agenda ────────────────────────────────────────────────────────────────
  const agendaStatus  = document.getElementById('agenda-status')  as HTMLElement;
  const agendaContent = document.getElementById('agenda-content') as HTMLElement;
  const agendaTbody   = document.getElementById('agenda-tbody')   as HTMLTableSectionElement;

  async function loadAgenda(): Promise<void> {
    agendaStatus.textContent = 'Chargement…';
    agendaStatus.className = '';
    try {
      const { status, data } = await proAgenda.get({ from: todayIso, to: todayIso });
      if (status === 401) { window.location.href = '/auth/login?next=/praticien/dashboard'; return; }
      if (status === 403) { agendaStatus.textContent = 'Accès refusé (403).'; agendaStatus.className = 'error'; return; }
      if (status !== 200) { agendaStatus.textContent = `Erreur serveur (HTTP ${status}).`; agendaStatus.className = 'error'; return; }

      agendaStatus.textContent = '';
      const entries = (data as AgendaEntry[]) ?? [];
      agendaTbody.innerHTML = '';

      entries.forEach((entry) => {
        const slots = entry.slots ?? [];
        const appts = entry.appointments ?? [];

        slots.forEach((slot) => {
          const tr = agendaTbody.insertRow();
          tr.insertCell().textContent = slot.starts_at ? new Date(slot.starts_at).toLocaleTimeString('fr-FR', { hour: '2-digit', minute: '2-digit' }) : '—';
          tr.insertCell().textContent = 'Créneau';
          tr.insertCell().textContent = '—';
          tr.insertCell().textContent = `${slot.duration_minutes ?? '?'} min`;
        });

        appts.forEach((appt) => {
          const tr = agendaTbody.insertRow();
          tr.insertCell().textContent = appt.scheduled_at ? new Date(appt.scheduled_at).toLocaleTimeString('fr-FR', { hour: '2-digit', minute: '2-digit' }) : '—';
          tr.insertCell().textContent = 'Rendez-vous';
          tr.insertCell().textContent = appt.status ?? '—';
          tr.insertCell().textContent = appt.notes ?? '—';
        });
      });

      agendaContent.hidden = false;
    } catch (err) {
      agendaStatus.textContent = `Erreur réseau : ${err instanceof Error ? err.message : String(err)}`;
      agendaStatus.className = 'error';
    }
  }

  // ── Appointments ──────────────────────────────────────────────────────────
  const appointmentsStatus  = document.getElementById('appointments-status')  as HTMLElement;
  const appointmentsContent = document.getElementById('appointments-content') as HTMLElement;
  const appointmentsTbody   = document.getElementById('appointments-tbody')   as HTMLTableSectionElement;
  const appointmentsEmpty   = document.getElementById('appointments-empty')   as HTMLElement;

  async function loadAppointments(): Promise<void> {
    appointmentsStatus.textContent = 'Chargement…';
    appointmentsStatus.className = '';
    try {
      const { status, data } = await proAgenda.getAppointments();
      if (status === 401) { window.location.href = '/auth/login?next=/praticien/dashboard'; return; }
      if (status === 403) { appointmentsStatus.textContent = 'Accès refusé (403).'; appointmentsStatus.className = 'error'; return; }
      if (status !== 200) { appointmentsStatus.textContent = `Erreur serveur (HTTP ${status}).`; appointmentsStatus.className = 'error'; return; }

      appointmentsStatus.textContent = '';
      const appts = (data as Appointment[]) ?? [];
      appointmentsTbody.innerHTML = '';

      const todayAppts = appts.filter((a) => a.scheduled_at?.startsWith(todayIso));

      if (todayAppts.length === 0) {
        appointmentsEmpty.hidden = false;
      } else {
        todayAppts.forEach((appt) => {
          const tr = appointmentsTbody.insertRow();
          tr.insertCell().textContent = new Date(appt.scheduled_at).toLocaleTimeString('fr-FR', { hour: '2-digit', minute: '2-digit' });
          tr.insertCell().textContent = appt.patient_id ?? '—';
          tr.insertCell().textContent = appt.status ?? '—';
        });
      }

      appointmentsContent.hidden = false;
    } catch (err) {
      appointmentsStatus.textContent = `Erreur réseau : ${err instanceof Error ? err.message : String(err)}`;
      appointmentsStatus.className = 'error';
    }
  }

  // ── Waiting room ──────────────────────────────────────────────────────────
  const waitingStatus  = document.getElementById('waiting-status')  as HTMLElement;
  const waitingContent = document.getElementById('waiting-content') as HTMLElement;
  const waitingNext    = document.getElementById('waiting-next')    as HTMLElement;
  const waitingEmpty   = document.getElementById('waiting-empty')   as HTMLElement;

  async function loadWaitingRoom(): Promise<void> {
    waitingStatus.textContent = 'Chargement…';
    waitingStatus.className = '';
    try {
      const { status, data } = await proAgenda.getWaitingRoom();
      if (status === 401) { window.location.href = '/auth/login?next=/praticien/dashboard'; return; }
      if (status === 403) { waitingStatus.textContent = 'Accès refusé (403).'; waitingStatus.className = 'error'; return; }
      if (status !== 200) { waitingStatus.textContent = `Erreur serveur (HTTP ${status}).`; waitingStatus.className = 'error'; return; }

      waitingStatus.textContent = '';
      const entries = (data as WaitingRoomEntry[]) ?? [];

      if (entries.length === 0) {
        waitingEmpty.hidden = false;
      } else {
        const next = entries[0];
        const checkinTime = next.checked_in_at
          ? new Date(next.checked_in_at).toLocaleTimeString('fr-FR', { hour: '2-digit', minute: '2-digit' })
          : '—';
        waitingNext.textContent = `Prochain patient : ${next.patient_id ?? '—'} — arrivé à ${checkinTime} (position ${next.position ?? 1})`;
        waitingNext.hidden = false;
      }

      waitingContent.hidden = false;
    } catch (err) {
      waitingStatus.textContent = `Erreur réseau : ${err instanceof Error ? err.message : String(err)}`;
      waitingStatus.className = 'error';
    }
  }

  void loadAgenda();
  void loadAppointments();
  void loadWaitingRoom();
</script>
