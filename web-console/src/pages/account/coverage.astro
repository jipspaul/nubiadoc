---
import Default from '../../layouts/Default.astro';
---
<Default title="GET/PATCH /v1/account/coverage — Nubia Console">
  <h1 style="margin-bottom:1.5rem;">GET + PATCH /v1/account/coverage</h1>

  <section style="margin-bottom:2rem;">
    <h2 style="margin-bottom:0.75rem;font-size:1rem;">GET — couverture actuelle</h2>
    <form id="coverage-form" style="display:flex;flex-direction:column;gap:0.75rem;max-width:400px;">
      <label>
        Access token (Bearer)
        <input type="text" name="access_token" required
          style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
      </label>
      <button type="submit"
        style="padding:0.5rem 1rem;background:var(--accent);color:#fff;border:none;border-radius:4px;cursor:pointer;align-self:flex-start;">
        GET
      </button>
    </form>
    <pre id="result" style="margin-top:1rem;padding:1rem;background:var(--surface);border:1px solid var(--border);border-radius:4px;white-space:pre-wrap;font-size:0.875rem;min-height:3rem;"></pre>
  </section>

  <section>
    <h2 style="margin-bottom:0.75rem;font-size:1rem;">PATCH — mutuelle &amp; régime</h2>
    <form id="coverage-patch-form" style="display:flex;flex-direction:column;gap:0.75rem;max-width:480px;">
      <label>
        Access token (Bearer)
        <input type="text" name="access_token_patch" required
          style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
      </label>

      <fieldset style="border:1px solid var(--border);border-radius:4px;padding:0.5rem 0.75rem;">
        <legend style="padding:0 0.25rem;font-size:0.875rem;">regime_obligatoire</legend>
        <label style="display:flex;align-items:center;gap:0.5rem;cursor:pointer;">
          <input type="radio" name="regime_obligatoire" value="regime_general" required /> regime_general
        </label>
        <label style="display:flex;align-items:center;gap:0.5rem;cursor:pointer;margin-top:0.25rem;">
          <input type="radio" name="regime_obligatoire" value="ame" /> ame
        </label>
        <label style="display:flex;align-items:center;gap:0.5rem;cursor:pointer;margin-top:0.25rem;">
          <input type="radio" name="regime_obligatoire" value="css" /> css
        </label>
      </fieldset>

      <label>
        NSS — numéro sécu (masqué, jamais affiché)
        <input type="password" name="nss" placeholder="2 91 03 75 119 078 35"
          autocomplete="off"
          style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
        <small style="color:var(--muted);font-size:0.75rem;">Optionnel — transmis chiffré, jamais renvoyé en clair.</small>
      </label>

      <fieldset style="border:1px solid var(--border);border-radius:4px;padding:0.5rem 0.75rem;">
        <legend style="padding:0 0.25rem;font-size:0.875rem;">mutuelle</legend>
        <label style="display:block;margin-bottom:0.5rem;">
          AMC
          <input type="text" name="mutuelle_amc" required placeholder="MGEN"
            style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
        </label>
        <label style="display:block;margin-bottom:0.5rem;">
          Numéro adhérent
          <input type="text" name="mutuelle_numero_adherent" required placeholder="123456789"
            style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
        </label>
        <label style="display:block;">
          Plateforme (optionnel)
          <input type="text" name="mutuelle_plateforme" placeholder="apicil"
            style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
        </label>
      </fieldset>

      <fieldset style="border:1px solid var(--border);border-radius:4px;padding:0.5rem 0.75rem;">
        <legend style="padding:0 0.25rem;font-size:0.875rem;">tiers_payant</legend>
        <label style="display:flex;align-items:center;gap:0.5rem;cursor:pointer;">
          <input type="radio" name="tiers_payant" value="true" required /> true (activé)
        </label>
        <label style="display:flex;align-items:center;gap:0.5rem;cursor:pointer;margin-top:0.25rem;">
          <input type="radio" name="tiers_payant" value="false" /> false (désactivé)
        </label>
      </fieldset>

      <button type="submit"
        style="padding:0.5rem 1rem;background:var(--accent);color:#fff;border:none;border-radius:4px;cursor:pointer;align-self:flex-start;">
        PATCH
      </button>
    </form>
    <pre id="result-patch" style="margin-top:1rem;padding:1rem;background:var(--surface);border:1px solid var(--border);border-radius:4px;white-space:pre-wrap;font-size:0.875rem;min-height:3rem;"></pre>
  </section>
</Default>

<style>
  pre.success { border-left: 4px solid green; }
  pre.error   { border-left: 4px solid red; }
</style>

<script>
  import { apiFetch } from '../../lib/api.ts';

  const getForm    = document.getElementById('coverage-form') as HTMLFormElement;
  const result     = document.getElementById('result') as HTMLPreElement;
  const patchForm  = document.getElementById('coverage-patch-form') as HTMLFormElement;
  const resultPatch = document.getElementById('result-patch') as HTMLPreElement;

  getForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(getForm);
    const access_token = fd.get('access_token') as string;
    result.className = '';
    result.textContent = 'Chargement…';
    try {
      const { status, data } = await apiFetch('/v1/account/coverage', {
        method: 'GET',
        headers: { 'Authorization': `Bearer ${access_token}` },
      });
      result.className = status < 300 ? 'success' : 'error';
      result.textContent = `HTTP ${status}\n${data !== null ? JSON.stringify(data, null, 2) : '(aucun contenu)'}`;
    } catch (err) {
      result.className = 'error';
      result.textContent = `Erreur réseau : ${err instanceof Error ? err.message : String(err)}`;
    }
  });

  patchForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(patchForm);
    const access_token    = fd.get('access_token_patch') as string;
    const regime          = fd.get('regime_obligatoire') as string;
    const nss             = fd.get('nss') as string;
    const amc             = fd.get('mutuelle_amc') as string;
    const numero_adherent = fd.get('mutuelle_numero_adherent') as string;
    const plateforme      = fd.get('mutuelle_plateforme') as string;
    const tiers_payant    = fd.get('tiers_payant') === 'true';

    const body: Record<string, unknown> = {
      regime_obligatoire: regime,
      mutuelle: {
        amc,
        numero_adherent,
        ...(plateforme ? { plateforme } : {}),
      },
      tiers_payant,
    };
    if (nss) body.nss = nss;

    resultPatch.className = '';
    resultPatch.textContent = 'Chargement…';
    try {
      const { status, data } = await apiFetch('/v1/account/coverage', {
        method: 'PATCH',
        headers: {
          'Content-Type': 'application/json',
          'Authorization': `Bearer ${access_token}`,
        },
        body: JSON.stringify(body),
      });
      resultPatch.className = status < 300 ? 'success' : 'error';
      resultPatch.textContent = `HTTP ${status}\n${data !== null ? JSON.stringify(data, null, 2) : '(aucun contenu)'}`;
    } catch (err) {
      resultPatch.className = 'error';
      resultPatch.textContent = `Erreur réseau : ${err instanceof Error ? err.message : String(err)}`;
    }
  });
</script>
