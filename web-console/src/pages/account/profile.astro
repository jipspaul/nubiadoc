---
import Default from '../../layouts/Default.astro';
---
<Default title="GET/PATCH /v1/account — Nubia Console">
  <h1 style="margin-bottom:1.5rem;">GET + PATCH /v1/account</h1>

  <section style="margin-bottom:2rem;">
    <h2 style="margin-bottom:0.75rem;font-size:1rem;">GET — identité patient</h2>
    <form id="get-form" style="display:flex;flex-direction:column;gap:0.75rem;max-width:400px;">
      <label>
        Access token (Bearer)
        <input type="text" name="access_token_get" required
          style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
      </label>
      <button type="submit"
        style="padding:0.5rem 1rem;background:var(--accent);color:#fff;border:none;border-radius:4px;cursor:pointer;align-self:flex-start;">
        GET
      </button>
    </form>
    <pre id="result-get" style="margin-top:1rem;padding:1rem;background:var(--surface);border:1px solid var(--border);border-radius:4px;white-space:pre-wrap;font-size:0.875rem;min-height:3rem;"></pre>
  </section>

  <section>
    <h2 style="margin-bottom:0.75rem;font-size:1rem;">PATCH — édition coordonnées</h2>
    <form id="patch-form" style="display:flex;flex-direction:column;gap:0.75rem;max-width:480px;">
      <label>
        Access token (Bearer)
        <input type="text" name="access_token_patch" required
          style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
      </label>

      <label>
        Prénom
        <input type="text" name="first_name" placeholder="Marie"
          style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
      </label>

      <label>
        Nom
        <input type="text" name="last_name" placeholder="Dupont"
          style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
      </label>

      <label>
        Date de naissance
        <input type="date" name="birth_date"
          style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
      </label>

      <label>
        Email
        <input type="email" name="email" placeholder="marie.dupont@example.com"
          pattern="[^@\s]+@[^@\s]+\.[^@\s]+"
          style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
      </label>

      <label>
        Téléphone
        <input type="tel" name="phone" placeholder="+33 6 12 34 56 78"
          pattern="^\+?[0-9 ]{7,20}$"
          style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
      </label>

      <button type="submit"
        style="padding:0.5rem 1rem;background:var(--accent);color:#fff;border:none;border-radius:4px;cursor:pointer;align-self:flex-start;">
        PATCH
      </button>
    </form>
    <pre id="result-patch" style="margin-top:1rem;padding:1rem;background:var(--surface);border:1px solid var(--border);border-radius:4px;white-space:pre-wrap;font-size:0.875rem;min-height:3rem;"></pre>
  </section>
</Default>

<style>
  pre.success { border-left: 4px solid green; }
  pre.error   { border-left: 4px solid red; }
</style>

<script>
  import { apiFetch } from '../../lib/api.ts';

  const getForm    = document.getElementById('get-form') as HTMLFormElement;
  const resultGet  = document.getElementById('result-get') as HTMLPreElement;
  const patchForm  = document.getElementById('patch-form') as HTMLFormElement;
  const resultPatch = document.getElementById('result-patch') as HTMLPreElement;

  getForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(getForm);
    const access_token = fd.get('access_token_get') as string;
    resultGet.className = '';
    resultGet.textContent = 'Chargement…';
    try {
      const { status, data } = await apiFetch('/v1/account', {
        headers: { 'Authorization': `Bearer ${access_token}` },
      });
      resultGet.className = status < 300 ? 'success' : 'error';
      resultGet.textContent = `HTTP ${status}\n${data !== null ? JSON.stringify(data, null, 2) : '(aucun contenu)'}`;
    } catch (err) {
      resultGet.className = 'error';
      resultGet.textContent = `Erreur réseau : ${err instanceof Error ? err.message : String(err)}`;
    }
  });

  patchForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(patchForm);
    const access_token = fd.get('access_token_patch') as string;

    const email = fd.get('email') as string;
    const phone = fd.get('phone') as string;
    if (email && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      resultPatch.className = 'error';
      resultPatch.textContent = 'Email invalide.';
      return;
    }
    if (phone && !/^\+?[0-9 ]{7,20}$/.test(phone)) {
      resultPatch.className = 'error';
      resultPatch.textContent = 'Téléphone invalide.';
      return;
    }

    const body: Record<string, unknown> = {};
    const first_name = fd.get('first_name') as string;
    const last_name  = fd.get('last_name') as string;
    const birth_date = fd.get('birth_date') as string;
    if (first_name) body.first_name = first_name;
    if (last_name)  body.last_name  = last_name;
    if (birth_date) body.birth_date = birth_date;
    if (email)      body.email      = email;
    if (phone)      body.phone      = phone;

    resultPatch.className = '';
    resultPatch.textContent = 'Chargement…';
    try {
      const { status, data } = await apiFetch('/v1/account', {
        method: 'PATCH',
        headers: {
          'Content-Type': 'application/json',
          'Authorization': `Bearer ${access_token}`,
        },
        body: JSON.stringify(body),
      });
      resultPatch.className = status < 300 ? 'success' : 'error';
      resultPatch.textContent = `HTTP ${status}\n${data !== null ? JSON.stringify(data, null, 2) : '(aucun contenu)'}`;
    } catch (err) {
      resultPatch.className = 'error';
      resultPatch.textContent = `Erreur réseau : ${err instanceof Error ? err.message : String(err)}`;
    }
  });
</script>
