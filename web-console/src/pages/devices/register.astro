---
import Default from '../../layouts/Default.astro';
---
<Default title="POST /v1/devices — Nubia Console">
  <h1 style="margin-bottom:1.5rem;">POST /v1/devices</h1>
  <p style="color:var(--muted);margin-bottom:1.5rem;">Enregistrer un token FCM (push notifications).</p>

  <form id="register-device-form" style="display:flex;flex-direction:column;gap:0.75rem;max-width:400px;">
    <label>
      Access token (Bearer)
      <input type="text" name="access_token" required
        style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
    </label>
    <label>
      FCM Token
      <input type="text" name="fcm_token" required placeholder="fcm-token-example"
        style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
    </label>
    <label>
      Platform
      <select name="platform" required
        style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;">
        <option value="android">android</option>
        <option value="ios">ios</option>
        <option value="web">web</option>
      </select>
    </label>
    <button type="submit"
      style="padding:0.5rem 1rem;background:var(--accent);color:#fff;border:none;border-radius:4px;cursor:pointer;align-self:flex-start;">
      Enregistrer le device
    </button>
  </form>

  <p id="status-badge" style="margin-top:1rem;display:none;"></p>

  <section id="device-info" style="display:none;margin-top:1rem;padding:1rem;background:var(--surface);border:1px solid var(--border);border-radius:4px;">
    <p><strong>id :</strong> <span id="device-id"></span></p>
  </section>

  <pre id="result" style="margin-top:1rem;padding:1rem;background:var(--surface);border:1px solid var(--border);border-radius:4px;white-space:pre-wrap;font-size:0.875rem;min-height:3rem;"></pre>
</Default>

<style>
  pre.success { border-left: 4px solid green; }
  pre.error   { border-left: 4px solid red; }
  .badge { display:inline-block;padding:0.25rem 0.6rem;border-radius:4px;font-size:0.85rem;font-weight:600; }
  .badge-ok  { background:#166534;color:#bbf7d0; }
  .badge-err { background:#7f1d1d;color:#fecaca; }
</style>

<script>
  import { apiFetch } from '../../lib/api.ts';

  const form = document.getElementById('register-device-form') as HTMLFormElement;
  const result = document.getElementById('result') as HTMLPreElement;
  const badge = document.getElementById('status-badge') as HTMLParagraphElement;
  const deviceInfo = document.getElementById('device-info') as HTMLElement;
  const deviceIdEl = document.getElementById('device-id') as HTMLElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(form);
    const access_token = fd.get('access_token') as string;
    const fcm_token = fd.get('fcm_token') as string;
    const platform = fd.get('platform') as string;

    result.className = '';
    result.textContent = 'Chargement…';
    badge.style.display = 'none';
    deviceInfo.style.display = 'none';

    try {
      const { status: httpStatus, data } = await apiFetch('/v1/devices', {
        method: 'POST',
        headers: {
          'Authorization': `Bearer ${access_token}`,
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({ fcm_token, platform }),
      });

      const ok = httpStatus < 300;
      result.className = ok ? 'success' : 'error';
      result.textContent = `HTTP ${httpStatus}\n${data !== null ? JSON.stringify(data, null, 2) : '(aucun contenu)'}`;
      badge.innerHTML = `<span class="badge ${ok ? 'badge-ok' : 'badge-err'}">HTTP ${httpStatus}</span>`;
      badge.style.display = 'block';

      if (ok && data !== null && typeof data === 'object') {
        const payload = data as Record<string, unknown>;
        deviceIdEl.textContent = String(payload.id ?? '—');
        deviceInfo.style.display = 'block';
      }
    } catch (err) {
      result.className = 'error';
      result.textContent = `Erreur réseau : ${err instanceof Error ? err.message : String(err)}`;
    }
  });
</script>
