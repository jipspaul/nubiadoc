---
import Default from '../../../layouts/Default.astro';
---
<Default title="Implant Passport — Nubia Console">
  <h1 style="margin-bottom:0.5rem;">GET /v1/implant-passport</h1>
  <p style="color:var(--muted);margin-bottom:1.5rem;font-size:0.875rem;">Passeport implantaire du patient connecté.</p>

  <form id="passport-form" style="display:flex;flex-direction:column;gap:0.75rem;max-width:400px;">
    <label>
      Access token (Bearer)
      <input type="text" name="access_token" required
        style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
    </label>
    <button type="submit"
      style="padding:0.5rem 1rem;background:var(--accent);color:#fff;border:none;border-radius:4px;cursor:pointer;align-self:flex-start;">
      Charger
    </button>
  </form>

  <p id="status-badge" style="margin-top:1rem;display:none;"></p>

  <section id="implants-list" style="margin-top:1rem;display:none;">
    <table style="width:100%;border-collapse:collapse;font-size:0.875rem;">
      <thead>
        <tr>
          <th style="text-align:left;padding:0.5rem;border-bottom:1px solid var(--border);">type</th>
          <th style="text-align:left;padding:0.5rem;border-bottom:1px solid var(--border);">tooth</th>
          <th style="text-align:left;padding:0.5rem;border-bottom:1px solid var(--border);">brand</th>
          <th style="text-align:left;padding:0.5rem;border-bottom:1px solid var(--border);">model</th>
          <th style="text-align:left;padding:0.5rem;border-bottom:1px solid var(--border);">date</th>
        </tr>
      </thead>
      <tbody id="implants-tbody"></tbody>
    </table>
    <p id="empty-state" style="display:none;color:var(--muted);margin-top:0.75rem;">Aucun implant enregistré.</p>
  </section>

  <pre id="result" style="margin-top:1rem;padding:1rem;background:var(--surface);border:1px solid var(--border);border-radius:4px;white-space:pre-wrap;font-size:0.875rem;min-height:3rem;"></pre>
</Default>

<style>
  pre.success { border-left: 4px solid green; }
  pre.error   { border-left: 4px solid red; }
  .badge { display:inline-block;padding:0.25rem 0.6rem;border-radius:4px;font-size:0.85rem;font-weight:600; }
  .badge-ok  { background:#166534;color:#bbf7d0; }
  .badge-err { background:#7f1d1d;color:#fecaca; }
  td { padding:0.5rem;border-bottom:1px solid var(--border); }
</style>

<script>
  import { apiFetch } from '../../../lib/api.ts';

  interface Implant {
    type?: string;
    tooth?: string | number;
    brand?: string;
    model?: string;
    date?: string;
  }

  interface PassportResponse {
    implants?: Implant[];
  }

  const form = document.getElementById('passport-form') as HTMLFormElement;
  const result = document.getElementById('result') as HTMLPreElement;
  const badge = document.getElementById('status-badge') as HTMLParagraphElement;
  const implantsList = document.getElementById('implants-list') as HTMLElement;
  const tbody = document.getElementById('implants-tbody') as HTMLTableSectionElement;
  const emptyState = document.getElementById('empty-state') as HTMLParagraphElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(form);
    const access_token = fd.get('access_token') as string;

    result.className = '';
    result.textContent = 'Chargement…';
    badge.style.display = 'none';
    implantsList.style.display = 'none';
    tbody.innerHTML = '';

    try {
      const { status: httpStatus, data } = await apiFetch('/v1/implant-passport', {
        method: 'GET',
        headers: { Authorization: `Bearer ${access_token}` },
      });
      result.className = httpStatus < 300 ? 'success' : 'error';
      result.textContent = `HTTP ${httpStatus}\n${data !== null ? JSON.stringify(data, null, 2) : '(aucun contenu)'}`;
      badge.innerHTML = `<span class="badge ${httpStatus < 300 ? 'badge-ok' : 'badge-err'}">HTTP ${httpStatus}</span>`;
      badge.style.display = 'block';

      if (httpStatus < 300 && data !== null && typeof data === 'object') {
        const passport = data as PassportResponse;
        const implants = Array.isArray(passport.implants) ? passport.implants
          : Array.isArray(data) ? (data as Implant[])
          : [];
        implantsList.style.display = 'block';
        if (implants.length === 0) {
          emptyState.style.display = 'block';
        } else {
          emptyState.style.display = 'none';
          for (const implant of implants) {
            const tr = document.createElement('tr');
            tr.innerHTML = `
              <td>${implant.type ?? ''}</td>
              <td>${implant.tooth ?? ''}</td>
              <td>${implant.brand ?? ''}</td>
              <td>${implant.model ?? ''}</td>
              <td>${implant.date ?? ''}</td>
            `;
            tbody.appendChild(tr);
          }
        }
      }
    } catch (err) {
      result.className = 'error';
      result.textContent = `Erreur réseau : ${err instanceof Error ? err.message : String(err)}`;
    }
  });
</script>
