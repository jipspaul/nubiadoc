---
import Default from '../../../layouts/Default.astro';
---
<Default title="Document Download — Nubia Console">
  <h1 style="margin-bottom:1.5rem;">GET /v1/documents/{'{id}'}/download</h1>
  <form id="download-form" style="display:flex;flex-direction:column;gap:0.75rem;max-width:480px;">
    <label>
      Access token (Bearer)
      <input type="text" name="access_token" required
        style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
    </label>
    <label>
      ID du document (UUID)
      <input type="text" name="document_id" required placeholder="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
        style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
    </label>
    <button type="submit"
      style="padding:0.5rem 1rem;background:var(--accent);color:#fff;border:none;border-radius:4px;cursor:pointer;align-self:flex-start;">
      Télécharger
    </button>
  </form>
  <p id="status-badge" style="margin-top:1rem;display:none;"></p>
  <pre id="result" style="margin-top:1rem;padding:1rem;background:var(--surface);border:1px solid var(--border);border-radius:4px;white-space:pre-wrap;font-size:0.875rem;min-height:3rem;"></pre>
</Default>

<style>
  pre.success { border-left: 4px solid green; }
  pre.error   { border-left: 4px solid red; }
  .badge { display:inline-block;padding:0.25rem 0.6rem;border-radius:4px;font-size:0.85rem;font-weight:600; }
  .badge-ok  { background:#166534;color:#bbf7d0; }
  .badge-err { background:#7f1d1d;color:#fecaca; }
</style>

<script>
  const API_BASE: string =
    (import.meta.env.PUBLIC_API_BASE as string | undefined) ?? 'http://localhost:3000';

  const form = document.getElementById('download-form') as HTMLFormElement;
  const result = document.getElementById('result') as HTMLPreElement;
  const badge = document.getElementById('status-badge') as HTMLParagraphElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(form);
    const access_token = fd.get('access_token') as string;
    const document_id = fd.get('document_id') as string;

    result.className = '';
    result.textContent = 'Chargement…';
    badge.style.display = 'none';

    try {
      const res = await fetch(`${API_BASE}/v1/documents/${document_id}/download`, {
        method: 'GET',
        headers: { 'Authorization': `Bearer ${access_token}` },
      });

      if (res.ok) {
        const blob = await res.blob();
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = 'document';
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
        URL.revokeObjectURL(url);
        result.className = 'success';
        result.textContent = '302 suivi → téléchargement lancé';
        badge.innerHTML = '<span class="badge badge-ok">302 suivi → téléchargement lancé</span>';
        badge.style.display = 'block';
      } else if (res.status === 404) {
        const text = await res.text();
        result.className = 'error';
        result.textContent = `HTTP 404 introuvable\n${text}`;
        badge.innerHTML = '<span class="badge badge-err">404 introuvable</span>';
        badge.style.display = 'block';
      } else if (res.status === 410) {
        const text = await res.text();
        result.className = 'error';
        result.textContent = `HTTP 410 lien expiré\n${text}`;
        badge.innerHTML = '<span class="badge badge-err">410 lien expiré</span>';
        badge.style.display = 'block';
      } else {
        const text = await res.text();
        result.className = 'error';
        result.textContent = `HTTP ${res.status}\n${text}`;
        badge.innerHTML = `<span class="badge badge-err">HTTP ${res.status}</span>`;
        badge.style.display = 'block';
      }
    } catch (err) {
      result.className = 'error';
      result.textContent = `Erreur réseau : ${err instanceof Error ? err.message : String(err)}`;
    }
  });
</script>
