---
import Default from '../../../layouts/Default.astro';
---
<Default title="Wedge — Devis (GET /v1/quotes) — Nubia Console">
  <h1 style="margin-bottom:1.5rem;">GET /v1/quotes</h1>
  <form id="quotes-form" style="display:flex;flex-direction:column;gap:0.75rem;max-width:400px;">
    <label>
      Access token patient (Bearer)
      <input type="text" name="access_token" required
        style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
    </label>
    <label>
      Filtre statut (optionnel)
      <input type="text" name="status" placeholder="ex : pending, signed, paid"
        style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
    </label>
    <button type="submit"
      style="padding:0.5rem 1rem;background:var(--accent);color:#fff;border:none;border-radius:4px;cursor:pointer;align-self:flex-start;">
      GET
    </button>
  </form>
  <p id="status-badge" style="margin-top:1rem;display:none;"></p>
  <pre id="result" style="margin-top:1rem;padding:1rem;background:var(--surface);border:1px solid var(--border);border-radius:4px;white-space:pre-wrap;font-size:0.875rem;min-height:3rem;"></pre>
  <section id="quotes-list" style="margin-top:1.5rem;display:none;">
    <h2 style="font-size:1rem;margin-bottom:0.75rem;">Devis</h2>
    <table style="width:100%;border-collapse:collapse;font-size:0.875rem;">
      <thead>
        <tr style="text-align:left;border-bottom:2px solid var(--border);">
          <th style="padding:0.4rem 0.75rem;">Statut</th>
          <th style="padding:0.4rem 0.75rem;">Montant (€)</th>
          <th style="padding:0.4rem 0.75rem;">Date</th>
          <th style="padding:0.4rem 0.75rem;">ID</th>
        </tr>
      </thead>
      <tbody id="quotes-tbody"></tbody>
    </table>
  </section>
</Default>

<style>
  pre.success { border-left: 4px solid green; }
  pre.error   { border-left: 4px solid red; }
  .badge { display:inline-block;padding:0.25rem 0.6rem;border-radius:4px;font-size:0.85rem;font-weight:600; }
  .badge-ok  { background:#166534;color:#bbf7d0; }
  .badge-err { background:#7f1d1d;color:#fecaca; }
  #quotes-tbody tr:nth-child(even) { background:var(--surface); }
  #quotes-tbody td { padding:0.4rem 0.75rem;border-bottom:1px solid var(--border); }
</style>

<script>
  import { apiFetch } from '../../../lib/api.ts';

  const form    = document.getElementById('quotes-form')  as HTMLFormElement;
  const result  = document.getElementById('result')       as HTMLPreElement;
  const badge   = document.getElementById('status-badge') as HTMLParagraphElement;
  const section = document.getElementById('quotes-list')  as HTMLElement;
  const tbody   = document.getElementById('quotes-tbody') as HTMLTableSectionElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(form);
    const access_token = fd.get('access_token') as string;
    const statusFilter = (fd.get('status') as string).trim();

    const path = statusFilter
      ? `/v1/quotes?status=${encodeURIComponent(statusFilter)}`
      : '/v1/quotes';

    result.className = '';
    result.textContent = 'Chargement…';
    badge.style.display = 'none';
    section.style.display = 'none';
    tbody.innerHTML = '';

    try {
      const { status: httpStatus, data } = await apiFetch(path, {
        headers: { 'Authorization': `Bearer ${access_token}` },
      });

      result.className = httpStatus < 300 ? 'success' : 'error';
      result.textContent = `HTTP ${httpStatus}\n${data !== null ? JSON.stringify(data, null, 2) : '(aucun contenu)'}`;
      badge.innerHTML = `<span class="badge ${httpStatus < 300 ? 'badge-ok' : 'badge-err'}">HTTP ${httpStatus}</span>`;
      badge.style.display = 'block';

      if (httpStatus === 200 && Array.isArray(data)) {
        section.style.display = '';
        for (const q of data as Array<Record<string, unknown>>) {
          const tr = document.createElement('tr');
          const amountCents = typeof q['amount_cents'] === 'number' ? q['amount_cents'] : null;
          const amountEur = amountCents !== null ? (amountCents / 100).toFixed(2) : '—';
          const date = typeof q['created_at'] === 'string'
            ? new Date(q['created_at']).toLocaleDateString('fr-FR')
            : '—';
          tr.innerHTML = `
            <td>${typeof q['status'] === 'string' ? q['status'] : '—'}</td>
            <td>${amountEur}</td>
            <td>${date}</td>
            <td style="font-family:monospace;font-size:0.75rem;">${typeof q['id'] === 'string' ? q['id'] : '—'}</td>
          `;
          tbody.appendChild(tr);
        }
      }
    } catch (err) {
      result.className = 'error';
      result.textContent = `Erreur réseau : ${err instanceof Error ? err.message : String(err)}`;
    }
  });
</script>
