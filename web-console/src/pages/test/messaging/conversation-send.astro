---
import Default from '../../../layouts/Default.astro';
---
<Default title="POST /v1/conversations/{id}/messages — Nubia Console">
  <h1 style="margin-bottom:1.5rem;">POST /v1/conversations/{id}/messages</h1>
  <form id="conversation-send-form" style="display:flex;flex-direction:column;gap:0.75rem;max-width:400px;">
    <label>
      Access token (Bearer)
      <input type="text" name="access_token" required
        style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
    </label>
    <label>
      Conversation ID
      <input type="text" name="conversation_id" required
        style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
    </label>
    <label>
      Message (body)
      <textarea name="body" required rows="4"
        style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;resize:vertical;font-family:inherit;"></textarea>
    </label>
    <label>
      Attachments (document IDs, un par ligne — optionnel)
      <textarea name="attachments" rows="2" placeholder="uuid-1&#10;uuid-2"
        style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;resize:vertical;font-family:inherit;"></textarea>
    </label>
    <button type="submit"
      style="padding:0.5rem 1rem;background:var(--accent);color:#fff;border:none;border-radius:4px;cursor:pointer;align-self:flex-start;">
      POST
    </button>
  </form>

  <p id="status-badge" style="margin-top:1rem;display:none;"></p>

  <section id="message-info" style="display:none;margin-top:1rem;padding:1rem;background:var(--surface);border:1px solid var(--border);border-radius:4px;">
    <p><strong>message_id :</strong> <span id="message-id"></span></p>
  </section>

  <pre id="result" style="margin-top:1rem;padding:1rem;background:var(--surface);border:1px solid var(--border);border-radius:4px;white-space:pre-wrap;font-size:0.875rem;min-height:3rem;"></pre>
</Default>

<style>
  pre.success { border-left: 4px solid green; }
  pre.error   { border-left: 4px solid red; }
  .badge { display:inline-block;padding:0.25rem 0.6rem;border-radius:4px;font-size:0.85rem;font-weight:600; }
  .badge-ok  { background:#166534;color:#bbf7d0; }
  .badge-err { background:#7f1d1d;color:#fecaca; }
</style>

<script>
  import { apiFetch } from '../../../lib/api.ts';

  const form = document.getElementById('conversation-send-form') as HTMLFormElement;
  const result = document.getElementById('result') as HTMLPreElement;
  const badge = document.getElementById('status-badge') as HTMLParagraphElement;
  const infoSection = document.getElementById('message-info') as HTMLElement;
  const messageIdEl = document.getElementById('message-id') as HTMLElement;

  const params = new URLSearchParams(window.location.search);
  const idParam = params.get('id');
  if (idParam) {
    (form.elements.namedItem('conversation_id') as HTMLInputElement).value = idParam;
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(form);
    const access_token = fd.get('access_token') as string;
    const conversation_id = fd.get('conversation_id') as string;
    const body = fd.get('body') as string;
    const attachmentsRaw = (fd.get('attachments') as string).trim();
    const attachments = attachmentsRaw
      ? attachmentsRaw.split('\n').map((s) => s.trim()).filter(Boolean)
      : undefined;

    result.className = '';
    result.textContent = 'Chargement…';
    badge.style.display = 'none';
    infoSection.style.display = 'none';

    try {
      const payload: Record<string, unknown> = { body };
      if (attachments && attachments.length > 0) payload.attachments = attachments;

      const { status: httpStatus, data } = await apiFetch(
        `/v1/conversations/${encodeURIComponent(conversation_id)}/messages`,
        {
          method: 'POST',
          headers: {
            'Authorization': `Bearer ${access_token}`,
            'Content-Type': 'application/json',
          },
          body: JSON.stringify(payload),
        },
      );

      const ok = httpStatus < 300;
      result.className = ok ? 'success' : 'error';
      result.textContent = `HTTP ${httpStatus}\n${data !== null ? JSON.stringify(data, null, 2) : '(aucun contenu)'}`;
      badge.innerHTML = `<span class="badge ${ok ? 'badge-ok' : 'badge-err'}">HTTP ${httpStatus}</span>`;
      badge.style.display = 'block';

      if (ok && data !== null && typeof data === 'object') {
        const pl = data as Record<string, unknown>;
        const msgId = String(pl.message_id ?? pl.id ?? '—');
        messageIdEl.textContent = msgId;
        infoSection.style.display = 'block';
      }
    } catch (err) {
      result.className = 'error';
      result.textContent = `Erreur réseau : ${err instanceof Error ? err.message : String(err)}`;
    }
  });
</script>
