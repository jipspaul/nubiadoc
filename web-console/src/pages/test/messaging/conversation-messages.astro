---
import Default from '../../../layouts/Default.astro';
---
<Default title="GET /v1/conversations/{id}/messages — Nubia Console">
  <h1 style="margin-bottom:1.5rem;">GET /v1/conversations/{id}/messages</h1>
  <form id="conv-messages-form" style="display:flex;flex-direction:column;gap:0.75rem;max-width:400px;">
    <label>
      Access token (Bearer)
      <input type="text" name="access_token" required
        style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
    </label>
    <label>
      Conversation ID
      <input type="text" name="conversation_id" required placeholder="uuid"
        style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
    </label>
    <label>
      Page (optionnel)
      <input type="text" name="page" placeholder="1"
        style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
    </label>
    <button type="submit"
      style="padding:0.5rem 1rem;background:var(--accent);color:#fff;border:none;border-radius:4px;cursor:pointer;align-self:flex-start;">
      GET
    </button>
  </form>

  <p id="status-badge" style="margin-top:1rem;display:none;"></p>

  <section id="messages-list" style="display:none;margin-top:1.5rem;">
    <h2 style="font-size:1rem;margin-bottom:0.75rem;">Messages</h2>
    <ul id="list-items" style="list-style:none;display:flex;flex-direction:column;gap:0.75rem;"></ul>
  </section>

  <pre id="result" style="margin-top:1rem;padding:1rem;background:var(--surface);border:1px solid var(--border);border-radius:4px;white-space:pre-wrap;font-size:0.875rem;min-height:3rem;"></pre>
</Default>

<style>
  pre.success { border-left: 4px solid green; }
  pre.error   { border-left: 4px solid red; }
  .badge { display:inline-block;padding:0.25rem 0.6rem;border-radius:4px;font-size:0.85rem;font-weight:600; }
  .badge-ok  { background:#166534;color:#bbf7d0; }
  .badge-err { background:#7f1d1d;color:#fecaca; }
  .msg-item {
    padding:0.75rem 1rem;
    background:var(--surface);
    border:1px solid var(--border);
    border-radius:4px;
    display:flex;
    flex-direction:column;
    gap:0.25rem;
  }
  .msg-item .msg-sender { font-weight:600;font-size:0.85rem;text-transform:uppercase;letter-spacing:0.05em; }
  .msg-item .msg-body { white-space:pre-wrap; }
  .msg-item .msg-meta { font-size:0.8rem;color:var(--muted); }
</style>

<script>
  import { apiFetch } from '../../../lib/api.ts';

  const form = document.getElementById('conv-messages-form') as HTMLFormElement;
  const result = document.getElementById('result') as HTMLPreElement;
  const badge = document.getElementById('status-badge') as HTMLParagraphElement;
  const listSection = document.getElementById('messages-list') as HTMLElement;
  const listItems = document.getElementById('list-items') as HTMLUListElement;

  const params = new URLSearchParams(window.location.search);
  const idParam = params.get('id');
  if (idParam) {
    (form.elements.namedItem('conversation_id') as HTMLInputElement).value = idParam;
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(form);
    const access_token = fd.get('access_token') as string;
    const conversation_id = fd.get('conversation_id') as string;
    const page = (fd.get('page') as string).trim();

    result.className = '';
    result.textContent = 'Chargement…';
    badge.style.display = 'none';
    listSection.style.display = 'none';
    listItems.innerHTML = '';

    const qs = page ? `?page=${encodeURIComponent(page)}` : '';

    try {
      const { status: httpStatus, data } = await apiFetch(
        `/v1/conversations/${encodeURIComponent(conversation_id)}/messages${qs}`,
        {
          method: 'GET',
          headers: { 'Authorization': `Bearer ${access_token}` },
        },
      );

      const ok = httpStatus < 300;
      result.className = ok ? 'success' : 'error';
      result.textContent = `HTTP ${httpStatus}\n${data !== null ? JSON.stringify(data, null, 2) : '(aucun contenu)'}`;
      badge.innerHTML = `<span class="badge ${ok ? 'badge-ok' : 'badge-err'}">HTTP ${httpStatus}</span>`;
      badge.style.display = 'block';

      const messages = Array.isArray(data) ? data : (data as Record<string, unknown> | null)?.data as unknown[];
      if (ok && Array.isArray(messages) && messages.length > 0) {
        for (const msg of messages as Record<string, unknown>[]) {
          const id = String(msg.id ?? '');
          const body = String(msg.body ?? '');
          const sender_type = String(msg.sender_type ?? '—');
          const created_at = msg.created_at ? new Date(msg.created_at as string).toLocaleString('fr-FR') : '—';

          const li = document.createElement('li');
          li.className = 'msg-item';
          li.setAttribute('data-message-id', id);
          li.innerHTML = `
            <span class="msg-sender">${escapeHtml(sender_type)}</span>
            <span class="msg-body">${escapeHtml(body)}</span>
            <span class="msg-meta">${escapeHtml(created_at)}</span>`;
          listItems.appendChild(li);
        }
        listSection.style.display = 'block';
      } else if (ok && Array.isArray(messages) && messages.length === 0) {
        listSection.style.display = 'block';
        const empty = document.createElement('li');
        empty.style.color = 'var(--muted)';
        empty.textContent = 'Aucun message.';
        listItems.appendChild(empty);
      }
    } catch (err) {
      result.className = 'error';
      result.textContent = `Erreur réseau : ${err instanceof Error ? err.message : String(err)}`;
    }
  });

  function escapeHtml(s: string): string {
    return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }
</script>
