---
import Default from '../../../layouts/Default.astro';
---
<Default title="GET /v1/cabinet/conversations — Nubia Console">
  <h1 style="margin-bottom:1.5rem;">GET /v1/cabinet/conversations</h1>
  <form id="cabinet-conversations-form" style="display:flex;flex-direction:column;gap:0.75rem;max-width:400px;">
    <label>
      Access token (Bearer)
      <input type="text" name="access_token" required
        style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
    </label>
    <button type="submit"
      style="padding:0.5rem 1rem;background:var(--accent);color:#fff;border:none;border-radius:4px;cursor:pointer;align-self:flex-start;">
      GET
    </button>
  </form>

  <p id="status-badge" style="margin-top:1rem;display:none;"></p>

  <section id="conversations-list" style="display:none;margin-top:1.5rem;">
    <h2 style="font-size:1rem;margin-bottom:0.75rem;">Conversations</h2>
    <ul id="list-items" style="list-style:none;display:flex;flex-direction:column;gap:0.75rem;"></ul>
  </section>

  <pre id="result" style="margin-top:1rem;padding:1rem;background:var(--surface);border:1px solid var(--border);border-radius:4px;white-space:pre-wrap;font-size:0.875rem;min-height:3rem;"></pre>
</Default>

<style>
  pre.success { border-left: 4px solid green; }
  pre.error   { border-left: 4px solid red; }
  .badge { display:inline-block;padding:0.25rem 0.6rem;border-radius:4px;font-size:0.85rem;font-weight:600; }
  .badge-ok  { background:#166534;color:#bbf7d0; }
  .badge-err { background:#7f1d1d;color:#fecaca; }
  .badge-urgent { background:#7f1d1d;color:#fecaca;font-size:0.75rem;padding:0.15rem 0.5rem;border-radius:4px; }
  .conv-item {
    padding:0.75rem 1rem;
    background:var(--surface);
    border:1px solid var(--border);
    border-radius:4px;
    display:flex;
    flex-direction:column;
    gap:0.25rem;
  }
  .conv-item .conv-patient { font-weight:600; }
  .conv-item .conv-meta { font-size:0.85rem; color:var(--muted); }
  .conv-item .conv-unread {
    display:inline-block;
    background:var(--accent);
    color:#fff;
    border-radius:9999px;
    padding:0 0.5rem;
    font-size:0.75rem;
    font-weight:700;
    min-width:1.5rem;
    text-align:center;
  }
  .conv-item .conv-unread[data-zero] { background:var(--border); color:var(--muted); }
</style>

<script>
  import { apiFetch } from '../../../lib/api.ts';

  const form = document.getElementById('cabinet-conversations-form') as HTMLFormElement;
  const result = document.getElementById('result') as HTMLPreElement;
  const badge = document.getElementById('status-badge') as HTMLParagraphElement;
  const listSection = document.getElementById('conversations-list') as HTMLElement;
  const listItems = document.getElementById('list-items') as HTMLUListElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(form);
    const access_token = fd.get('access_token') as string;

    result.className = '';
    result.textContent = 'Chargement…';
    badge.style.display = 'none';
    listSection.style.display = 'none';
    listItems.innerHTML = '';

    try {
      const { status: httpStatus, data } = await apiFetch('/v1/cabinet/conversations', {
        method: 'GET',
        headers: { 'Authorization': `Bearer ${access_token}` },
      });

      const ok = httpStatus < 300;
      result.className = ok ? 'success' : 'error';
      result.textContent = `HTTP ${httpStatus}\n${data !== null ? JSON.stringify(data, null, 2) : '(aucun contenu)'}`;
      badge.innerHTML = `<span class="badge ${ok ? 'badge-ok' : 'badge-err'}">HTTP ${httpStatus}</span>`;
      badge.style.display = 'block';

      if (ok && Array.isArray(data) && data.length > 0) {
        for (const conv of data as Record<string, unknown>[]) {
          const id = String(conv.id ?? '');
          const patient_name = String(conv.patient_name ?? '—');
          const last_message_at = conv.last_message_at ? new Date(conv.last_message_at as string).toLocaleString('fr-FR') : '—';
          const unread_count = Number(conv.unread_count ?? 0);
          const urgent = Boolean(conv.triage_flag);

          const li = document.createElement('li');
          li.className = 'conv-item';
          li.setAttribute('data-conversation-id', id);
          li.innerHTML = `
            <div style="display:flex;justify-content:space-between;align-items:center;gap:0.5rem;">
              <span class="conv-patient">${escapeHtml(patient_name)}${urgent ? ' <span class="badge-urgent" data-urgent>urgent</span>' : ''}</span>
              <span class="conv-unread" ${unread_count === 0 ? 'data-zero' : ''}>${unread_count}</span>
            </div>
            <span class="conv-meta">id : ${escapeHtml(id)}</span>
            <span class="conv-meta">dernier message : ${escapeHtml(last_message_at)}</span>`;
          listItems.appendChild(li);
        }
        listSection.style.display = 'block';
      } else if (ok && Array.isArray(data) && data.length === 0) {
        listSection.style.display = 'block';
        const empty = document.createElement('li');
        empty.style.color = 'var(--muted)';
        empty.textContent = 'Aucune conversation.';
        listItems.appendChild(empty);
      }
    } catch (err) {
      result.className = 'error';
      result.textContent = `Erreur réseau : ${err instanceof Error ? err.message : String(err)}`;
    }
  });

  function escapeHtml(s: string): string {
    return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }
</script>
