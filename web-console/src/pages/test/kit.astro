---
import Default from '../../layouts/Default.astro';
import Button from '../../components/kit/Button.astro';
import Field from '../../components/kit/Field.astro';
import Card from '../../components/kit/Card.astro';
import Table from '../../components/kit/Table.astro';
import Modal from '../../components/kit/Modal.astro';
import Tabs from '../../components/kit/Tabs.astro';
import Toast from '../../components/kit/Toast.astro';
import Badge from '../../components/kit/Badge.astro';
import EmptyState from '../../components/kit/EmptyState.astro';
import Spinner from '../../components/kit/Spinner.astro';
---

<Default title="Kit composants — Nubia Console">
  <h1 id="kit-heading">Kit composants — W6</h1>
  <p class="subtitle">Démo de chaque composant du kit. Données fictives uniquement.</p>

  <section class="section" aria-labelledby="section-button">
    <h2 id="section-button">Button</h2>
    <div class="row">
      <Button variant="primary">Primaire</Button>
      <Button variant="secondary">Secondaire</Button>
      <Button variant="danger">Danger</Button>
      <Button variant="primary" disabled>Désactivé</Button>
    </div>
  </section>

  <section class="section" aria-labelledby="section-field">
    <h2 id="section-field">Field</h2>
    <div class="col-narrow">
      <Field id="demo-name" label="Nom" placeholder="Jean Dupont" required />
      <Field id="demo-email" label="Email" type="email" hint="Utilisé pour la connexion" />
      <Field id="demo-error" label="Mot de passe" type="password" error="8 caractères minimum" />
    </div>
  </section>

  <section class="section" aria-labelledby="section-card">
    <h2 id="section-card">Card</h2>
    <Card title="Informations patient">
      <p>Contenu de la carte. Données fictives : Jean Dupont, né le 01/01/1980.</p>
    </Card>
  </section>

  <section class="section" aria-labelledby="section-table">
    <h2 id="section-table">Table</h2>
    <Table caption="Liste des rendez-vous">
      <thead>
        <tr>
          <th scope="col">Date</th>
          <th scope="col">Patient</th>
          <th scope="col">Motif</th>
          <th scope="col">Statut</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>2026-06-10 09:00</td>
          <td>Alice Martin</td>
          <td>Détartrage</td>
          <td><Badge variant="success">Confirmé</Badge></td>
        </tr>
        <tr>
          <td>2026-06-11 14:30</td>
          <td>Bob Durand</td>
          <td>Consultation</td>
          <td><Badge variant="warning">En attente</Badge></td>
        </tr>
        <tr>
          <td>2026-06-12 10:00</td>
          <td>Claire Petit</td>
          <td>Radio</td>
          <td><Badge variant="error">Annulé</Badge></td>
        </tr>
      </tbody>
    </Table>
  </section>

  <section class="section" aria-labelledby="section-modal">
    <h2 id="section-modal">Modal</h2>
    <Button variant="secondary" id="open-demo-modal" data-modal-open="demo-modal">
      Ouvrir la modal
    </Button>
    <Modal id="demo-modal" title="Confirmer l'action">
      <p>Cette action est irréversible. Confirmer ?</p>
      <div slot="footer">
        <Button variant="secondary" data-modal-close="demo-modal">Annuler</Button>
        <Button variant="danger">Supprimer</Button>
      </div>
    </Modal>
  </section>

  <section class="section" aria-labelledby="section-tabs">
    <h2 id="section-tabs">Tabs</h2>
    <Tabs id="demo-tabs" tabs={[
      { id: 'info', label: 'Informations' },
      { id: 'docs', label: 'Documents' },
      { id: 'history', label: 'Historique' },
    ]}>
      <div id="demo-tabs-panel-info" role="tabpanel" aria-labelledby="demo-tabs-tab-info">
        <p>Contenu de l'onglet Informations.</p>
      </div>
      <div id="demo-tabs-panel-docs" role="tabpanel" aria-labelledby="demo-tabs-tab-docs" hidden>
        <p>Contenu de l'onglet Documents.</p>
      </div>
      <div id="demo-tabs-panel-history" role="tabpanel" aria-labelledby="demo-tabs-tab-history" hidden>
        <p>Contenu de l'onglet Historique.</p>
      </div>
    </Tabs>
  </section>

  <section class="section" aria-labelledby="section-toast">
    <h2 id="section-toast">Toast</h2>
    <div class="col-narrow">
      <Toast variant="success" message="Enregistrement réussi." />
      <Toast variant="error" message="Une erreur est survenue." />
      <Toast variant="warning" message="Attention : données incomplètes." />
      <Toast variant="info" message="Mise à jour disponible." />
    </div>
  </section>

  <section class="section" aria-labelledby="section-badge">
    <h2 id="section-badge">Badge</h2>
    <div class="row">
      <Badge>Défaut</Badge>
      <Badge variant="success">Confirmé</Badge>
      <Badge variant="error">Annulé</Badge>
      <Badge variant="warning">En attente</Badge>
      <Badge variant="info">Info</Badge>
    </div>
  </section>

  <section class="section" aria-labelledby="section-empty">
    <h2 id="section-empty">EmptyState</h2>
    <Card>
      <EmptyState
        id="demo-empty"
        icon="📭"
        title="Aucun document"
        description="Ajoutez votre premier document pour le retrouver ici."
      >
        <Button variant="primary">Ajouter un document</Button>
      </EmptyState>
    </Card>
  </section>

  <section class="section" aria-labelledby="section-spinner">
    <h2 id="section-spinner">Spinner</h2>
    <div class="row" style="align-items:center;">
      <Spinner size="sm" label="Petit" id="spinner-sm" />
      <Spinner size="md" label="Moyen" id="spinner-md" />
      <Spinner size="lg" label="Grand" id="spinner-lg" />
    </div>
  </section>
</Default>

<style>
  h1 { margin-bottom: var(--space-2); }
  .subtitle { color: var(--color-muted); font-size: var(--font-size-sm); margin-bottom: var(--space-8); }
  .section { margin-top: var(--space-8); }
  .section h2 {
    font-size: var(--font-size-lg);
    border-bottom: 1px solid var(--color-border);
    padding-bottom: var(--space-2);
    margin-bottom: var(--space-4);
  }
  .row { display: flex; flex-wrap: wrap; gap: var(--space-3); align-items: flex-start; }
  .col-narrow { display: flex; flex-direction: column; gap: var(--space-4); max-width: 360px; }
</style>
