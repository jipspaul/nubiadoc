---
import Default from '../../../../layouts/Default.astro';
---
<Default title="Nouvelle ordonnance — Nubia Console">
  <h1 style="margin-bottom:0.5rem;">§17 Back-office — Créer une ordonnance</h1>
  <p style="color:var(--muted);font-size:0.875rem;margin-bottom:1.5rem;">
    POST <code>/v1/cabinet/prescriptions</code>
    &nbsp;·&nbsp;
    GET <code>/v1/cabinet/prescriptions</code>
    &nbsp;·&nbsp; <code>practitioner</code> only
  </p>

  <!-- Access token -->
  <section style="margin-bottom:2rem;">
    <label style="font-size:0.875rem;font-weight:600;">
      Access token (Bearer)
      <input id="access-token" type="text" name="access_token" placeholder="eyJ…"
        style="display:block;width:100%;max-width:600px;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
    </label>
  </section>

  <!-- Section 1 : POST create -->
  <section aria-labelledby="h-create" style="margin-bottom:2rem;border:1px solid var(--border);border-radius:6px;padding:1rem;">
    <h2 id="h-create" style="margin:0 0 1rem;font-size:1rem;">POST /v1/cabinet/prescriptions — créer une ordonnance</h2>
    <form id="form-create" style="display:flex;flex-direction:column;gap:0.75rem;max-width:500px;">
      <label style="font-size:0.875rem;">
        patient_id <span style="color:red">*</span>
        <input type="text" name="patient_id" required
          style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
      </label>
      <fieldset style="border:1px solid var(--border);border-radius:4px;padding:0.75rem;">
        <legend style="font-size:0.875rem;padding:0 0.25rem;">items[0] — premier médicament</legend>
        <label style="font-size:0.875rem;">
          label <span style="color:red">*</span>
          <input type="text" name="item_label" required placeholder="Amoxicilline 500 mg"
            style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
        </label>
        <label style="font-size:0.875rem;margin-top:0.5rem;">
          form (optionnel)
          <input type="text" name="item_form" placeholder="gélule"
            style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
        </label>
        <label style="font-size:0.875rem;margin-top:0.5rem;">
          posology <span style="color:red">*</span>
          <input type="text" name="item_posology" required placeholder="1 gélule 3x/jour"
            style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
        </label>
        <label style="font-size:0.875rem;margin-top:0.5rem;">
          duration <span style="color:red">*</span>
          <input type="text" name="item_duration" required placeholder="7 jours"
            style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
        </label>
        <label style="font-size:0.875rem;margin-top:0.5rem;">
          quantity <span style="color:red">*</span>
          <input type="number" name="item_quantity" required placeholder="1" min="1"
            style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
        </label>
      </fieldset>
      <button type="submit" id="btn-create"
        style="padding:0.5rem 1rem;background:var(--accent);color:#fff;border:none;border-radius:4px;cursor:pointer;align-self:flex-start;">
        POST (créer)
      </button>
    </form>
    <p id="badge-create" style="margin-top:0.75rem;display:none;"></p>
    <pre id="result-create" style="margin-top:0.5rem;padding:1rem;background:var(--surface);border:1px solid var(--border);border-radius:4px;white-space:pre-wrap;font-size:0.875rem;min-height:2.5rem;"></pre>
  </section>

  <!-- Section 2 : GET list -->
  <section aria-labelledby="h-list" style="margin-bottom:2rem;border:1px solid var(--border);border-radius:6px;padding:1rem;">
    <h2 id="h-list" style="margin:0 0 1rem;font-size:1rem;">GET /v1/cabinet/prescriptions — liste existante</h2>
    <form id="form-list" style="display:flex;flex-wrap:wrap;gap:0.75rem;align-items:flex-end;">
      <label style="font-size:0.875rem;">
        patient_id (optionnel)
        <input type="text" name="patient_id"
          style="display:block;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;width:220px;" />
      </label>
      <button type="submit" id="btn-list"
        style="padding:0.5rem 1rem;background:var(--accent);color:#fff;border:none;border-radius:4px;cursor:pointer;">
        GET
      </button>
    </form>
    <p id="badge-list" style="margin-top:0.75rem;display:none;"></p>
    <pre id="result-list" style="margin-top:0.5rem;padding:1rem;background:var(--surface);border:1px solid var(--border);border-radius:4px;white-space:pre-wrap;font-size:0.875rem;min-height:2.5rem;"></pre>
  </section>
</Default>

<style>
  pre.success { border-left: 4px solid green; }
  pre.error   { border-left: 4px solid red; }
  .badge { display:inline-block;padding:0.25rem 0.6rem;border-radius:4px;font-size:0.85rem;font-weight:600; }
  .badge-ok  { background:#166534;color:#bbf7d0; }
  .badge-err { background:#7f1d1d;color:#fecaca; }
</style>

<script>
  import { apiFetch } from '../../../../lib/api.ts';

  function getToken(): string {
    return (document.getElementById('access-token') as HTMLInputElement).value;
  }

  function renderResult(
    resultEl: HTMLPreElement,
    badgeEl: HTMLParagraphElement,
    httpStatus: number,
    data: unknown,
  ): void {
    resultEl.className = httpStatus < 300 ? 'success' : 'error';
    resultEl.textContent = `HTTP ${httpStatus}\n${data !== null ? JSON.stringify(data, null, 2) : '(aucun contenu)'}`;
    badgeEl.innerHTML = `<span class="badge ${httpStatus < 300 ? 'badge-ok' : 'badge-err'}">HTTP ${httpStatus}</span>`;
    badgeEl.style.display = 'block';
  }

  function renderError(resultEl: HTMLPreElement, err: unknown): void {
    resultEl.className = 'error';
    resultEl.textContent = `Erreur réseau : ${err instanceof Error ? err.message : String(err)}`;
  }

  // --- POST create ---
  const formCreate = document.getElementById('form-create') as HTMLFormElement;
  const resultCreate = document.getElementById('result-create') as HTMLPreElement;
  const badgeCreate = document.getElementById('badge-create') as HTMLParagraphElement;

  formCreate.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(formCreate);
    const body = {
      patient_id: fd.get('patient_id') as string,
      items: [{
        label: fd.get('item_label') as string,
        ...(fd.get('item_form') ? { form: fd.get('item_form') as string } : {}),
        posology: fd.get('item_posology') as string,
        duration: fd.get('item_duration') as string,
        quantity: Number(fd.get('item_quantity')),
      }],
    };
    resultCreate.className = '';
    resultCreate.textContent = 'Chargement…';
    badgeCreate.style.display = 'none';
    try {
      const { status, data } = await apiFetch('/v1/cabinet/prescriptions', {
        method: 'POST',
        headers: {
          'Authorization': `Bearer ${getToken()}`,
          'Content-Type': 'application/json',
        },
        body: JSON.stringify(body),
      });
      renderResult(resultCreate, badgeCreate, status, data);
    } catch (err) {
      renderError(resultCreate, err);
    }
  });

  // --- GET list ---
  const formList = document.getElementById('form-list') as HTMLFormElement;
  const resultList = document.getElementById('result-list') as HTMLPreElement;
  const badgeList = document.getElementById('badge-list') as HTMLParagraphElement;

  formList.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(formList);
    const patientId = fd.get('patient_id') as string;
    const params = new URLSearchParams();
    if (patientId) params.set('patient_id', patientId);
    const qs = params.toString() ? `?${params.toString()}` : '';
    resultList.className = '';
    resultList.textContent = 'Chargement…';
    badgeList.style.display = 'none';
    try {
      const { status, data } = await apiFetch(`/v1/cabinet/prescriptions${qs}`, {
        method: 'GET',
        headers: { 'Authorization': `Bearer ${getToken()}` },
      });
      renderResult(resultList, badgeList, status, data);
    } catch (err) {
      renderError(resultList, err);
    }
  });
</script>
