---
import Default from '../../../layouts/Default.astro';
---
<Default title="Notification Preferences — Nubia Console">
  <h1 style="margin-bottom:1.5rem;">GET + PATCH /v1/account/notification-preferences</h1>

  <section style="margin-bottom:2rem;">
    <h2 style="margin-bottom:1rem;font-size:1.125rem;">GET — consulter les préférences</h2>
    <form id="get-form" style="display:flex;flex-direction:column;gap:0.75rem;max-width:400px;">
      <label>
        Access token (Bearer)
        <input type="text" name="access_token" required
          style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
      </label>
      <button type="submit"
        style="padding:0.5rem 1rem;background:var(--accent);color:#fff;border:none;border-radius:4px;cursor:pointer;align-self:flex-start;">
        GET
      </button>
    </form>
    <pre id="get-result" style="margin-top:1.5rem;padding:1rem;background:var(--surface);border:1px solid var(--border);border-radius:4px;white-space:pre-wrap;font-size:0.875rem;min-height:3rem;"></pre>
  </section>

  <section>
    <h2 style="margin-bottom:1rem;font-size:1.125rem;">PATCH — mettre à jour les préférences</h2>
    <form id="patch-form" style="display:flex;flex-direction:column;gap:0.75rem;max-width:480px;">
      <label>
        Access token (Bearer)
        <input type="text" name="access_token" required
          style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
      </label>

      <fieldset style="border:1px solid var(--border);border-radius:4px;padding:0.5rem 0.75rem;">
        <legend style="padding:0 0.25rem;font-size:0.875rem;">Canal email</legend>
        <label style="display:flex;align-items:center;gap:0.5rem;cursor:pointer;">
          <input type="checkbox" name="email_appointment_reminder" value="true" /> Rappels RDV
        </label>
        <label style="display:flex;align-items:center;gap:0.5rem;cursor:pointer;margin-top:0.25rem;">
          <input type="checkbox" name="email_document_ready" value="true" /> Document prêt
        </label>
        <label style="display:flex;align-items:center;gap:0.5rem;cursor:pointer;margin-top:0.25rem;">
          <input type="checkbox" name="email_payment_due" value="true" /> Paiement dû
        </label>
        <label style="display:flex;align-items:center;gap:0.5rem;cursor:pointer;margin-top:0.25rem;">
          <input type="checkbox" name="email_message" value="true" /> Nouveau message
        </label>
      </fieldset>

      <fieldset style="border:1px solid var(--border);border-radius:4px;padding:0.5rem 0.75rem;">
        <legend style="padding:0 0.25rem;font-size:0.875rem;">Canal push</legend>
        <label style="display:flex;align-items:center;gap:0.5rem;cursor:pointer;">
          <input type="checkbox" name="push_appointment_reminder" value="true" /> Rappels RDV
        </label>
        <label style="display:flex;align-items:center;gap:0.5rem;cursor:pointer;margin-top:0.25rem;">
          <input type="checkbox" name="push_document_ready" value="true" /> Document prêt
        </label>
        <label style="display:flex;align-items:center;gap:0.5rem;cursor:pointer;margin-top:0.25rem;">
          <input type="checkbox" name="push_payment_due" value="true" /> Paiement dû
        </label>
        <label style="display:flex;align-items:center;gap:0.5rem;cursor:pointer;margin-top:0.25rem;">
          <input type="checkbox" name="push_message" value="true" /> Nouveau message
        </label>
      </fieldset>

      <fieldset style="border:1px solid var(--border);border-radius:4px;padding:0.5rem 0.75rem;">
        <legend style="padding:0 0.25rem;font-size:0.875rem;">Canal SMS</legend>
        <label style="display:flex;align-items:center;gap:0.5rem;cursor:pointer;">
          <input type="checkbox" name="sms_appointment_reminder" value="true" /> Rappels RDV
        </label>
        <label style="display:flex;align-items:center;gap:0.5rem;cursor:pointer;margin-top:0.25rem;">
          <input type="checkbox" name="sms_payment_due" value="true" /> Paiement dû
        </label>
      </fieldset>

      <button type="submit"
        style="padding:0.5rem 1rem;background:var(--accent);color:#fff;border:none;border-radius:4px;cursor:pointer;align-self:flex-start;">
        Envoyer PATCH
      </button>
    </form>
    <pre id="patch-result" style="margin-top:1.5rem;padding:1rem;background:var(--surface);border:1px solid var(--border);border-radius:4px;white-space:pre-wrap;font-size:0.875rem;min-height:3rem;"></pre>
  </section>
</Default>

<style>
  pre.success { border-left: 4px solid green; }
  pre.error   { border-left: 4px solid red; }
</style>

<script>
  import { apiFetch } from '../../../lib/api.ts';

  // GET
  const getForm = document.getElementById('get-form') as HTMLFormElement;
  const getResult = document.getElementById('get-result') as HTMLPreElement;

  getForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(getForm);
    const access_token = fd.get('access_token') as string;

    getResult.className = '';
    getResult.textContent = 'Chargement…';

    try {
      const { status, data } = await apiFetch('/v1/account/notification-preferences', {
        headers: { 'Authorization': `Bearer ${access_token}` },
      });
      getResult.className = status < 300 ? 'success' : 'error';
      getResult.textContent = `HTTP ${status}\n${data !== null ? JSON.stringify(data, null, 2) : '(aucun contenu)'}`;
    } catch (err) {
      getResult.className = 'error';
      getResult.textContent = `Erreur réseau : ${err instanceof Error ? err.message : String(err)}`;
    }
  });

  // PATCH
  const patchForm = document.getElementById('patch-form') as HTMLFormElement;
  const patchResult = document.getElementById('patch-result') as HTMLPreElement;

  patchForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(patchForm);
    const access_token = fd.get('access_token') as string;

    const channels: Record<string, Record<string, boolean>> = {
      email: {
        appointment_reminder: fd.get('email_appointment_reminder') === 'true',
        document_ready: fd.get('email_document_ready') === 'true',
        payment_due: fd.get('email_payment_due') === 'true',
        message: fd.get('email_message') === 'true',
      },
      push: {
        appointment_reminder: fd.get('push_appointment_reminder') === 'true',
        document_ready: fd.get('push_document_ready') === 'true',
        payment_due: fd.get('push_payment_due') === 'true',
        message: fd.get('push_message') === 'true',
      },
      sms: {
        appointment_reminder: fd.get('sms_appointment_reminder') === 'true',
        payment_due: fd.get('sms_payment_due') === 'true',
      },
    };

    patchResult.className = '';
    patchResult.textContent = 'Chargement…';

    try {
      const { status, data } = await apiFetch('/v1/account/notification-preferences', {
        method: 'PATCH',
        headers: {
          'Content-Type': 'application/json',
          'Authorization': `Bearer ${access_token}`,
        },
        body: JSON.stringify({ channels }),
      });
      patchResult.className = status < 300 ? 'success' : 'error';
      patchResult.textContent = `HTTP ${status}\n${data !== null ? JSON.stringify(data, null, 2) : '(aucun contenu)'}`;
    } catch (err) {
      patchResult.className = 'error';
      patchResult.textContent = `Erreur réseau : ${err instanceof Error ? err.message : String(err)}`;
    }
  });
</script>
