---
import Default from '../../../layouts/Default.astro';
---
<Default title="Account Update — Nubia Console">
  <h1 style="margin-bottom:1.5rem;">PATCH /v1/account</h1>
  <form id="account-update-form" style="display:flex;flex-direction:column;gap:0.75rem;max-width:480px;">
    <label>
      Access token (Bearer)
      <input type="text" name="access_token" required
        style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
    </label>

    <label>
      Prénom
      <input type="text" name="first_name" placeholder="Marie"
        style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
    </label>

    <label>
      Nom
      <input type="text" name="last_name" placeholder="Dupont"
        style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
    </label>

    <label>
      Date de naissance
      <input type="date" name="birth_date"
        style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
    </label>

    <label>
      Email
      <input type="email" name="email" placeholder="marie.dupont@example.com"
        style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
    </label>

    <label>
      Téléphone
      <input type="tel" name="phone" placeholder="+33 6 12 34 56 78"
        style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
    </label>

    <button type="submit"
      style="padding:0.5rem 1rem;background:var(--accent);color:#fff;border:none;border-radius:4px;cursor:pointer;align-self:flex-start;">
      Envoyer
    </button>
  </form>
  <pre id="result" style="margin-top:1.5rem;padding:1rem;background:var(--surface);border:1px solid var(--border);border-radius:4px;white-space:pre-wrap;font-size:0.875rem;min-height:3rem;"></pre>
</Default>

<style>
  pre.success { border-left: 4px solid green; }
  pre.error   { border-left: 4px solid red; }
</style>

<script>
  import { apiFetch } from '../../../lib/api.ts';

  const form = document.getElementById('account-update-form') as HTMLFormElement;
  const result = document.getElementById('result') as HTMLPreElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(form);
    const access_token = fd.get('access_token') as string;

    const body: Record<string, unknown> = {};
    const first_name = fd.get('first_name') as string;
    const last_name = fd.get('last_name') as string;
    const birth_date = fd.get('birth_date') as string;
    const email = fd.get('email') as string;
    const phone = fd.get('phone') as string;

    if (first_name) body.first_name = first_name;
    if (last_name) body.last_name = last_name;
    if (birth_date) body.birth_date = birth_date;
    if (email) body.email = email;
    if (phone) body.phone = phone;

    result.className = '';
    result.textContent = 'Chargement…';

    try {
      const { status, data } = await apiFetch('/v1/account', {
        method: 'PATCH',
        headers: {
          'Content-Type': 'application/json',
          'Authorization': `Bearer ${access_token}`,
        },
        body: JSON.stringify(body),
      });
      result.className = status < 300 ? 'success' : 'error';
      result.textContent = `HTTP ${status}\n${data !== null ? JSON.stringify(data, null, 2) : '(aucun contenu)'}`;
    } catch (err) {
      result.className = 'error';
      result.textContent = `Erreur réseau : ${err instanceof Error ? err.message : String(err)}`;
    }
  });
</script>
