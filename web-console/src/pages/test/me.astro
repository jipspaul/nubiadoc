---
import Default from '../../layouts/Default.astro';
---
<Default title="Test /v1/me — Nubia Console">
  <h1 style="margin-bottom:0.5rem;">Test : profil, refresh &amp; logout</h1>
  <p style="color:var(--muted);margin-bottom:2rem;">
    GET /v1/me · POST /v1/auth/refresh · POST /v1/auth/logout
  </p>

  <section style="margin-bottom:2rem;">
    <h2 style="font-size:1rem;margin-bottom:0.75rem;">1. GET /v1/me — Profil</h2>
    <form id="me-form" style="display:flex;flex-direction:column;gap:0.75rem;max-width:400px;">
      <label>
        Access token (Bearer)
        <input type="text" id="access-token" name="access_token" required
          style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
      </label>
      <button type="submit"
        style="padding:0.5rem 1rem;background:var(--accent);color:#fff;border:none;border-radius:4px;cursor:pointer;align-self:flex-start;">
        GET
      </button>
    </form>

    <section id="profile" style="display:none;margin-top:1rem;">
      <dl style="display:grid;grid-template-columns:max-content 1fr;gap:0.5rem 1rem;padding:1rem;background:var(--surface);border:1px solid var(--border);border-radius:4px;">
        <dt style="color:var(--muted);">user_id</dt><dd id="field-user_id">—</dd>
        <dt style="color:var(--muted);">email</dt><dd id="field-email">—</dd>
        <dt style="color:var(--muted);">kind</dt><dd id="field-kind">—</dd>
        <dt id="label-account_id" style="color:var(--muted);display:none;">account_id</dt>
        <dd id="field-account_id" style="display:none;">—</dd>
      </dl>
    </section>

    <section id="memberships-section" style="display:none;margin-top:1rem;">
      <h3 style="font-size:0.875rem;margin-bottom:0.5rem;color:var(--muted);">Memberships</h3>
      <table style="width:100%;border-collapse:collapse;background:var(--surface);border:1px solid var(--border);border-radius:4px;">
        <thead>
          <tr>
            <th style="padding:0.5rem 1rem;text-align:left;color:var(--muted);border-bottom:1px solid var(--border);">cabinet_id</th>
            <th style="padding:0.5rem 1rem;text-align:left;color:var(--muted);border-bottom:1px solid var(--border);">role</th>
          </tr>
        </thead>
        <tbody id="memberships-body"></tbody>
      </table>
    </section>

    <pre id="me-result" style="margin-top:1rem;padding:1rem;background:var(--surface);border:1px solid var(--border);border-radius:4px;white-space:pre-wrap;font-size:0.875rem;min-height:3rem;"></pre>
  </section>

  <section style="margin-bottom:2rem;">
    <h2 style="font-size:1rem;margin-bottom:0.75rem;">2. POST /v1/auth/refresh</h2>
    <form id="refresh-form" style="display:flex;flex-direction:column;gap:0.75rem;max-width:400px;">
      <label>
        Refresh token
        <input type="text" name="refresh_token" required
          style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
      </label>
      <button type="submit"
        style="padding:0.5rem 1rem;background:var(--accent);color:#fff;border:none;border-radius:4px;cursor:pointer;align-self:flex-start;">
        Rafraîchir
      </button>
    </form>
    <pre id="refresh-result" style="margin-top:1rem;padding:1rem;background:var(--surface);border:1px solid var(--border);border-radius:4px;white-space:pre-wrap;font-size:0.875rem;min-height:3rem;"></pre>
  </section>

  <section>
    <h2 style="font-size:1rem;margin-bottom:0.75rem;">3. POST /v1/auth/logout</h2>
    <form id="logout-form" style="display:flex;flex-direction:column;gap:0.75rem;max-width:400px;">
      <label>
        Access token (Bearer)
        <input type="text" name="logout_access_token" required
          style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
      </label>
      <label>
        Refresh token
        <input type="text" name="logout_refresh_token" required
          style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
      </label>
      <button type="submit"
        style="padding:0.5rem 1rem;background:#c0392b;color:#fff;border:none;border-radius:4px;cursor:pointer;align-self:flex-start;">
        Révoquer &amp; logout
      </button>
    </form>
    <pre id="logout-result" style="margin-top:1rem;padding:1rem;background:var(--surface);border:1px solid var(--border);border-radius:4px;white-space:pre-wrap;font-size:0.875rem;min-height:3rem;"></pre>
  </section>
</Default>

<style>
  pre.success { border-left: 4px solid green; }
  pre.error   { border-left: 4px solid red; }
</style>

<script>
  import { apiFetch } from '../../lib/api.ts';

  interface Membership { cabinet_id: string; role: string; }
  interface MeResponse {
    user_id: string;
    email: string;
    kind: 'patient' | 'pro';
    account_id?: string;
    memberships?: Membership[];
  }

  // --- GET /v1/me ---
  const meForm = document.getElementById('me-form') as HTMLFormElement;
  const meResult = document.getElementById('me-result') as HTMLPreElement;
  const profile = document.getElementById('profile') as HTMLElement;
  const membershipsSection = document.getElementById('memberships-section') as HTMLElement;
  const membershipsBody = document.getElementById('memberships-body') as HTMLTableSectionElement;

  meForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(meForm);
    const access_token = fd.get('access_token') as string;

    meResult.className = '';
    meResult.textContent = 'Chargement…';
    profile.style.display = 'none';
    membershipsSection.style.display = 'none';

    try {
      const { status, data } = await apiFetch('/v1/me', {
        method: 'GET',
        headers: { 'Authorization': `Bearer ${access_token}` },
      });

      meResult.className = status < 300 ? 'success' : 'error';
      meResult.textContent = `HTTP ${status}\n${data !== null ? JSON.stringify(data, null, 2) : '(aucun contenu)'}`;

      if (status === 200 && data) {
        const me = data as MeResponse;
        (document.getElementById('field-user_id') as HTMLElement).textContent = me.user_id ?? '—';
        (document.getElementById('field-email') as HTMLElement).textContent = me.email ?? '—';
        (document.getElementById('field-kind') as HTMLElement).textContent = me.kind ?? '—';
        profile.style.display = '';

        if (me.kind === 'patient' && me.account_id) {
          const labelAccountId = document.getElementById('label-account_id') as HTMLElement;
          const fieldAccountId = document.getElementById('field-account_id') as HTMLElement;
          fieldAccountId.textContent = me.account_id;
          labelAccountId.style.display = '';
          fieldAccountId.style.display = '';
        }

        if (me.kind === 'pro' && me.memberships?.length) {
          membershipsBody.innerHTML = me.memberships.map((m) =>
            `<tr><td style="padding:0.5rem 1rem;border-bottom:1px solid var(--border);">${m.cabinet_id}</td><td style="padding:0.5rem 1rem;border-bottom:1px solid var(--border);">${m.role}</td></tr>`
          ).join('');
          membershipsSection.style.display = '';
        }
      }
    } catch (err) {
      meResult.className = 'error';
      meResult.textContent = `Erreur réseau : ${err instanceof Error ? err.message : String(err)}`;
    }
  });

  // --- POST /v1/auth/refresh ---
  const refreshForm = document.getElementById('refresh-form') as HTMLFormElement;
  const refreshResult = document.getElementById('refresh-result') as HTMLPreElement;

  refreshForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(refreshForm);
    const refresh_token = fd.get('refresh_token') as string;

    refreshResult.className = '';
    refreshResult.textContent = 'Chargement…';

    try {
      const { status, data } = await apiFetch('/v1/auth/refresh', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ refresh_token }),
      });
      refreshResult.className = status === 200 ? 'success' : 'error';
      refreshResult.textContent = `HTTP ${status}\n${data !== null ? JSON.stringify(data, null, 2) : '(aucun contenu)'}`;
    } catch (err) {
      refreshResult.className = 'error';
      refreshResult.textContent = `Erreur réseau : ${err instanceof Error ? err.message : String(err)}`;
    }
  });

  // --- POST /v1/auth/logout ---
  const logoutForm = document.getElementById('logout-form') as HTMLFormElement;
  const logoutResult = document.getElementById('logout-result') as HTMLPreElement;

  logoutForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(logoutForm);
    const access_token = fd.get('logout_access_token') as string;
    const refresh_token = fd.get('logout_refresh_token') as string;

    logoutResult.className = '';
    logoutResult.textContent = 'Chargement…';

    try {
      const { status, data } = await apiFetch('/v1/auth/logout', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Authorization': `Bearer ${access_token}`,
        },
        body: JSON.stringify({ refresh_token }),
      });
      logoutResult.className = status === 204 ? 'success' : 'error';
      logoutResult.textContent = `HTTP ${status}\n${data !== null ? JSON.stringify(data, null, 2) : '(aucun contenu)'}`;
    } catch (err) {
      logoutResult.className = 'error';
      logoutResult.textContent = `Erreur réseau : ${err instanceof Error ? err.message : String(err)}`;
    }
  });
</script>
