---
import Default from '../../../layouts/Default.astro';
---
<Default title="Queue — Nubia Console">
  <h1 style="margin-bottom:1.5rem;">GET /v1/appointments/:id/queue</h1>
  <form id="queue-form" style="display:flex;flex-direction:column;gap:0.75rem;max-width:400px;">
    <label>
      Access token (Bearer)
      <input type="text" name="access_token" required
        style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
    </label>
    <label>
      Appointment ID
      <input type="text" name="appointment_id" required placeholder="uuid"
        style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
    </label>
    <button type="submit"
      style="padding:0.5rem 1rem;background:var(--accent);color:#fff;border:none;border-radius:4px;cursor:pointer;align-self:flex-start;">
      GET
    </button>
  </form>
  <p id="status-badge" style="margin-top:1rem;display:none;"></p>
  <section id="queue-result" aria-live="polite" style="margin-top:1rem;display:none;">
    <dl style="display:grid;grid-template-columns:max-content 1fr;gap:0.5rem 1rem;padding:1rem;background:var(--surface);border:1px solid var(--border);border-radius:4px;">
      <dt>Position</dt><dd id="q-position">—</dd>
      <dt>Attente estimée</dt><dd id="q-wait">—</dd>
      <dt>Statut</dt><dd id="q-status">—</dd>
    </dl>
  </section>
  <pre id="result" style="margin-top:1rem;padding:1rem;background:var(--surface);border:1px solid var(--border);border-radius:4px;white-space:pre-wrap;font-size:0.875rem;min-height:3rem;"></pre>
</Default>

<style>
  pre.success { border-left: 4px solid green; }
  pre.error   { border-left: 4px solid red; }
  .badge { display:inline-block;padding:0.25rem 0.6rem;border-radius:4px;font-size:0.85rem;font-weight:600; }
  .badge-ok  { background:#166534;color:#bbf7d0; }
  .badge-err { background:#7f1d1d;color:#fecaca; }
</style>

<script>
  import { apiFetch } from '../../../lib/api.ts';

  interface QueueResponse {
    position: number;
    est_wait_min: number;
    status: string;
  }

  const form = document.getElementById('queue-form') as HTMLFormElement;
  const result = document.getElementById('result') as HTMLPreElement;
  const badge = document.getElementById('status-badge') as HTMLParagraphElement;
  const queueResult = document.getElementById('queue-result') as HTMLElement;
  const qPosition = document.getElementById('q-position') as HTMLElement;
  const qWait = document.getElementById('q-wait') as HTMLElement;
  const qStatus = document.getElementById('q-status') as HTMLElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(form);
    const access_token = fd.get('access_token') as string;
    const appointment_id = fd.get('appointment_id') as string;

    result.className = '';
    result.textContent = 'Chargement…';
    badge.style.display = 'none';
    queueResult.style.display = 'none';

    try {
      const { status: httpStatus, data } = await apiFetch(
        `/v1/appointments/${encodeURIComponent(appointment_id)}/queue`,
        { method: 'GET', headers: { Authorization: `Bearer ${access_token}` } },
      );

      result.className = httpStatus < 300 ? 'success' : 'error';
      result.textContent = `HTTP ${httpStatus}\n${data !== null ? JSON.stringify(data, null, 2) : '(aucun contenu)'}`;
      badge.innerHTML = `<span class="badge ${httpStatus < 300 ? 'badge-ok' : 'badge-err'}">HTTP ${httpStatus}</span>`;
      badge.style.display = 'block';

      if (httpStatus === 200 && data !== null) {
        const q = data as QueueResponse;
        qPosition.textContent = String(q.position);
        qWait.textContent = `${q.est_wait_min} min`;
        qStatus.textContent = q.status;
        queueResult.style.display = 'block';
      }
    } catch (err) {
      result.className = 'error';
      result.textContent = `Erreur réseau : ${err instanceof Error ? err.message : String(err)}`;
    }
  });
</script>
