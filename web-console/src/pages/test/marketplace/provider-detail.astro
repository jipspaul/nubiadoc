---
import Default from '../../../layouts/Default.astro';
---
<Default title="Provider Detail — Nubia Console">
  <h1 style="margin-bottom:1.5rem;">GET /v1/providers/{id}</h1>
  <form id="provider-form" style="display:flex;flex-direction:column;gap:0.75rem;max-width:480px;">
    <label>
      provider_id
      <input type="text" id="provider-id" name="provider_id" placeholder="ex : prov_123"
        required
        style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
    </label>
    <label>
      from (availability)
      <input type="text" name="from" placeholder="ex : 2026-06-10"
        style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
    </label>
    <label>
      to (availability)
      <input type="text" name="to" placeholder="ex : 2026-06-17"
        style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
    </label>
    <label>
      motif (availability)
      <input type="text" name="motif" placeholder="ex : consultation"
        style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
    </label>
    <button type="submit"
      style="padding:0.5rem 1rem;background:var(--accent);color:#fff;border:none;border-radius:4px;cursor:pointer;align-self:flex-start;">
      Charger
    </button>
  </form>

  <!-- Profil praticien -->
  <section id="profile-section" style="margin-top:2rem;display:none;">
    <h2 style="font-size:1rem;margin-bottom:0.75rem;">
      Profil — <span id="profile-status-badge"></span>
    </h2>
    <p id="profile-error" role="alert" style="display:none;color:#fca5a5;margin-bottom:0.5rem;"></p>
    <dl id="profile-dl" style="display:grid;grid-template-columns:max-content 1fr;gap:0.25rem 1rem;font-size:0.875rem;"></dl>
  </section>

  <!-- Créneaux -->
  <section id="availability-section" style="margin-top:2rem;display:none;">
    <h2 style="font-size:1rem;margin-bottom:0.75rem;">
      Disponibilités — <span id="avail-status-badge"></span>
    </h2>
    <p id="avail-error" role="alert" style="display:none;color:#fca5a5;margin-bottom:0.5rem;"></p>
    <table id="slots-table" style="width:100%;border-collapse:collapse;font-size:0.875rem;">
      <thead>
        <tr>
          <th style="text-align:left;padding:0.5rem;border-bottom:1px solid var(--border);">slot_id</th>
          <th style="text-align:left;padding:0.5rem;border-bottom:1px solid var(--border);">starts_at</th>
          <th style="text-align:left;padding:0.5rem;border-bottom:1px solid var(--border);">ends_at</th>
          <th style="text-align:left;padding:0.5rem;border-bottom:1px solid var(--border);">motif</th>
        </tr>
      </thead>
      <tbody id="slots-tbody">
        <tr><td colspan="4" style="padding:0.5rem;color:var(--muted);">—</td></tr>
      </tbody>
    </table>
  </section>
</Default>

<style>
  #profile-dl dt { color: var(--muted); }
  #profile-dl dd { color: var(--text); }
  #slots-tbody td { padding: 0.5rem; border-bottom: 1px solid var(--border); }
  .badge { display:inline-block;padding:0.25rem 0.6rem;border-radius:4px;font-size:0.85rem;font-weight:600; }
  .badge-ok  { background:#166534;color:#bbf7d0; }
  .badge-err { background:#7f1d1d;color:#fecaca; }
</style>

<script>
  import { apiFetch } from '../../../lib/api.ts';

  const form = document.getElementById('provider-form') as HTMLFormElement;

  const profileSection = document.getElementById('profile-section') as HTMLElement;
  const profileBadge = document.getElementById('profile-status-badge') as HTMLSpanElement;
  const profileError = document.getElementById('profile-error') as HTMLParagraphElement;
  const profileDl = document.getElementById('profile-dl') as HTMLDListElement;

  const availSection = document.getElementById('availability-section') as HTMLElement;
  const availBadge = document.getElementById('avail-status-badge') as HTMLSpanElement;
  const availError = document.getElementById('avail-error') as HTMLParagraphElement;
  const slotsTbody = document.getElementById('slots-tbody') as HTMLTableSectionElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(form);
    const providerId = (fd.get('provider_id') as string).trim();
    const from = (fd.get('from') as string).trim();
    const to = (fd.get('to') as string).trim();
    const motif = (fd.get('motif') as string).trim();

    // Reset display
    profileSection.style.display = 'none';
    availSection.style.display = 'none';
    profileError.style.display = 'none';
    availError.style.display = 'none';

    // --- GET /v1/providers/{id} ---
    try {
      const { status, data } = await apiFetch(`/v1/providers/${providerId}`);
      profileBadge.innerHTML = `<span class="badge ${status < 300 ? 'badge-ok' : 'badge-err'}">HTTP ${status}</span>`;
      profileSection.style.display = 'block';

      if (status >= 300) {
        profileError.textContent = JSON.stringify(data, null, 2);
        profileError.style.display = 'block';
        profileDl.innerHTML = '';
      } else {
        const profile = data as Record<string, unknown>;
        const fields: Array<[string, string]> = [
          ['provider_id', String(profile.provider_id ?? '—')],
          ['display_name', String(profile.display_name ?? '—')],
          ['specialty', String(profile.specialty ?? '—')],
          ['sector', String(profile.sector ?? '—')],
          ['address', String(profile.address ?? '—')],
          ['bio', String(profile.bio ?? '—')],
          ['languages', Array.isArray(profile.languages) ? profile.languages.join(', ') : String(profile.languages ?? '—')],
          ['rating_avg', profile.rating_avg != null ? String(profile.rating_avg) : '—'],
          ['review_count', profile.review_count != null ? String(profile.review_count) : '—'],
          ['accepts_new', profile.accepts_new != null ? String(profile.accepts_new) : '—'],
          ['teleconsult', profile.teleconsult != null ? String(profile.teleconsult) : '—'],
        ];
        profileDl.innerHTML = fields
          .map(([k, v]) => `<dt>${k}</dt><dd>${v}</dd>`)
          .join('');
      }
    } catch (err) {
      profileBadge.innerHTML = '<span class="badge badge-err">Erreur réseau</span>';
      profileError.textContent = err instanceof Error ? err.message : String(err);
      profileError.style.display = 'block';
      profileSection.style.display = 'block';
    }

    // --- GET /v1/providers/{id}/availability ---
    const availParams = new URLSearchParams();
    if (from) availParams.set('from', from);
    if (to) availParams.set('to', to);
    if (motif) availParams.set('motif', motif);
    const availPath = `/v1/providers/${providerId}/availability${availParams.toString() ? '?' + availParams.toString() : ''}`;

    try {
      const { status, data } = await apiFetch(availPath);
      availBadge.innerHTML = `<span class="badge ${status < 300 ? 'badge-ok' : 'badge-err'}">HTTP ${status}</span>`;
      availSection.style.display = 'block';

      if (status >= 300) {
        availError.textContent = JSON.stringify(data, null, 2);
        availError.style.display = 'block';
        slotsTbody.innerHTML = `<tr><td colspan="4" style="padding:0.5rem;color:#fca5a5;">Erreur HTTP ${status}</td></tr>`;
        return;
      }

      const result = data as { data?: Array<Record<string, unknown>> };
      const slots = result.data ?? [];
      slotsTbody.innerHTML = '';
      if (slots.length === 0) {
        slotsTbody.innerHTML = '<tr><td colspan="4" style="padding:0.5rem;color:var(--muted);">Aucun créneau disponible.</td></tr>';
      } else {
        for (const s of slots) {
          const tr = document.createElement('tr');
          tr.innerHTML = [
            String(s.slot_id ?? '—'),
            String(s.starts_at ?? '—'),
            String(s.ends_at ?? '—'),
            String(s.motif ?? '—'),
          ].map(v => `<td>${v}</td>`).join('');
          slotsTbody.appendChild(tr);
        }
      }
    } catch (err) {
      availBadge.innerHTML = '<span class="badge badge-err">Erreur réseau</span>';
      availError.textContent = err instanceof Error ? err.message : String(err);
      availError.style.display = 'block';
      availSection.style.display = 'block';
    }
  });
</script>
