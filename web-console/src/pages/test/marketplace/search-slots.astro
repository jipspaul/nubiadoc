---
import Default from '../../../layouts/Default.astro';
---
<Default title="Search Slots — Nubia Console">
  <h1 style="margin-bottom:1.5rem;">GET /v1/search/slots</h1>
  <form id="search-form" style="display:flex;flex-direction:column;gap:0.75rem;max-width:480px;">
    <label>
      specialty
      <input type="text" name="specialty" placeholder="ex : cardiologie"
        style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
    </label>
    <label>
      near (lat,lng)
      <input type="text" name="near" placeholder="ex : 48.8566,2.3522"
        style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
    </label>
    <label>
      radius_km
      <input type="number" name="radius_km" placeholder="ex : 10" min="1"
        style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
    </label>
    <label>
      available
      <select name="available"
        style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;">
        <option value="">— aucun —</option>
        <option value="today">today</option>
        <option value="week">week</option>
      </select>
    </label>
    <button type="submit"
      style="padding:0.5rem 1rem;background:var(--accent);color:#fff;border:none;border-radius:4px;cursor:pointer;align-self:flex-start;">
      Rechercher
    </button>
  </form>

  <p id="status-badge" style="margin-top:1rem;display:none;"></p>
  <p id="error-msg" role="alert" style="display:none;color:#fca5a5;margin-top:0.5rem;"></p>

  <section id="results-section" style="margin-top:1.5rem;">
    <table id="slots-table" style="width:100%;border-collapse:collapse;font-size:0.875rem;">
      <thead>
        <tr>
          <th style="text-align:left;padding:0.5rem;border-bottom:1px solid var(--border);">provider_id</th>
          <th style="text-align:left;padding:0.5rem;border-bottom:1px solid var(--border);">display_name</th>
          <th style="text-align:left;padding:0.5rem;border-bottom:1px solid var(--border);">first_slot_at</th>
          <th style="text-align:left;padding:0.5rem;border-bottom:1px solid var(--border);">slots</th>
        </tr>
      </thead>
      <tbody id="slots-tbody">
        <tr><td colspan="4" style="padding:0.5rem;color:var(--muted);">—</td></tr>
      </tbody>
    </table>
  </section>
</Default>

<style>
  #slots-tbody td { padding: 0.5rem; border-bottom: 1px solid var(--border); }
  .badge { display:inline-block;padding:0.25rem 0.6rem;border-radius:4px;font-size:0.85rem;font-weight:600; }
  .badge-ok  { background:#166534;color:#bbf7d0; }
  .badge-err { background:#7f1d1d;color:#fecaca; }
</style>

<script>
  import { apiFetch } from '../../../lib/api.ts';

  const form = document.getElementById('search-form') as HTMLFormElement;
  const tbody = document.getElementById('slots-tbody') as HTMLTableSectionElement;
  const badge = document.getElementById('status-badge') as HTMLParagraphElement;
  const errorMsg = document.getElementById('error-msg') as HTMLParagraphElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(form);
    const params = new URLSearchParams();
    for (const [key, val] of fd.entries()) {
      if (val && String(val).trim()) params.set(key, String(val).trim());
    }
    const path = `/v1/search/slots${params.toString() ? '?' + params.toString() : ''}`;

    tbody.innerHTML = '<tr><td colspan="4" style="padding:0.5rem;color:var(--muted);">Chargement…</td></tr>';
    badge.style.display = 'none';
    errorMsg.style.display = 'none';

    try {
      const { status, data } = await apiFetch(path);
      badge.innerHTML = `<span class="badge ${status < 300 ? 'badge-ok' : 'badge-err'}">HTTP ${status}</span>`;
      badge.style.display = 'block';

      if (status >= 300) {
        tbody.innerHTML = `<tr><td colspan="4" style="padding:0.5rem;color:#fca5a5;">Erreur HTTP ${status}</td></tr>`;
        errorMsg.textContent = JSON.stringify(data, null, 2);
        errorMsg.style.display = 'block';
        return;
      }

      const result = data as {
        data?: Array<{ provider_id: string; display_name: string; first_slot_at: string; slots: Array<{ slot_id: string; starts_at: string }> }>;
      };
      const providers = result.data ?? [];
      tbody.innerHTML = '';
      if (providers.length === 0) {
        tbody.innerHTML = '<tr><td colspan="4" style="padding:0.5rem;color:var(--muted);">Aucun créneau.</td></tr>';
      } else {
        for (const p of providers) {
          const slotsSummary = p.slots?.map(s => s.starts_at).slice(0, 3).join(', ') ?? '—';
          const tr = document.createElement('tr');
          tr.innerHTML = [
            p.provider_id ?? '',
            p.display_name ?? '',
            p.first_slot_at ?? '—',
            slotsSummary,
          ].map(v => `<td>${v}</td>`).join('');
          tbody.appendChild(tr);
        }
      }
    } catch (err) {
      tbody.innerHTML = '<tr><td colspan="4" style="padding:0.5rem;color:#fca5a5;">Erreur réseau</td></tr>';
      errorMsg.textContent = err instanceof Error ? err.message : String(err);
      errorMsg.style.display = 'block';
    }
  });
</script>
