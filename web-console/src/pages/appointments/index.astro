---
import Default from '../../layouts/Default.astro';
---
<Default title="Mes rendez-vous — Nubia Console">
  <h1 style="margin-bottom:0.5rem;">GET /v1/appointments + POST /v1/appointments</h1>
  <p style="color:var(--muted);margin-bottom:1.5rem;font-size:0.875rem;">Liste des RDV patient + prise de RDV.</p>

  <section aria-labelledby="list-heading" style="margin-bottom:2rem;">
    <h2 id="list-heading" style="font-size:1.1rem;margin-bottom:0.75rem;">Liste des rendez-vous</h2>
    <form id="list-form" style="display:flex;flex-direction:column;gap:0.75rem;max-width:500px;">
      <label>
        Access token (Bearer)
        <input type="text" name="access_token" required
          style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
      </label>
      <label>
        Statut
        <select name="status"
          style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;">
          <option value="">tous</option>
          <option value="upcoming">upcoming</option>
          <option value="past">past</option>
        </select>
      </label>
      <label>
        Cursor (pagination, optionnel)
        <input type="text" name="cursor" placeholder="opaque cursor"
          style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
      </label>
      <button type="submit" id="list-btn"
        style="padding:0.5rem 1rem;background:var(--accent);color:#fff;border:none;border-radius:4px;cursor:pointer;align-self:flex-start;">
        Charger les RDV
      </button>
    </form>
    <p id="list-badge" style="margin-top:1rem;display:none;"></p>
    <pre id="list-result" style="margin-top:1rem;padding:1rem;background:var(--surface);border:1px solid var(--border);border-radius:4px;white-space:pre-wrap;font-size:0.875rem;min-height:3rem;"></pre>
  </section>

  <hr style="border:none;border-top:1px solid var(--border);margin:2rem 0;" />

  <section aria-labelledby="book-heading">
    <h2 id="book-heading" style="font-size:1.1rem;margin-bottom:0.75rem;">Prendre un rendez-vous</h2>
    <form id="book-form" style="display:flex;flex-direction:column;gap:0.75rem;max-width:500px;">
      <label>
        Access token (Bearer)
        <input type="text" name="access_token" required
          style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
      </label>
      <label>
        Provider ID
        <input type="text" name="provider_id" required placeholder="uuid"
          style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
      </label>
      <label>
        Motif
        <input type="text" name="motif" required placeholder="ex: bilan annuel"
          style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
      </label>
      <label>
        Slot ID (optionnel)
        <input type="text" name="slot_id" placeholder="uuid"
          style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
      </label>
      <label>
        Starts at (optionnel, ISO 8601)
        <input type="text" name="starts_at" placeholder="2026-06-10T09:00:00Z"
          style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
      </label>
      <button type="submit" id="book-btn"
        style="padding:0.5rem 1rem;background:var(--accent);color:#fff;border:none;border-radius:4px;cursor:pointer;align-self:flex-start;">
        Prendre RDV
      </button>
    </form>
    <p id="book-badge" style="margin-top:1rem;display:none;"></p>
    <p id="book-confirmation" style="margin-top:0.75rem;display:none;padding:0.75rem;background:var(--surface);border:1px solid var(--border);border-radius:4px;"></p>
    <pre id="book-result" style="margin-top:1rem;padding:1rem;background:var(--surface);border:1px solid var(--border);border-radius:4px;white-space:pre-wrap;font-size:0.875rem;min-height:3rem;"></pre>
  </section>
</Default>

<style>
  pre.success { border-left: 4px solid green; }
  pre.error   { border-left: 4px solid red; }
  .badge { display:inline-block;padding:0.25rem 0.6rem;border-radius:4px;font-size:0.85rem;font-weight:600; }
  .badge-ok  { background:#166534;color:#bbf7d0; }
  .badge-err { background:#7f1d1d;color:#fecaca; }
</style>

<script>
  import { apiFetch } from '../../lib/api.ts';

  interface AppointmentCreated {
    appointment_id?: string;
    status?: string;
  }

  // --- Liste des RDV ---
  const listForm = document.getElementById('list-form') as HTMLFormElement;
  const listResult = document.getElementById('list-result') as HTMLPreElement;
  const listBadge = document.getElementById('list-badge') as HTMLParagraphElement;

  listForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(listForm);
    const access_token = fd.get('access_token') as string;
    const status = fd.get('status') as string;
    const cursor = fd.get('cursor') as string;

    const params = new URLSearchParams();
    if (status) params.set('status', status);
    if (cursor) params.set('cursor', cursor);
    const qs = params.toString() ? `?${params.toString()}` : '';

    listResult.className = '';
    listResult.textContent = 'Chargement…';
    listBadge.style.display = 'none';

    try {
      const { status: httpStatus, data } = await apiFetch(`/v1/appointments${qs}`, {
        headers: { Authorization: `Bearer ${access_token}` },
      });
      listResult.className = httpStatus < 300 ? 'success' : 'error';
      listResult.textContent = `HTTP ${httpStatus}\n${data !== null ? JSON.stringify(data, null, 2) : '(aucun contenu)'}`;
      listBadge.innerHTML = `<span class="badge ${httpStatus < 300 ? 'badge-ok' : 'badge-err'}">HTTP ${httpStatus}</span>`;
      listBadge.style.display = 'block';
    } catch (err) {
      listResult.className = 'error';
      listResult.textContent = `Erreur réseau : ${err instanceof Error ? err.message : String(err)}`;
    }
  });

  // --- Prise de RDV ---
  const bookForm = document.getElementById('book-form') as HTMLFormElement;
  const bookResult = document.getElementById('book-result') as HTMLPreElement;
  const bookBadge = document.getElementById('book-badge') as HTMLParagraphElement;
  const bookConfirmation = document.getElementById('book-confirmation') as HTMLParagraphElement;

  bookForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(bookForm);
    const access_token = fd.get('access_token') as string;
    const provider_id = fd.get('provider_id') as string;
    const motif = fd.get('motif') as string;
    const slot_id = fd.get('slot_id') as string;
    const starts_at = fd.get('starts_at') as string;

    const body: Record<string, string> = { provider_id, motif };
    if (slot_id) body.slot_id = slot_id;
    if (starts_at) body.starts_at = starts_at;

    bookResult.className = '';
    bookResult.textContent = 'Envoi…';
    bookBadge.style.display = 'none';
    bookConfirmation.style.display = 'none';

    try {
      const { status: httpStatus, data } = await apiFetch('/v1/appointments', {
        method: 'POST',
        headers: {
          Authorization: `Bearer ${access_token}`,
          'Content-Type': 'application/json',
        },
        body: JSON.stringify(body),
      });
      bookResult.className = httpStatus < 300 ? 'success' : 'error';
      bookResult.textContent = `HTTP ${httpStatus}\n${data !== null ? JSON.stringify(data, null, 2) : '(aucun contenu)'}`;
      bookBadge.innerHTML = `<span class="badge ${httpStatus < 300 ? 'badge-ok' : 'badge-err'}">HTTP ${httpStatus}</span>`;
      bookBadge.style.display = 'block';

      if (httpStatus === 201 && data && typeof data === 'object') {
        const d = data as AppointmentCreated;
        bookConfirmation.textContent = `RDV créé — id: ${d.appointment_id ?? '—'} · statut: ${d.status ?? '—'}`;
        bookConfirmation.style.display = 'block';
      }
    } catch (err) {
      bookResult.className = 'error';
      bookResult.textContent = `Erreur réseau : ${err instanceof Error ? err.message : String(err)}`;
    }
  });
</script>
