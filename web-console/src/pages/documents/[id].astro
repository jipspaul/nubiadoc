---
import Default from '../../layouts/Default.astro';
---
<Default title="Détail document — Nubia Console">
  <h1 style="margin-bottom:0.5rem;">GET /v1/documents/{'{id}'} + GET /v1/documents/{'{id}'}/download</h1>
  <p style="color:var(--muted);margin-bottom:1.5rem;font-size:0.875rem;">Métadonnées d'un document + téléchargement via URL signée.</p>

  <section aria-labelledby="detail-heading" style="margin-bottom:2rem;">
    <h2 id="detail-heading" style="font-size:1.1rem;margin-bottom:0.75rem;">Métadonnées du document</h2>
    <form id="detail-form" style="display:flex;flex-direction:column;gap:0.75rem;max-width:480px;">
      <label>
        Access token (Bearer)
        <input type="text" name="access_token" required
          style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
      </label>
      <label>
        ID du document (UUID)
        <input type="text" name="document_id" required placeholder="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
          style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
      </label>
      <button type="submit" id="detail-btn"
        style="padding:0.5rem 1rem;background:var(--accent);color:#fff;border:none;border-radius:4px;cursor:pointer;align-self:flex-start;">
        Charger les métadonnées
      </button>
    </form>
    <p id="detail-badge" style="margin-top:1rem;display:none;"></p>
    <pre id="detail-result" style="margin-top:1rem;padding:1rem;background:var(--surface);border:1px solid var(--border);border-radius:4px;white-space:pre-wrap;font-size:0.875rem;min-height:3rem;"></pre>
  </section>

  <hr style="border:none;border-top:1px solid var(--border);margin:2rem 0;" />

  <section aria-labelledby="download-heading">
    <h2 id="download-heading" style="font-size:1.1rem;margin-bottom:0.75rem;">Télécharger</h2>
    <form id="download-form" style="display:flex;flex-direction:column;gap:0.75rem;max-width:480px;">
      <label>
        Access token (Bearer)
        <input type="text" name="access_token" required
          style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
      </label>
      <label>
        ID du document (UUID)
        <input type="text" name="document_id" required placeholder="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
          style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
      </label>
      <button type="submit" id="download-btn"
        style="padding:0.5rem 1rem;background:var(--accent);color:#fff;border:none;border-radius:4px;cursor:pointer;align-self:flex-start;">
        Télécharger
      </button>
    </form>
    <p id="download-badge" style="margin-top:1rem;display:none;"></p>
    <pre id="download-result" style="margin-top:1rem;padding:1rem;background:var(--surface);border:1px solid var(--border);border-radius:4px;white-space:pre-wrap;font-size:0.875rem;min-height:3rem;"></pre>
  </section>

  <hr style="border:none;border-top:1px solid var(--border);margin:2rem 0;" />

  <nav aria-label="Autres pages documents">
    <a href="/documents">← Retour à la liste</a>
  </nav>
</Default>

<style>
  pre.success { border-left: 4px solid green; }
  pre.error   { border-left: 4px solid red; }
  .badge { display:inline-block;padding:0.25rem 0.6rem;border-radius:4px;font-size:0.85rem;font-weight:600; }
  .badge-ok  { background:#166534;color:#bbf7d0; }
  .badge-err { background:#7f1d1d;color:#fecaca; }
</style>

<script>
  import { apiFetch } from '../../lib/api.ts';

  const API_BASE: string =
    (import.meta.env.PUBLIC_API_BASE as string | undefined) ?? 'http://localhost:3000';

  // --- Métadonnées ---
  const detailForm = document.getElementById('detail-form') as HTMLFormElement;
  const detailResult = document.getElementById('detail-result') as HTMLPreElement;
  const detailBadge = document.getElementById('detail-badge') as HTMLParagraphElement;

  detailForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(detailForm);
    const access_token = fd.get('access_token') as string;
    const document_id = fd.get('document_id') as string;

    detailResult.className = '';
    detailResult.textContent = 'Chargement…';
    detailBadge.style.display = 'none';

    try {
      const { status: httpStatus, data } = await apiFetch(`/v1/documents/${document_id}`, {
        headers: { Authorization: `Bearer ${access_token}` },
      });
      detailResult.className = httpStatus < 300 ? 'success' : 'error';
      detailResult.textContent = `HTTP ${httpStatus}\n${data !== null ? JSON.stringify(data, null, 2) : '(aucun contenu)'}`;
      detailBadge.innerHTML = `<span class="badge ${httpStatus < 300 ? 'badge-ok' : 'badge-err'}">HTTP ${httpStatus}</span>`;
      detailBadge.style.display = 'block';
    } catch (err) {
      detailResult.className = 'error';
      detailResult.textContent = `Erreur réseau : ${err instanceof Error ? err.message : String(err)}`;
    }
  });

  // --- Téléchargement ---
  const downloadForm = document.getElementById('download-form') as HTMLFormElement;
  const downloadResult = document.getElementById('download-result') as HTMLPreElement;
  const downloadBadge = document.getElementById('download-badge') as HTMLParagraphElement;

  downloadForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(downloadForm);
    const access_token = fd.get('access_token') as string;
    const document_id = fd.get('document_id') as string;

    downloadResult.className = '';
    downloadResult.textContent = 'Chargement…';
    downloadBadge.style.display = 'none';

    try {
      const res = await fetch(`${API_BASE}/v1/documents/${document_id}/download`, {
        method: 'GET',
        headers: { Authorization: `Bearer ${access_token}` },
      });

      if (res.ok) {
        const blob = await res.blob();
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = document_id;
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
        URL.revokeObjectURL(url);
        downloadResult.className = 'success';
        downloadResult.textContent = '302 suivi → téléchargement lancé';
        downloadBadge.innerHTML = '<span class="badge badge-ok">302 → téléchargement</span>';
        downloadBadge.style.display = 'block';
      } else if (res.status === 410) {
        downloadResult.className = 'error';
        downloadResult.textContent = `HTTP 410 — lien expiré\n${await res.text()}`;
        downloadBadge.innerHTML = '<span class="badge badge-err">410 lien expiré</span>';
        downloadBadge.style.display = 'block';
      } else {
        const text = await res.text();
        downloadResult.className = 'error';
        downloadResult.textContent = `HTTP ${res.status}\n${text}`;
        downloadBadge.innerHTML = `<span class="badge badge-err">HTTP ${res.status}</span>`;
        downloadBadge.style.display = 'block';
      }
    } catch (err) {
      downloadResult.className = 'error';
      downloadResult.textContent = `Erreur réseau : ${err instanceof Error ? err.message : String(err)}`;
    }
  });
</script>
