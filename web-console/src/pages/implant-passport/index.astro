---
import Default from '../../layouts/Default.astro';
---
<Default title="Passeport implantaire — Nubia Console">
  <h1 style="margin-bottom:0.5rem;">GET /v1/implant-passport</h1>
  <p style="color:var(--muted);margin-bottom:1.5rem;font-size:0.875rem;">Liste des implants et détail du passeport implantaire patient.</p>

  <section aria-labelledby="list-heading" style="margin-bottom:2rem;">
    <h2 id="list-heading" style="font-size:1.1rem;margin-bottom:0.75rem;">Passeport implantaire</h2>
    <form id="passport-form" style="display:flex;flex-direction:column;gap:0.75rem;max-width:500px;">
      <label>
        Access token (Bearer)
        <input type="text" name="access_token" required
          style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
      </label>
      <button type="submit"
        style="padding:0.5rem 1rem;background:var(--accent);color:#fff;border:none;border-radius:4px;cursor:pointer;align-self:flex-start;">
        Charger le passeport
      </button>
    </form>
    <p id="status-badge" style="margin-top:1rem;display:none;"></p>
    <section id="implants-list" style="margin-top:1rem;display:none;" aria-labelledby="implants-heading">
      <h3 id="implants-heading" style="font-size:1rem;margin-bottom:0.5rem;">Implants</h3>
      <table style="width:100%;border-collapse:collapse;font-size:0.875rem;">
        <thead>
          <tr>
            <th style="text-align:left;padding:0.5rem;border-bottom:1px solid var(--border);">id</th>
            <th style="text-align:left;padding:0.5rem;border-bottom:1px solid var(--border);">référence</th>
            <th style="text-align:left;padding:0.5rem;border-bottom:1px solid var(--border);">fabricant</th>
            <th style="text-align:left;padding:0.5rem;border-bottom:1px solid var(--border);">posé le</th>
          </tr>
        </thead>
        <tbody id="implants-tbody"></tbody>
      </table>
      <p id="empty-state" style="display:none;color:var(--muted);margin-top:0.75rem;">Aucun implant enregistré.</p>
    </section>
    <pre id="result" style="margin-top:1rem;padding:1rem;background:var(--surface);border:1px solid var(--border);border-radius:4px;white-space:pre-wrap;font-size:0.875rem;min-height:3rem;"></pre>
  </section>

  <hr style="border:none;border-top:1px solid var(--border);margin:2rem 0;" />

  <section aria-labelledby="export-heading">
    <h2 id="export-heading" style="font-size:1.1rem;margin-bottom:0.75rem;">Export PDF</h2>
    <p style="font-size:0.875rem;color:var(--muted);margin-bottom:0.75rem;">
      Génère une URL signée pour télécharger le passeport en PDF via
      <code>GET /v1/implant-passport/export</code>.
    </p>
    <form id="export-form" style="display:flex;flex-direction:column;gap:0.75rem;max-width:500px;">
      <label>
        Access token (Bearer)
        <input type="text" name="access_token" required
          style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
      </label>
      <button type="submit"
        style="padding:0.5rem 1rem;background:var(--accent);color:#fff;border:none;border-radius:4px;cursor:pointer;align-self:flex-start;">
        Obtenir le lien PDF
      </button>
    </form>
    <p id="export-badge" style="margin-top:1rem;display:none;"></p>
    <p id="export-link-container" style="margin-top:0.75rem;display:none;">
      Lien PDF : <a id="export-link" href="#" target="_blank" rel="noopener noreferrer">Télécharger</a>
    </p>
    <pre id="export-result" style="margin-top:1rem;padding:1rem;background:var(--surface);border:1px solid var(--border);border-radius:4px;white-space:pre-wrap;font-size:0.875rem;min-height:3rem;"></pre>
  </section>
</Default>

<style>
  pre.success { border-left: 4px solid green; }
  pre.error   { border-left: 4px solid red; }
  .badge { display:inline-block;padding:0.25rem 0.6rem;border-radius:4px;font-size:0.85rem;font-weight:600; }
  .badge-ok  { background:#166534;color:#bbf7d0; }
  .badge-err { background:#7f1d1d;color:#fecaca; }
  td { padding:0.5rem;border-bottom:1px solid var(--border); }
</style>

<script>
  import { apiFetch } from '../../lib/api.ts';

  interface ImplantEntry {
    id?: string;
    reference?: string;
    manufacturer?: string;
    implanted_at?: string;
  }

  interface ExportResponse {
    url?: string;
  }

  // --- Passeport ---
  const passportForm = document.getElementById('passport-form') as HTMLFormElement;
  const result = document.getElementById('result') as HTMLPreElement;
  const badge = document.getElementById('status-badge') as HTMLParagraphElement;
  const implantsList = document.getElementById('implants-list') as HTMLElement;
  const tbody = document.getElementById('implants-tbody') as HTMLTableSectionElement;
  const emptyState = document.getElementById('empty-state') as HTMLParagraphElement;

  passportForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(passportForm);
    const access_token = fd.get('access_token') as string;

    result.className = '';
    result.textContent = 'Chargement…';
    badge.style.display = 'none';
    implantsList.style.display = 'none';
    tbody.innerHTML = '';

    try {
      const { status: httpStatus, data } = await apiFetch('/v1/implant-passport', {
        headers: { Authorization: `Bearer ${access_token}` },
      });
      result.className = httpStatus < 300 ? 'success' : 'error';
      result.textContent = `HTTP ${httpStatus}\n${data !== null ? JSON.stringify(data, null, 2) : '(aucun contenu)'}`;
      badge.innerHTML = `<span class="badge ${httpStatus < 300 ? 'badge-ok' : 'badge-err'}">HTTP ${httpStatus}</span>`;
      badge.style.display = 'block';

      if (httpStatus < 300 && data !== null && typeof data === 'object') {
        const implants = (data as Record<string, unknown>).implants;
        if (Array.isArray(implants)) {
          implantsList.style.display = 'block';
          if (implants.length === 0) {
            emptyState.style.display = 'block';
          } else {
            emptyState.style.display = 'none';
            for (const implant of implants as ImplantEntry[]) {
              const tr = document.createElement('tr');
              tr.innerHTML = `
                <td>${implant.id ?? ''}</td>
                <td>${implant.reference ?? ''}</td>
                <td>${implant.manufacturer ?? ''}</td>
                <td>${implant.implanted_at ?? ''}</td>
              `;
              tbody.appendChild(tr);
            }
          }
        }
      }
    } catch (err) {
      result.className = 'error';
      result.textContent = `Erreur réseau : ${err instanceof Error ? err.message : String(err)}`;
    }
  });

  // --- Export PDF ---
  const exportForm = document.getElementById('export-form') as HTMLFormElement;
  const exportResult = document.getElementById('export-result') as HTMLPreElement;
  const exportBadge = document.getElementById('export-badge') as HTMLParagraphElement;
  const exportLinkContainer = document.getElementById('export-link-container') as HTMLParagraphElement;
  const exportLink = document.getElementById('export-link') as HTMLAnchorElement;

  exportForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(exportForm);
    const access_token = fd.get('access_token') as string;

    exportResult.className = '';
    exportResult.textContent = 'Chargement…';
    exportBadge.style.display = 'none';
    exportLinkContainer.style.display = 'none';

    try {
      const { status: httpStatus, data } = await apiFetch('/v1/implant-passport/export', {
        headers: { Authorization: `Bearer ${access_token}` },
      });
      exportResult.className = httpStatus < 300 ? 'success' : 'error';
      exportResult.textContent = `HTTP ${httpStatus}\n${data !== null ? JSON.stringify(data, null, 2) : '(aucun contenu)'}`;
      exportBadge.innerHTML = `<span class="badge ${httpStatus < 300 ? 'badge-ok' : 'badge-err'}">HTTP ${httpStatus}</span>`;
      exportBadge.style.display = 'block';

      if (httpStatus < 300 && data !== null && typeof data === 'object') {
        const d = data as ExportResponse;
        if (d.url) {
          exportLink.href = d.url;
          exportLinkContainer.style.display = 'block';
        }
      }
    } catch (err) {
      exportResult.className = 'error';
      exportResult.textContent = `Erreur réseau : ${err instanceof Error ? err.message : String(err)}`;
    }
  });
</script>
