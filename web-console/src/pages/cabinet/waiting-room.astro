---
import Default from '../../layouts/Default.astro';
---
<Default title="Salle d'attente — Nubia Console">
  <h1 style="margin-bottom:1.5rem;">GET /v1/cabinet/waiting-room + POST call-next</h1>

  <section style="margin-bottom:2rem;">
    <h2 style="margin-bottom:0.75rem;">File d'attente</h2>
    <form id="waiting-room-form" style="display:flex;flex-direction:column;gap:0.75rem;max-width:400px;">
      <label>
        Access token (Bearer)
        <input type="text" name="access_token" required
          style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
      </label>
      <button type="submit"
        style="padding:0.5rem 1rem;background:var(--accent);color:#fff;border:none;border-radius:4px;cursor:pointer;align-self:flex-start;">
        Charger la file
      </button>
    </form>
    <p id="room-badge" style="margin-top:1rem;display:none;"></p>
    <pre id="room-result" style="margin-top:1rem;padding:1rem;background:var(--surface);border:1px solid var(--border);border-radius:4px;white-space:pre-wrap;font-size:0.875rem;min-height:3rem;"></pre>
  </section>

  <section>
    <h2 style="margin-bottom:0.75rem;">Appeler le suivant</h2>
    <form id="call-next-form" style="display:flex;flex-direction:column;gap:0.75rem;max-width:400px;">
      <label>
        Access token (Bearer)
        <input type="text" name="access_token_cn" required
          style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
      </label>
      <button type="submit"
        style="padding:0.5rem 1rem;background:var(--accent);color:#fff;border:none;border-radius:4px;cursor:pointer;align-self:flex-start;">
        Appeler le suivant
      </button>
    </form>
    <p id="cn-badge" style="margin-top:1rem;display:none;"></p>
    <pre id="cn-result" style="margin-top:1rem;padding:1rem;background:var(--surface);border:1px solid var(--border);border-radius:4px;white-space:pre-wrap;font-size:0.875rem;min-height:3rem;"></pre>
  </section>
</Default>

<style>
  pre.success { border-left: 4px solid green; }
  pre.error   { border-left: 4px solid red; }
  .badge { display:inline-block;padding:0.25rem 0.6rem;border-radius:4px;font-size:0.85rem;font-weight:600; }
  .badge-ok  { background:#166534;color:#bbf7d0; }
  .badge-err { background:#7f1d1d;color:#fecaca; }
</style>

<script>
  import { apiFetch } from '../../lib/api.ts';

  const roomForm = document.getElementById('waiting-room-form') as HTMLFormElement;
  const roomResult = document.getElementById('room-result') as HTMLPreElement;
  const roomBadge = document.getElementById('room-badge') as HTMLParagraphElement;

  roomForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(roomForm);
    const access_token = fd.get('access_token') as string;

    roomResult.className = '';
    roomResult.textContent = 'Chargement…';
    roomBadge.style.display = 'none';

    try {
      const { status: httpStatus, data } = await apiFetch('/v1/cabinet/waiting-room', {
        method: 'GET',
        headers: { Authorization: `Bearer ${access_token}` },
      });
      roomResult.className = httpStatus < 300 ? 'success' : 'error';
      roomResult.textContent = `HTTP ${httpStatus}\n${data !== null ? JSON.stringify(data, null, 2) : '(aucun contenu)'}`;
      roomBadge.innerHTML = `<span class="badge ${httpStatus < 300 ? 'badge-ok' : 'badge-err'}">HTTP ${httpStatus}</span>`;
      roomBadge.style.display = 'block';
    } catch (err) {
      roomResult.className = 'error';
      roomResult.textContent = `Erreur réseau : ${err instanceof Error ? err.message : String(err)}`;
    }
  });

  const cnForm = document.getElementById('call-next-form') as HTMLFormElement;
  const cnResult = document.getElementById('cn-result') as HTMLPreElement;
  const cnBadge = document.getElementById('cn-badge') as HTMLParagraphElement;

  cnForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(cnForm);
    const access_token = fd.get('access_token_cn') as string;

    cnResult.className = '';
    cnResult.textContent = 'Chargement…';
    cnBadge.style.display = 'none';

    try {
      const { status: httpStatus, data } = await apiFetch('/v1/cabinet/waiting-room/call-next', {
        method: 'POST',
        headers: { Authorization: `Bearer ${access_token}` },
      });
      cnResult.className = httpStatus < 300 ? 'success' : 'error';
      cnResult.textContent = `HTTP ${httpStatus}\n${data !== null ? JSON.stringify(data, null, 2) : '(aucun contenu)'}`;
      cnBadge.innerHTML = `<span class="badge ${httpStatus < 300 ? 'badge-ok' : 'badge-err'}">HTTP ${httpStatus}</span>`;
      cnBadge.style.display = 'block';
    } catch (err) {
      cnResult.className = 'error';
      cnResult.textContent = `Erreur réseau : ${err instanceof Error ? err.message : String(err)}`;
    }
  });
</script>
