---
import Default from '../../../layouts/Default.astro';
---
<Default title="RDV cabinet — Nubia Console">
  <h1 style="margin-bottom:0.5rem;">Rendez-vous — GET /v1/cabinet/appointments</h1>
  <p style="color:var(--muted);margin-bottom:1.5rem;">Rôle requis : <code>pro</code></p>

  <section aria-labelledby="list-heading">
    <h2 id="list-heading" style="margin-bottom:1rem;">Lister les RDV</h2>
    <form id="appointments-form" style="display:flex;flex-direction:column;gap:0.75rem;max-width:480px;">
      <label>
        Access token (Bearer)
        <input type="text" name="access_token" required
          style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
      </label>
      <label>
        Statut (filtre optionnel)
        <select name="status"
          style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;">
          <option value="">— tous —</option>
          <option value="requested">requested</option>
          <option value="confirmed">confirmed</option>
          <option value="in_progress">in_progress</option>
          <option value="done">done</option>
          <option value="cancelled">cancelled</option>
        </select>
      </label>
      <label>
        Date (filtre optionnel, YYYY-MM-DD)
        <input type="date" name="date"
          style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
      </label>
      <button type="submit"
        style="padding:0.5rem 1rem;background:var(--accent);color:#fff;border:none;border-radius:4px;cursor:pointer;align-self:flex-start;">
        GET
      </button>
    </form>
    <p id="list-badge" style="margin-top:1rem;display:none;"></p>
    <pre id="list-result" style="margin-top:0.5rem;padding:1rem;background:var(--surface);border:1px solid var(--border);border-radius:4px;white-space:pre-wrap;font-size:0.875rem;min-height:3rem;"></pre>
  </section>
</Default>

<style>
  pre.success { border-left: 4px solid green; }
  pre.error   { border-left: 4px solid red; }
  .badge { display:inline-block;padding:0.25rem 0.6rem;border-radius:4px;font-size:0.85rem;font-weight:600; }
  .badge-ok  { background:#166534;color:#bbf7d0; }
  .badge-err { background:#7f1d1d;color:#fecaca; }
</style>

<script>
  import { apiFetch } from '../../../lib/api.ts';

  const form = document.getElementById('appointments-form') as HTMLFormElement;
  const result = document.getElementById('list-result') as HTMLPreElement;
  const badge = document.getElementById('list-badge') as HTMLParagraphElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(form);
    const access_token = fd.get('access_token') as string;
    const status = fd.get('status') as string;
    const date = fd.get('date') as string;

    result.className = '';
    result.textContent = 'Chargement…';
    badge.style.display = 'none';

    const params = new URLSearchParams();
    if (status) params.set('status', status);
    if (date) params.set('date', date);
    const qs = params.toString() ? `?${params.toString()}` : '';

    try {
      const { status: httpStatus, data } = await apiFetch(`/v1/cabinet/appointments${qs}`, {
        method: 'GET',
        headers: { 'Authorization': `Bearer ${access_token}` },
      });
      result.className = httpStatus < 300 ? 'success' : 'error';
      result.textContent = `HTTP ${httpStatus}\n${data !== null ? JSON.stringify(data, null, 2) : '(aucun contenu)'}`;
      badge.innerHTML = `<span class="badge ${httpStatus < 300 ? 'badge-ok' : 'badge-err'}">HTTP ${httpStatus}</span>`;
      badge.style.display = 'block';
    } catch (err) {
      result.className = 'error';
      result.textContent = `Erreur réseau : ${err instanceof Error ? err.message : String(err)}`;
    }
  });
</script>
