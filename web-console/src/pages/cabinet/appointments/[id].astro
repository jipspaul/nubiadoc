---
import Default from '../../../layouts/Default.astro';
---
<Default title="Détail RDV cabinet — Nubia Console">
  <h1 style="margin-bottom:0.5rem;">RDV — GET · POST confirm · PATCH</h1>
  <p style="color:var(--muted);margin-bottom:1.5rem;">
    <code>GET /v1/cabinet/appointments/:id</code> ·
    <code>POST /v1/cabinet/appointments/:id/confirm</code> ·
    <code>PATCH /v1/cabinet/appointments/:id</code>
  </p>

  <section aria-labelledby="get-heading">
    <h2 id="get-heading" style="margin-bottom:1rem;">Détail d'un RDV</h2>
    <form id="get-form" style="display:flex;flex-direction:column;gap:0.75rem;max-width:480px;">
      <label>
        Access token (Bearer)
        <input type="text" name="access_token" required
          style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
      </label>
      <label>
        Appointment ID
        <input type="text" name="appointment_id" required placeholder="uuid"
          style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
      </label>
      <button type="submit"
        style="padding:0.5rem 1rem;background:var(--accent);color:#fff;border:none;border-radius:4px;cursor:pointer;align-self:flex-start;">
        GET
      </button>
    </form>
    <p id="get-badge" style="margin-top:1rem;display:none;"></p>
    <pre id="get-result" style="margin-top:0.5rem;padding:1rem;background:var(--surface);border:1px solid var(--border);border-radius:4px;white-space:pre-wrap;font-size:0.875rem;min-height:3rem;"></pre>
  </section>

  <section aria-labelledby="confirm-heading" style="margin-top:2.5rem;">
    <h2 id="confirm-heading" style="margin-bottom:1rem;">Confirmer un RDV</h2>
    <form id="confirm-form" style="display:flex;flex-direction:column;gap:0.75rem;max-width:480px;">
      <label>
        Access token (Bearer)
        <input type="text" name="access_token" required
          style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
      </label>
      <label>
        Appointment ID
        <input type="text" name="appointment_id" required placeholder="uuid"
          style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
      </label>
      <button type="submit"
        style="padding:0.5rem 1rem;background:var(--accent);color:#fff;border:none;border-radius:4px;cursor:pointer;align-self:flex-start;">
        POST confirm
      </button>
    </form>
    <p id="confirm-badge" style="margin-top:1rem;display:none;"></p>
    <pre id="confirm-result" style="margin-top:0.5rem;padding:1rem;background:var(--surface);border:1px solid var(--border);border-radius:4px;white-space:pre-wrap;font-size:0.875rem;min-height:3rem;"></pre>
  </section>

  <section aria-labelledby="patch-heading" style="margin-top:2.5rem;">
    <h2 id="patch-heading" style="margin-bottom:1rem;">Modifier un RDV</h2>
    <form id="patch-form" style="display:flex;flex-direction:column;gap:0.75rem;max-width:480px;">
      <label>
        Access token (Bearer)
        <input type="text" name="access_token" required
          style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
      </label>
      <label>
        Appointment ID
        <input type="text" name="appointment_id" required placeholder="uuid"
          style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
      </label>
      <label>
        Nouveau starts_at (ISO 8601, optionnel)
        <input type="datetime-local" name="starts_at"
          style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
      </label>
      <label>
        Motif (optionnel)
        <input type="text" name="motif" placeholder="consultation"
          style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
      </label>
      <button type="submit"
        style="padding:0.5rem 1rem;background:var(--accent);color:#fff;border:none;border-radius:4px;cursor:pointer;align-self:flex-start;">
        PATCH
      </button>
    </form>
    <p id="patch-badge" style="margin-top:1rem;display:none;"></p>
    <pre id="patch-result" style="margin-top:0.5rem;padding:1rem;background:var(--surface);border:1px solid var(--border);border-radius:4px;white-space:pre-wrap;font-size:0.875rem;min-height:3rem;"></pre>
  </section>
</Default>

<style>
  pre.success { border-left: 4px solid green; }
  pre.error   { border-left: 4px solid red; }
  .badge { display:inline-block;padding:0.25rem 0.6rem;border-radius:4px;font-size:0.85rem;font-weight:600; }
  .badge-ok  { background:#166534;color:#bbf7d0; }
  .badge-err { background:#7f1d1d;color:#fecaca; }
</style>

<script>
  import { apiFetch } from '../../../lib/api.ts';

  function showResult(
    resultEl: HTMLPreElement,
    badgeEl: HTMLParagraphElement,
    httpStatus: number,
    data: unknown,
  ): void {
    resultEl.className = httpStatus < 300 ? 'success' : 'error';
    resultEl.textContent = `HTTP ${httpStatus}\n${data !== null ? JSON.stringify(data, null, 2) : '(aucun contenu)'}`;
    badgeEl.innerHTML = `<span class="badge ${httpStatus < 300 ? 'badge-ok' : 'badge-err'}">HTTP ${httpStatus}</span>`;
    badgeEl.style.display = 'block';
  }

  const getForm = document.getElementById('get-form') as HTMLFormElement;
  const getResult = document.getElementById('get-result') as HTMLPreElement;
  const getBadge = document.getElementById('get-badge') as HTMLParagraphElement;

  getForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(getForm);
    const access_token = fd.get('access_token') as string;
    const appointment_id = fd.get('appointment_id') as string;

    getResult.className = '';
    getResult.textContent = 'Chargement…';
    getBadge.style.display = 'none';

    try {
      const { status: httpStatus, data } = await apiFetch(
        `/v1/cabinet/appointments/${encodeURIComponent(appointment_id)}`,
        { method: 'GET', headers: { 'Authorization': `Bearer ${access_token}` } },
      );
      showResult(getResult, getBadge, httpStatus, data);
    } catch (err) {
      getResult.className = 'error';
      getResult.textContent = `Erreur réseau : ${err instanceof Error ? err.message : String(err)}`;
    }
  });

  const confirmForm = document.getElementById('confirm-form') as HTMLFormElement;
  const confirmResult = document.getElementById('confirm-result') as HTMLPreElement;
  const confirmBadge = document.getElementById('confirm-badge') as HTMLParagraphElement;

  confirmForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(confirmForm);
    const access_token = fd.get('access_token') as string;
    const appointment_id = fd.get('appointment_id') as string;

    confirmResult.className = '';
    confirmResult.textContent = 'Chargement…';
    confirmBadge.style.display = 'none';

    try {
      const { status: httpStatus, data } = await apiFetch(
        `/v1/cabinet/appointments/${encodeURIComponent(appointment_id)}/confirm`,
        {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Authorization': `Bearer ${access_token}`,
          },
        },
      );
      showResult(confirmResult, confirmBadge, httpStatus, data);
    } catch (err) {
      confirmResult.className = 'error';
      confirmResult.textContent = `Erreur réseau : ${err instanceof Error ? err.message : String(err)}`;
    }
  });

  const patchForm = document.getElementById('patch-form') as HTMLFormElement;
  const patchResult = document.getElementById('patch-result') as HTMLPreElement;
  const patchBadge = document.getElementById('patch-badge') as HTMLParagraphElement;

  patchForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(patchForm);
    const access_token = fd.get('access_token') as string;
    const appointment_id = fd.get('appointment_id') as string;

    const body: Record<string, unknown> = {};
    const starts_at = fd.get('starts_at') as string;
    const motif = fd.get('motif') as string;
    if (starts_at) body.starts_at = new Date(starts_at).toISOString();
    if (motif) body.motif = motif;

    patchResult.className = '';
    patchResult.textContent = 'Chargement…';
    patchBadge.style.display = 'none';

    try {
      const { status: httpStatus, data } = await apiFetch(
        `/v1/cabinet/appointments/${encodeURIComponent(appointment_id)}`,
        {
          method: 'PATCH',
          headers: {
            'Content-Type': 'application/json',
            'Authorization': `Bearer ${access_token}`,
          },
          body: JSON.stringify(body),
        },
      );
      showResult(patchResult, patchBadge, httpStatus, data);
    } catch (err) {
      patchResult.className = 'error';
      patchResult.textContent = `Erreur réseau : ${err instanceof Error ? err.message : String(err)}`;
    }
  });
</script>
