---
import Default from '../../layouts/Default.astro';
---
<Default title="Mise en ligne annuaire — Nubia Console">
  <h1 style="margin-bottom:0.5rem;">Annuaire — PUT /v1/cabinet/provider/listing</h1>
  <p style="color:var(--muted);margin-bottom:1.5rem;">Rôle requis : <code>admin</code> · Refusée si RPPS non vérifié (<code>409 provider_not_verified</code>)</p>

  <section aria-labelledby="listing-heading">
    <h2 id="listing-heading" style="margin-bottom:1rem;">Activer / Désactiver la mise en ligne</h2>
    <form id="listing-form" style="display:flex;flex-direction:column;gap:0.75rem;max-width:480px;">
      <label>
        Access token (Bearer, rôle admin)
        <input type="text" name="access_token" required
          style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
      </label>
      <fieldset style="border:1px solid var(--border);border-radius:4px;padding:0.75rem;">
        <legend style="padding:0 0.5rem;font-size:0.9rem;">Statut souhaité</legend>
        <label style="display:flex;align-items:center;gap:0.5rem;cursor:pointer;">
          <input type="radio" name="listed" value="true" required /> Activer (listed: true)
        </label>
        <label style="display:flex;align-items:center;gap:0.5rem;cursor:pointer;margin-top:0.5rem;">
          <input type="radio" name="listed" value="false" required /> Désactiver (listed: false)
        </label>
      </fieldset>
      <button type="submit"
        style="padding:0.5rem 1rem;background:var(--accent);color:#fff;border:none;border-radius:4px;cursor:pointer;align-self:flex-start;">
        PUT
      </button>
    </form>
    <p id="listing-badge" style="margin-top:1rem;display:none;"></p>
    <pre id="listing-result" style="margin-top:0.5rem;padding:1rem;background:var(--surface);border:1px solid var(--border);border-radius:4px;white-space:pre-wrap;font-size:0.875rem;min-height:3rem;"></pre>
  </section>

  <section aria-labelledby="note-heading" style="margin-top:2rem;">
    <h2 id="note-heading" style="margin-bottom:0.5rem;font-size:1rem;">Note</h2>
    <p style="color:var(--muted);font-size:0.875rem;">
      Si le praticien n'est pas vérifié (RPPS non validé), l'API répond <code>409 provider_not_verified</code>.
      Pour lancer la vérification, rendez-vous sur <a href="/pro/verification">/pro/verification</a>.
    </p>
  </section>
</Default>

<style>
  pre.success { border-left: 4px solid green; }
  pre.error   { border-left: 4px solid red; }
  .badge { display:inline-block;padding:0.25rem 0.6rem;border-radius:4px;font-size:0.85rem;font-weight:600; }
  .badge-ok  { background:#166534;color:#bbf7d0; }
  .badge-err { background:#7f1d1d;color:#fecaca; }
</style>

<script>
  import { apiFetch } from '../../lib/api.ts';

  function showResult(
    resultEl: HTMLPreElement,
    badgeEl: HTMLParagraphElement,
    httpStatus: number,
    data: unknown,
  ): void {
    resultEl.className = httpStatus < 300 ? 'success' : 'error';
    resultEl.textContent = `HTTP ${httpStatus}\n${data !== null ? JSON.stringify(data, null, 2) : '(aucun contenu)'}`;
    badgeEl.innerHTML = `<span class="badge ${httpStatus < 300 ? 'badge-ok' : 'badge-err'}">HTTP ${httpStatus}</span>`;
    badgeEl.style.display = 'block';
  }

  const listingForm = document.getElementById('listing-form') as HTMLFormElement;
  const listingResult = document.getElementById('listing-result') as HTMLPreElement;
  const listingBadge = document.getElementById('listing-badge') as HTMLParagraphElement;

  listingForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(listingForm);
    const access_token = fd.get('access_token') as string;
    const listed = fd.get('listed') === 'true';

    listingResult.className = '';
    listingResult.textContent = 'Chargement…';
    listingBadge.style.display = 'none';

    try {
      const { status, data } = await apiFetch('/v1/cabinet/provider/listing', {
        method: 'PUT',
        headers: {
          'Content-Type': 'application/json',
          'Authorization': `Bearer ${access_token}`,
        },
        body: JSON.stringify({ listed }),
      });
      showResult(listingResult, listingBadge, status, data);
    } catch (err) {
      listingResult.className = 'error';
      listingResult.textContent = `Erreur réseau : ${err instanceof Error ? err.message : String(err)}`;
    }
  });
</script>
