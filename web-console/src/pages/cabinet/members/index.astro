---
import Default from '../../../layouts/Default.astro';
---
<Default title="Cabinet Members — Nubia Console">
  <h1 style="margin-bottom:0.5rem;">Membres — GET /v1/cabinet/members &amp; POST</h1>
  <p style="color:var(--muted);margin-bottom:1.5rem;">Rôle requis : <code>admin</code></p>

  <section aria-labelledby="list-heading">
    <h2 id="list-heading" style="margin-bottom:1rem;">Lister les membres</h2>
    <form id="members-list-form" style="display:flex;flex-direction:column;gap:0.75rem;max-width:480px;">
      <label>
        Access token (Bearer, rôle admin)
        <input type="text" name="access_token" required
          style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
      </label>
      <button type="submit"
        style="padding:0.5rem 1rem;background:var(--accent);color:#fff;border:none;border-radius:4px;cursor:pointer;align-self:flex-start;">
        GET
      </button>
    </form>
    <p id="list-badge" style="margin-top:1rem;display:none;"></p>
    <pre id="list-result" style="margin-top:0.5rem;padding:1rem;background:var(--surface);border:1px solid var(--border);border-radius:4px;white-space:pre-wrap;font-size:0.875rem;min-height:3rem;"></pre>
  </section>

  <section aria-labelledby="add-heading" style="margin-top:2.5rem;">
    <h2 id="add-heading" style="margin-bottom:1rem;">Ajouter un membre</h2>
    <form id="members-add-form" style="display:flex;flex-direction:column;gap:0.75rem;max-width:480px;">
      <label>
        Access token (Bearer, rôle admin)
        <input type="text" name="access_token" required
          style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
      </label>
      <label>
        Email
        <input type="email" name="email" required placeholder="praticien@cabinet.fr"
          style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
      </label>
      <label>
        Prénom
        <input type="text" name="first_name" required placeholder="Jean"
          style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
      </label>
      <label>
        Nom
        <input type="text" name="last_name" required placeholder="Martin"
          style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
      </label>
      <label>
        Rôle
        <select name="role" required
          style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;">
          <option value="practitioner">practitioner</option>
          <option value="secretary">secretary</option>
          <option value="admin">admin</option>
        </select>
      </label>
      <label>
        RPPS (optionnel, praticien)
        <input type="text" name="rpps" placeholder="12345678901"
          style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
      </label>
      <button type="submit"
        style="padding:0.5rem 1rem;background:var(--accent);color:#fff;border:none;border-radius:4px;cursor:pointer;align-self:flex-start;">
        POST
      </button>
    </form>
    <p id="add-badge" style="margin-top:1rem;display:none;"></p>
    <pre id="add-result" style="margin-top:0.5rem;padding:1rem;background:var(--surface);border:1px solid var(--border);border-radius:4px;white-space:pre-wrap;font-size:0.875rem;min-height:3rem;"></pre>
  </section>
</Default>

<style>
  pre.success { border-left: 4px solid green; }
  pre.error   { border-left: 4px solid red; }
  .badge { display:inline-block;padding:0.25rem 0.6rem;border-radius:4px;font-size:0.85rem;font-weight:600; }
  .badge-ok  { background:#166534;color:#bbf7d0; }
  .badge-err { background:#7f1d1d;color:#fecaca; }
</style>

<script>
  import { apiFetch } from '../../../lib/api.ts';

  function showResult(
    resultEl: HTMLPreElement,
    badgeEl: HTMLParagraphElement,
    httpStatus: number,
    data: unknown,
  ): void {
    resultEl.className = httpStatus < 300 ? 'success' : 'error';
    resultEl.textContent = `HTTP ${httpStatus}\n${data !== null ? JSON.stringify(data, null, 2) : '(aucun contenu)'}`;
    badgeEl.innerHTML = `<span class="badge ${httpStatus < 300 ? 'badge-ok' : 'badge-err'}">HTTP ${httpStatus}</span>`;
    badgeEl.style.display = 'block';
  }

  const listForm = document.getElementById('members-list-form') as HTMLFormElement;
  const listResult = document.getElementById('list-result') as HTMLPreElement;
  const listBadge = document.getElementById('list-badge') as HTMLParagraphElement;

  listForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(listForm);
    const access_token = fd.get('access_token') as string;

    listResult.className = '';
    listResult.textContent = 'Chargement…';
    listBadge.style.display = 'none';

    try {
      const { status, data } = await apiFetch('/v1/cabinet/members', {
        method: 'GET',
        headers: { 'Authorization': `Bearer ${access_token}` },
      });
      showResult(listResult, listBadge, status, data);
    } catch (err) {
      listResult.className = 'error';
      listResult.textContent = `Erreur réseau : ${err instanceof Error ? err.message : String(err)}`;
    }
  });

  const addForm = document.getElementById('members-add-form') as HTMLFormElement;
  const addResult = document.getElementById('add-result') as HTMLPreElement;
  const addBadge = document.getElementById('add-badge') as HTMLParagraphElement;

  addForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(addForm);
    const access_token = fd.get('access_token') as string;

    const body: Record<string, unknown> = {
      email: fd.get('email') as string,
      first_name: fd.get('first_name') as string,
      last_name: fd.get('last_name') as string,
      role: fd.get('role') as string,
    };
    const rpps = fd.get('rpps') as string;
    if (rpps) body.rpps = rpps;

    addResult.className = '';
    addResult.textContent = 'Chargement…';
    addBadge.style.display = 'none';

    try {
      const { status, data } = await apiFetch('/v1/cabinet/members', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Authorization': `Bearer ${access_token}`,
        },
        body: JSON.stringify(body),
      });
      showResult(addResult, addBadge, status, data);
    } catch (err) {
      addResult.className = 'error';
      addResult.textContent = `Erreur réseau : ${err instanceof Error ? err.message : String(err)}`;
    }
  });
</script>
