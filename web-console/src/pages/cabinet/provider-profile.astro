---
import Default from '../../layouts/Default.astro';

const sectors = [
  { value: '1', label: 'Secteur 1 — Conventionné sans dépassement' },
  { value: '2', label: 'Secteur 2 — Conventionné avec dépassement' },
  { value: '3', label: 'Secteur 3 — Non conventionné' },
];

const languages = [
  { value: 'fr', label: 'Français' },
  { value: 'en', label: 'Anglais' },
  { value: 'es', label: 'Espagnol' },
  { value: 'ar', label: 'Arabe' },
  { value: 'pt', label: 'Portugais' },
  { value: 'de', label: 'Allemand' },
  { value: 'it', label: 'Italien' },
  { value: 'zh', label: 'Mandarin' },
];

const acts = [
  { value: 'consultation', label: 'Consultation' },
  { value: 'detartrage', label: 'Détartrage' },
  { value: 'obturation', label: 'Obturation' },
  { value: 'extraction', label: 'Extraction' },
  { value: 'endodontie', label: 'Endodontie' },
  { value: 'prothese', label: 'Prothèse' },
  { value: 'implant', label: 'Implantologie' },
  { value: 'orthodontie', label: 'Orthodontie' },
  { value: 'chirurgie', label: 'Chirurgie orale' },
  { value: 'teleconsultation', label: 'Téléconsultation' },
];
---
<Default title="Profil praticien — Nubia Console">
  <h1 style="margin-bottom:0.5rem;">Profil public praticien — PATCH /v1/cabinet/provider</h1>
  <p style="color:var(--muted);margin-bottom:1.5rem;">Rôle requis : <code>pro</code> (practitioner/admin) · Secrétaire → <code>403 forbidden</code> (R.4127-72)</p>

  <section aria-labelledby="profile-heading">
    <h2 id="profile-heading" style="margin-bottom:1rem;">Éditer le profil public</h2>
    <form id="profile-form" style="display:flex;flex-direction:column;gap:1rem;max-width:560px;">
      <label>
        Access token (Bearer, rôle pro)
        <input type="text" name="access_token" required
          style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
      </label>

      <label>
        Bio
        <textarea name="bio" rows="4" placeholder="Présentation du praticien…"
          style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;resize:vertical;"></textarea>
      </label>

      <fieldset style="border:1px solid var(--border);border-radius:4px;padding:0.75rem;">
        <legend style="padding:0 0.5rem;font-size:0.9rem;">Actes pratiqués</legend>
        <div style="display:flex;flex-wrap:wrap;gap:0.5rem;margin-top:0.25rem;">
          {acts.map(a => (
            <label style="display:flex;align-items:center;gap:0.35rem;cursor:pointer;font-size:0.875rem;">
              <input type="checkbox" name="acts" value={a.value} /> {a.label}
            </label>
          ))}
        </div>
      </fieldset>

      <fieldset style="border:1px solid var(--border);border-radius:4px;padding:0.75rem;">
        <legend style="padding:0 0.5rem;font-size:0.9rem;">Tarifs</legend>
        <div style="display:flex;flex-direction:column;gap:0.5rem;margin-top:0.25rem;">
          <label>
            Secteur conventionnel
            <select name="sector"
              style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;">
              <option value="">— choisir —</option>
              {sectors.map(s => <option value={s.value}>{s.label}</option>)}
            </select>
          </label>
          <label>
            Consultation secteur 1 (centimes, ex : 2500 = 25,00 €)
            <input type="number" name="sector_1_amount_cents" min="0" placeholder="2500"
              style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
          </label>
          <label>
            Consultation secteur 2 (centimes)
            <input type="number" name="sector_2_amount_cents" min="0" placeholder="4000"
              style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
          </label>
          <label>
            Consultation secteur 3 (centimes)
            <input type="number" name="sector_3_amount_cents" min="0" placeholder="6000"
              style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
          </label>
        </div>
      </fieldset>

      <fieldset style="border:1px solid var(--border);border-radius:4px;padding:0.75rem;">
        <legend style="padding:0 0.5rem;font-size:0.9rem;">Langues parlées</legend>
        <div style="display:flex;flex-wrap:wrap;gap:0.5rem;margin-top:0.25rem;">
          {languages.map(l => (
            <label style="display:flex;align-items:center;gap:0.35rem;cursor:pointer;font-size:0.875rem;">
              <input type="checkbox" name="languages" value={l.value} /> {l.label}
            </label>
          ))}
        </div>
      </fieldset>

      <label style="display:flex;align-items:center;gap:0.5rem;cursor:pointer;">
        <input type="checkbox" name="pmr" id="pmr-toggle" />
        Accès PMR (personnes à mobilité réduite)
      </label>

      <label>
        Photo (multipart, image/*)
        <input type="file" name="photo" accept="image/*"
          style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
      </label>

      <button type="submit"
        style="padding:0.5rem 1rem;background:var(--accent);color:#fff;border:none;border-radius:4px;cursor:pointer;align-self:flex-start;">
        PATCH
      </button>
    </form>

    <p id="profile-badge" style="margin-top:1rem;display:none;"></p>
    <pre id="profile-result" style="margin-top:0.5rem;padding:1rem;background:var(--surface);border:1px solid var(--border);border-radius:4px;white-space:pre-wrap;font-size:0.875rem;min-height:3rem;"></pre>
  </section>

  <section aria-labelledby="note-403-heading" style="margin-top:2rem;">
    <h2 id="note-403-heading" style="margin-bottom:0.5rem;font-size:1rem;">Note — Cloisonnement R.4127-72</h2>
    <p style="color:var(--muted);font-size:0.875rem;">
      Un token <strong>secrétaire</strong> reçoit <code>403 forbidden</code> sur cet endpoint.
      Seuls les rôles <code>practitioner</code> et <code>admin</code> peuvent modifier le profil public.
    </p>
  </section>
</Default>

<style>
  pre.success { border-left: 4px solid green; }
  pre.error   { border-left: 4px solid red; }
  .badge { display:inline-block;padding:0.25rem 0.6rem;border-radius:4px;font-size:0.85rem;font-weight:600; }
  .badge-ok  { background:#166534;color:#bbf7d0; }
  .badge-err { background:#7f1d1d;color:#fecaca; }
</style>

<script>
  import { apiFetch } from '../../lib/api.ts';

  function showResult(
    resultEl: HTMLPreElement,
    badgeEl: HTMLParagraphElement,
    httpStatus: number,
    data: unknown,
  ): void {
    resultEl.className = httpStatus < 300 ? 'success' : 'error';
    resultEl.textContent = `HTTP ${httpStatus}\n${data !== null ? JSON.stringify(data, null, 2) : '(aucun contenu)'}`;
    badgeEl.innerHTML = `<span class="badge ${httpStatus < 300 ? 'badge-ok' : 'badge-err'}">HTTP ${httpStatus}</span>`;
    badgeEl.style.display = 'block';
  }

  const form = document.getElementById('profile-form') as HTMLFormElement;
  const resultEl = document.getElementById('profile-result') as HTMLPreElement;
  const badgeEl = document.getElementById('profile-badge') as HTMLParagraphElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(form);
    const access_token = fd.get('access_token') as string;

    resultEl.className = '';
    resultEl.textContent = 'Chargement…';
    badgeEl.style.display = 'none';

    const photoFile = fd.get('photo') as File | null;
    const hasPhoto = photoFile && photoFile.size > 0;

    try {
      if (hasPhoto) {
        // multipart: send FormData directly (photo + text fields)
        const multipart = new FormData();
        const bio = fd.get('bio') as string;
        const sector = fd.get('sector') as string;
        const s1 = fd.get('sector_1_amount_cents') as string;
        const s2 = fd.get('sector_2_amount_cents') as string;
        const s3 = fd.get('sector_3_amount_cents') as string;
        const pmr = (document.getElementById('pmr-toggle') as HTMLInputElement).checked;
        const acts = fd.getAll('acts') as string[];
        const languages = fd.getAll('languages') as string[];

        if (bio) multipart.append('bio', bio);
        if (sector) multipart.append('sector', sector);
        if (s1) multipart.append('sector_1_amount_cents', s1);
        if (s2) multipart.append('sector_2_amount_cents', s2);
        if (s3) multipart.append('sector_3_amount_cents', s3);
        multipart.append('pmr', String(pmr));
        acts.forEach(a => multipart.append('acts[]', a));
        languages.forEach(l => multipart.append('languages[]', l));
        multipart.append('photo', photoFile as File);

        const { status, data } = await apiFetch('/v1/cabinet/provider', {
          method: 'PATCH',
          headers: { Authorization: `Bearer ${access_token}` },
          body: multipart,
        });
        showResult(resultEl, badgeEl, status, data);
      } else {
        // JSON: no photo
        const body: Record<string, unknown> = {};
        const bio = fd.get('bio') as string;
        const sector = fd.get('sector') as string;
        const s1 = fd.get('sector_1_amount_cents') as string;
        const s2 = fd.get('sector_2_amount_cents') as string;
        const s3 = fd.get('sector_3_amount_cents') as string;
        const pmr = (document.getElementById('pmr-toggle') as HTMLInputElement).checked;
        const acts = fd.getAll('acts') as string[];
        const languages = fd.getAll('languages') as string[];

        if (bio) body.bio = bio;
        if (sector) body.sector = sector;
        if (s1) body.sector_1_amount_cents = parseInt(s1, 10);
        if (s2) body.sector_2_amount_cents = parseInt(s2, 10);
        if (s3) body.sector_3_amount_cents = parseInt(s3, 10);
        body.pmr = pmr;
        if (acts.length > 0) body.acts = acts;
        if (languages.length > 0) body.languages = languages;

        const { status, data } = await apiFetch('/v1/cabinet/provider', {
          method: 'PATCH',
          headers: {
            'Content-Type': 'application/json',
            Authorization: `Bearer ${access_token}`,
          },
          body: JSON.stringify(body),
        });
        showResult(resultEl, badgeEl, status, data);
      }
    } catch (err) {
      resultEl.className = 'error';
      resultEl.textContent = `Erreur réseau : ${err instanceof Error ? err.message : String(err)}`;
    }
  });
</script>
