---
import Default from '../../../layouts/Default.astro';
---
<Default title="Consultation — Nubia Console">
  <h1 style="margin-bottom:0.5rem;">Contexte clinique — GET /v1/cabinet/consultations/:id</h1>
  <p style="color:var(--muted);margin-bottom:1.5rem;">Rôle requis : <code>practitioner</code> — 403 pour secretary</p>

  <section aria-labelledby="get-heading">
    <h2 id="get-heading" style="margin-bottom:1rem;">Contexte clinique de la séance</h2>
    <form id="consultation-form" style="display:flex;flex-direction:column;gap:0.75rem;max-width:480px;">
      <label>
        Access token (Bearer)
        <input type="text" id="access_token" name="access_token" required
          style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
      </label>
      <label>
        Consultation ID
        <input type="text" name="consultation_id" required placeholder="uuid"
          style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
      </label>
      <button type="submit"
        style="padding:0.5rem 1rem;background:var(--accent);color:#fff;border:none;border-radius:4px;cursor:pointer;align-self:flex-start;">
        GET
      </button>
    </form>
    <p id="get-badge" style="margin-top:1rem;display:none;"></p>
    <pre id="get-result" style="margin-top:0.5rem;padding:1rem;background:var(--surface);border:1px solid var(--border);border-radius:4px;white-space:pre-wrap;font-size:0.875rem;min-height:3rem;"></pre>
  </section>
</Default>

<style>
  pre.success { border-left: 4px solid green; }
  pre.error   { border-left: 4px solid red; }
  .badge { display:inline-block;padding:0.25rem 0.6rem;border-radius:4px;font-size:0.85rem;font-weight:600; }
  .badge-ok  { background:#166534;color:#bbf7d0; }
  .badge-err { background:#7f1d1d;color:#fecaca; }
</style>

<script>
  import { apiFetch } from '../../../lib/api.ts';

  function showResult(
    resultEl: HTMLPreElement,
    badgeEl: HTMLParagraphElement,
    httpStatus: number,
    data: unknown,
  ): void {
    resultEl.className = httpStatus < 300 ? 'success' : 'error';
    resultEl.textContent = `HTTP ${httpStatus}\n${data !== null ? JSON.stringify(data, null, 2) : '(aucun contenu)'}`;
    badgeEl.innerHTML = `<span class="badge ${httpStatus < 300 ? 'badge-ok' : 'badge-err'}">HTTP ${httpStatus}</span>`;
    badgeEl.style.display = 'block';
  }

  const form = document.getElementById('consultation-form') as HTMLFormElement;
  const result = document.getElementById('get-result') as HTMLPreElement;
  const badge = document.getElementById('get-badge') as HTMLParagraphElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(form);
    const access_token = fd.get('access_token') as string;
    const consultation_id = fd.get('consultation_id') as string;

    result.className = '';
    result.textContent = 'Chargement…';
    badge.style.display = 'none';

    try {
      const { status: httpStatus, data } = await apiFetch(
        `/v1/cabinet/consultations/${encodeURIComponent(consultation_id)}`,
        { method: 'GET', headers: { 'Authorization': `Bearer ${access_token}` } },
      );
      showResult(result, badge, httpStatus, data);
    } catch (err) {
      result.className = 'error';
      result.textContent = `Erreur réseau : ${err instanceof Error ? err.message : String(err)}`;
    }
  });
</script>
