---
import Default from '../../../layouts/Default.astro';
---
<Default title="Ouvrir un créneau — Nubia Console">
  <h1 style="margin-bottom:0.5rem;">Ouvrir un créneau — POST /v1/cabinet/slots</h1>
  <p style="color:var(--muted);margin-bottom:1.5rem;">Rôle requis : <code>pro</code></p>

  <section aria-labelledby="create-heading">
    <h2 id="create-heading" style="margin-bottom:1rem;">Créer un créneau</h2>
    <form id="slots-create-form" style="display:flex;flex-direction:column;gap:0.75rem;max-width:480px;">
      <label>
        Access token (Bearer)
        <input type="text" name="access_token" required
          style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
      </label>
      <label>
        Practitioner ID
        <input type="text" name="practitioner_id" required placeholder="uuid du praticien"
          style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
      </label>
      <label>
        Début
        <input type="datetime-local" name="starts_at" required
          style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
      </label>
      <label>
        Fin
        <input type="datetime-local" name="ends_at" required
          style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
      </label>
      <label>
        Motif (optionnel)
        <input type="text" name="motif" placeholder="consultation, urgence…"
          style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
      </label>
      <label>
        Statut
        <select name="status"
          style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;">
          <option value="open">open</option>
          <option value="blocked">blocked</option>
        </select>
      </label>
      <button type="submit"
        style="padding:0.5rem 1rem;background:var(--accent);color:#fff;border:none;border-radius:4px;cursor:pointer;align-self:flex-start;">
        POST
      </button>
    </form>
    <p id="create-badge" style="margin-top:1rem;display:none;"></p>
    <pre id="create-result" style="margin-top:0.5rem;padding:1rem;background:var(--surface);border:1px solid var(--border);border-radius:4px;white-space:pre-wrap;font-size:0.875rem;min-height:3rem;"></pre>
  </section>
</Default>

<style>
  pre.success { border-left: 4px solid green; }
  pre.error   { border-left: 4px solid red; }
  .badge { display:inline-block;padding:0.25rem 0.6rem;border-radius:4px;font-size:0.85rem;font-weight:600; }
  .badge-ok  { background:#166534;color:#bbf7d0; }
  .badge-err { background:#7f1d1d;color:#fecaca; }
</style>

<script>
  import { apiFetch } from '../../../lib/api.ts';

  const form = document.getElementById('slots-create-form') as HTMLFormElement;
  const result = document.getElementById('create-result') as HTMLPreElement;
  const badge = document.getElementById('create-badge') as HTMLParagraphElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(form);
    const access_token = fd.get('access_token') as string;

    const body: Record<string, unknown> = {
      practitioner_id: fd.get('practitioner_id') as string,
      starts_at: new Date(fd.get('starts_at') as string).toISOString(),
      ends_at: new Date(fd.get('ends_at') as string).toISOString(),
      status: fd.get('status') as string,
    };
    const motif = fd.get('motif') as string;
    if (motif) body.motif = motif;

    result.className = '';
    result.textContent = 'Chargement…';
    badge.style.display = 'none';

    try {
      const { status: httpStatus, data } = await apiFetch('/v1/cabinet/slots', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Authorization': `Bearer ${access_token}`,
        },
        body: JSON.stringify(body),
      });
      result.className = httpStatus < 300 ? 'success' : 'error';
      result.textContent = `HTTP ${httpStatus}\n${data !== null ? JSON.stringify(data, null, 2) : '(aucun contenu)'}`;
      badge.innerHTML = `<span class="badge ${httpStatus < 300 ? 'badge-ok' : 'badge-err'}">HTTP ${httpStatus}</span>`;
      badge.style.display = 'block';
    } catch (err) {
      result.className = 'error';
      result.textContent = `Erreur réseau : ${err instanceof Error ? err.message : String(err)}`;
    }
  });
</script>
