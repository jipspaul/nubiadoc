---
import AppShell from '../../../layouts/AppShell.astro';

const jwt = Astro.cookies.get('nubia_jwt')?.value;
const role = Astro.cookies.get('nubia_role')?.value;

if (!jwt) {
  return Astro.redirect(`/auth/login?next=${encodeURIComponent(Astro.url.pathname)}`);
}
if (role !== 'secretary' && role !== 'admin' && role !== 'practitioner') {
  return new Response('Accès interdit', { status: 403 });
}
---
<AppShell title="Facturation — Espace secrétaire" role="secretary">
  <header>
    <h1>Facturation</h1>
    <p>Suivi des devis du cabinet. Aucune donnée clinique (R.4127-72 — Annexe B).</p>
  </header>

  <section aria-labelledby="quotes-heading">
    <h2 id="quotes-heading">Devis du cabinet</h2>

    <fieldset id="filter-bar">
      <legend class="sr-only">Filtrer par statut</legend>
      <button type="button" class="filter-btn active" data-status="">Tous</button>
      <button type="button" class="filter-btn" data-status="pending">En attente</button>
      <button type="button" class="filter-btn" data-status="signed">Signé</button>
      <button type="button" class="filter-btn" data-status="paid">Payé</button>
    </fieldset>

    <div id="quotes-status" role="status" aria-live="polite"></div>
    <div id="quotes-container">
      <table id="quotes-table" hidden aria-label="Devis du cabinet">
        <thead>
          <tr>
            <th scope="col">Réf.</th>
            <th scope="col">Patient</th>
            <th scope="col">Montant (€)</th>
            <th scope="col">Statut</th>
            <th scope="col">Date</th>
          </tr>
        </thead>
        <tbody id="quotes-tbody"></tbody>
      </table>
      <p id="quotes-empty" hidden>Aucun devis trouvé.</p>
    </div>
  </section>
</AppShell>

<style>
  h1 { margin-bottom: 0.25rem; }
  h1 + p { color: var(--color-muted); font-size: var(--font-size-sm); margin-bottom: var(--space-6); }
  h2 { margin-bottom: var(--space-4); }

  #filter-bar {
    border: none;
    padding: 0;
    margin: 0 0 var(--space-4);
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  .filter-btn {
    padding: var(--space-1) var(--space-3);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-surface);
    font-size: var(--font-size-sm);
    cursor: pointer;
    color: inherit;
  }

  .filter-btn.active {
    background: var(--color-accent);
    color: var(--color-accent-fg);
    border-color: var(--color-accent);
  }

  table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--font-size-sm);
  }
  th, td {
    padding: var(--space-2) var(--space-3);
    text-align: left;
    border-bottom: 1px solid var(--color-border);
  }
  th {
    font-weight: 600;
    background: var(--color-surface);
  }
  tr:hover td { background: var(--color-surface); }

  #quotes-status {
    margin-bottom: var(--space-3);
    font-size: var(--font-size-sm);
    color: var(--color-muted);
  }
  #quotes-status.error { color: var(--color-danger, #dc2626); }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    overflow: hidden;
    clip: rect(0,0,0,0);
    white-space: nowrap;
    border: 0;
  }
</style>

<script>
  import { proQuotes } from '../../../lib/endpoints.ts';
  import type { CabinetQuote } from '../../../lib/endpoints.ts';

  const statusEl = document.getElementById('quotes-status') as HTMLElement;
  const tableEl = document.getElementById('quotes-table') as HTMLTableElement;
  const tbodyEl = document.getElementById('quotes-tbody') as HTMLTableSectionElement;
  const emptyEl = document.getElementById('quotes-empty') as HTMLParagraphElement;
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');

  let currentStatus = '';

  async function loadQuotes(status: string): Promise<void> {
    statusEl.textContent = 'Chargement…';
    statusEl.className = '';
    tableEl.hidden = true;
    emptyEl.hidden = true;
    tbodyEl.innerHTML = '';

    try {
      const { status: httpStatus, data } = await proQuotes.list(status ? { status } : undefined);

      if (httpStatus === 401) {
        window.location.href = '/auth/login?next=/secretary/facturation';
        return;
      }
      if (httpStatus === 403) {
        statusEl.textContent = 'Accès refusé (403). Ce compte n\'a pas les droits requis.';
        statusEl.className = 'error';
        return;
      }
      if (httpStatus !== 200) {
        statusEl.textContent = `Erreur serveur (HTTP ${httpStatus}).`;
        statusEl.className = 'error';
        return;
      }

      const quotes = data as CabinetQuote[];
      statusEl.textContent = '';

      if (!quotes || quotes.length === 0) {
        emptyEl.hidden = false;
        return;
      }

      for (const q of quotes) {
        const tr = document.createElement('tr');
        const amount = q.total_amount != null
          ? (q.total_amount / 100).toLocaleString('fr-FR', { minimumFractionDigits: 2 })
          : '—';
        const date = q.created_at
          ? new Date(q.created_at).toLocaleDateString('fr-FR')
          : '—';
        tr.innerHTML = `
          <td><code>${q.id}</code></td>
          <td>${q.patient_name ?? '—'}</td>
          <td>${amount}</td>
          <td>${q.status}</td>
          <td>${date}</td>
        `;
        tbodyEl.appendChild(tr);
      }

      tableEl.hidden = false;
    } catch (err) {
      statusEl.textContent = `Erreur réseau : ${err instanceof Error ? err.message : String(err)}`;
      statusEl.className = 'error';
    }
  }

  filterBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      filterBtns.forEach((b) => b.classList.remove('active'));
      btn.classList.add('active');
      currentStatus = btn.dataset.status ?? '';
      void loadQuotes(currentStatus);
    });
  });

  void loadQuotes(currentStatus);
</script>
