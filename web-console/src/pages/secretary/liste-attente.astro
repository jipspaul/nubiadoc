---
import AppShell from '../../layouts/AppShell.astro';

const jwt  = Astro.cookies.get('nubia_jwt')?.value;
const role = Astro.cookies.get('nubia_role')?.value;

if (!jwt) {
  return Astro.redirect(`/auth/login?next=${encodeURIComponent(Astro.url.pathname)}`);
}
if (role !== 'secretary' && role !== 'admin') {
  return new Response('Accès interdit', { status: 403 });
}
---
<AppShell title="Liste d'attente — Espace secrétaire" role="secretary">
  <header>
    <h1>Liste d'attente cabinet</h1>
    <p>Patients en attente de créneau. Proposez un rendez-vous via le bouton d'action.</p>
  </header>

  <!-- ── Liste d'attente — GET /v1/cabinet/waiting-list ──────────────────── -->
  <section aria-labelledby="h-waiting-list">
    <h2 id="h-waiting-list">
      Demandes en attente
      <span id="waiting-badge" class="count-badge" hidden></span>
    </h2>
    <div id="list-status" role="status" aria-live="polite"></div>
    <div id="list-content" hidden>
      <table id="waiting-table" aria-label="Liste d'attente cabinet">
        <thead>
          <tr>
            <th scope="col">Patient</th>
            <th scope="col">Motif</th>
            <th scope="col">Date demande</th>
            <th scope="col">Statut</th>
            <th scope="col">Action</th>
          </tr>
        </thead>
        <tbody id="waiting-tbody"></tbody>
      </table>
      <p id="waiting-empty" hidden class="empty-hint">Aucune demande en liste d'attente.</p>
    </div>
  </section>

  <!-- ── Confirmation d'offre ─────────────────────────────────────────────── -->
  <div id="offer-confirm" class="confirm-banner" hidden role="status" aria-live="polite">
    Créneau proposé avec succès.
  </div>
</AppShell>

<style>
  header { margin-bottom: var(--space-6); }
  h1 { margin-bottom: var(--space-1); }
  header > p { color: var(--color-muted); font-size: var(--font-size-sm); }

  section {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-6);
    margin-bottom: var(--space-6);
  }

  h2 {
    margin: 0 0 var(--space-4);
    font-size: var(--font-size-base);
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--font-size-sm);
  }

  th, td {
    padding: var(--space-2) var(--space-3);
    text-align: left;
    border-bottom: 1px solid var(--color-border);
  }

  th { color: var(--color-muted); font-weight: 600; }
  tr:last-child td { border-bottom: none; }

  .empty-hint {
    color: var(--color-muted);
    font-size: var(--font-size-sm);
    margin: 0;
    padding: var(--space-4) 0;
  }

  [role="status"] {
    font-size: var(--font-size-sm);
    min-height: 1.25rem;
    margin-bottom: var(--space-2);
    color: var(--color-muted);
  }

  [role="status"].error { color: var(--color-error-fg); }

  .count-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--color-accent);
    color: var(--color-accent-fg);
    border-radius: 9999px;
    font-size: var(--font-size-sm);
    font-weight: 700;
    min-width: 1.5rem;
    height: 1.5rem;
    padding: 0 var(--space-1);
  }

  button.offer-btn {
    padding: var(--space-1) var(--space-3);
    background: var(--color-accent);
    color: var(--color-accent-fg);
    border: none;
    border-radius: var(--radius-sm);
    font-size: var(--font-size-sm);
    cursor: pointer;
  }

  button.offer-btn:disabled {
    opacity: 0.5;
    cursor: default;
  }

  .confirm-banner {
    padding: var(--space-3) var(--space-4);
    background: var(--color-success-bg, #d1fae5);
    color: var(--color-success-fg, #065f46);
    border-radius: var(--radius-sm);
    font-size: var(--font-size-sm);
    margin-bottom: var(--space-4);
  }
</style>

<script>
  import { proAgenda } from '../../lib/endpoints.ts';
  import type { WaitingListEntry } from '../../lib/endpoints.ts';

  const loginRedirect = '/auth/login?next=/secretary/liste-attente';

  const listStatus   = document.getElementById('list-status')   as HTMLElement;
  const listContent  = document.getElementById('list-content')  as HTMLElement;
  const waitingTbody = document.getElementById('waiting-tbody') as HTMLTableSectionElement;
  const waitingEmpty = document.getElementById('waiting-empty') as HTMLElement;
  const waitingBadge = document.getElementById('waiting-badge') as HTMLElement;
  const offerConfirm = document.getElementById('offer-confirm') as HTMLElement;

  async function loadWaitingList(): Promise<void> {
    listStatus.textContent = 'Chargement…';
    listStatus.className = '';
    try {
      const { status, data } = await proAgenda.getWaitingList();
      if (status === 401) { window.location.href = loginRedirect; return; }
      if (status === 403) { listStatus.textContent = 'Accès refusé (403).'; listStatus.className = 'error'; return; }
      if (status !== 200) { listStatus.textContent = `Erreur serveur (HTTP ${status}).`; listStatus.className = 'error'; return; }

      listStatus.textContent = '';
      const entries = (data as WaitingListEntry[]) ?? [];
      waitingTbody.innerHTML = '';
      waitingEmpty.hidden = true;

      if (entries.length === 0) {
        waitingEmpty.hidden = false;
        waitingBadge.hidden = true;
      } else {
        waitingBadge.textContent = String(entries.length);
        waitingBadge.hidden = false;
        entries.forEach((entry) => {
          const tr = waitingTbody.insertRow();
          tr.dataset.id = entry.id;

          const requestedAt = entry.requested_at
            ? new Date(entry.requested_at).toLocaleDateString('fr-FR', { day: '2-digit', month: '2-digit', year: 'numeric' })
            : '—';

          tr.insertCell().textContent = entry.patient_id ?? '—';
          tr.insertCell().textContent = '—';
          tr.insertCell().textContent = requestedAt;
          tr.insertCell().textContent = entry.status ?? '—';

          const actionTd = tr.insertCell();
          const btn = document.createElement('button');
          btn.className = 'offer-btn';
          btn.textContent = 'Proposer créneau';
          btn.setAttribute('aria-label', `Proposer un créneau au patient ${entry.patient_id ?? entry.id}`);
          btn.dataset.id = entry.id;
          btn.addEventListener('click', () => void offerSlot(entry.id, btn));
          actionTd.appendChild(btn);
        });
      }

      listContent.hidden = false;
    } catch (err) {
      listStatus.textContent = `Erreur réseau : ${err instanceof Error ? err.message : String(err)}`;
      listStatus.className = 'error';
    }
  }

  async function offerSlot(id: string, btn: HTMLButtonElement): Promise<void> {
    btn.disabled = true;
    btn.textContent = '…';
    try {
      const { status } = await proAgenda.offerWaitingList(id);
      if (status === 401) { window.location.href = loginRedirect; return; }
      if (status === 403) {
        listStatus.textContent = 'Accès refusé (403).';
        listStatus.className = 'error';
        btn.disabled = false;
        btn.textContent = 'Proposer créneau';
        return;
      }
      if (status !== 200 && status !== 201 && status !== 204) {
        listStatus.textContent = `Erreur lors de l'offre (HTTP ${status}).`;
        listStatus.className = 'error';
        btn.disabled = false;
        btn.textContent = 'Proposer créneau';
        return;
      }

      offerConfirm.hidden = false;
      setTimeout(() => { offerConfirm.hidden = true; }, 4000);
      // Rafraîchit la liste pour refléter le changement de statut
      void loadWaitingList();
    } catch (err) {
      listStatus.textContent = `Erreur réseau : ${err instanceof Error ? err.message : String(err)}`;
      listStatus.className = 'error';
      btn.disabled = false;
      btn.textContent = 'Proposer créneau';
    }
  }

  void loadWaitingList();
</script>
