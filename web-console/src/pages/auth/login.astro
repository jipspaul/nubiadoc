---
import Default from '../../layouts/Default.astro';
---
<Default title="Login — Nubia Console">
  <h1 style="margin-bottom:1.5rem;">POST /v1/auth/login</h1>
  <form id="login-form" style="display:flex;flex-direction:column;gap:0.75rem;max-width:400px;">
    <label>
      Email
      <input type="email" name="email" required
        style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
    </label>
    <label>
      Mot de passe
      <input type="password" name="password" required
        style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
    </label>
    <fieldset id="mfa-section" hidden
      style="border:1px solid var(--border);border-radius:4px;padding:0.75rem;display:flex;flex-direction:column;gap:0.5rem;">
      <legend style="padding:0 0.25rem;font-size:0.875rem;color:var(--muted);">MFA requis</legend>
      <label>
        Code MFA (6 chiffres)
        <input type="text" name="mfa_code" inputmode="numeric" maxlength="6" pattern="\\d{6}"
          autocomplete="one-time-code"
          style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
      </label>
    </fieldset>
    <button type="submit"
      style="padding:0.5rem 1rem;background:var(--accent);color:#fff;border:none;border-radius:4px;cursor:pointer;align-self:flex-start;">
      Se connecter
    </button>
  </form>
  <pre id="result" style="margin-top:1.5rem;padding:1rem;background:var(--surface);border:1px solid var(--border);border-radius:4px;white-space:pre-wrap;font-size:0.875rem;min-height:3rem;"></pre>
</Default>

<style>
  pre.success { border-left: 4px solid green; }
  pre.error   { border-left: 4px solid red; }
</style>

<script>
  import { authFetch } from '../../lib/api.ts';
  import { login } from '../../lib/session.ts';

  const form = document.getElementById('login-form') as HTMLFormElement;
  const result = document.getElementById('result') as HTMLPreElement;
  const mfaSection = document.getElementById('mfa-section') as HTMLFieldSetElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(form);
    const email = fd.get('email') as string;
    const password = fd.get('password') as string;
    const mfa_code = (fd.get('mfa_code') as string) || undefined;

    result.className = '';
    result.textContent = 'Chargement…';

    const body: Record<string, string> = { email, password };
    if (mfa_code) body.mfa_code = mfa_code;

    try {
      const { status, data } = await authFetch('/v1/auth/login', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });

      if (status === 200) {
        const tokens = data as { access_token: string; refresh_token: string; token_type: string; expires_in: number; context_required?: boolean };
        login(tokens.access_token);
        if (tokens.context_required) {
          window.location.href = '/auth/select-context';
        } else {
          window.location.href = '/app';
        }
        return;
      } else if (status === 401) {
        const errData = data as Record<string, unknown> | null;
        if (errData && errData.code === 'mfa_required') {
          mfaSection.hidden = false;
          result.className = 'error';
          result.textContent = `HTTP 401 — MFA requis\nEntrez votre code TOTP et resoumettez.`;
        } else {
          result.className = 'error';
          result.textContent = `HTTP 401 — Identifiants incorrects.`;
        }
      } else {
        result.className = 'error';
        result.textContent = `HTTP ${status}\n${JSON.stringify(data, null, 2)}`;
      }
    } catch (err) {
      result.className = 'error';
      result.textContent = `Erreur réseau : ${err instanceof Error ? err.message : String(err)}`;
    }
  });
</script>
