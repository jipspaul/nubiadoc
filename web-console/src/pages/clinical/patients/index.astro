---
import Default from '../../../layouts/Default.astro';
---
<Default title="Patients du cabinet — Nubia Console">
  <h1 style="margin-bottom:0.5rem;">Patients du cabinet — GET/POST /v1/cabinet/patients</h1>
  <p style="color:var(--muted);margin-bottom:1.5rem;">Token pro requis. Secrétariat : fiche administrative. Praticien/admin : accès clinique complet.</p>

  <section aria-labelledby="list-heading">
    <h2 id="list-heading" style="margin-bottom:1rem;">Lister les dossiers</h2>
    <form id="patients-list-form" style="display:flex;flex-direction:column;gap:0.75rem;max-width:480px;">
      <label>
        Access token (Bearer, rôle pro)
        <input type="text" name="access_token" required
          style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
      </label>
      <label>
        q (recherche, optionnel)
        <input type="text" name="q" placeholder="Nom ou prénom"
          style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
      </label>
      <label>
        filter (optionnel)
        <select name="filter"
          style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;">
          <option value="">— aucun —</option>
          <option value="in_treatment">in_treatment</option>
          <option value="to_review">to_review</option>
        </select>
      </label>
      <button type="submit"
        style="padding:0.5rem 1rem;background:var(--accent);color:#fff;border:none;border-radius:4px;cursor:pointer;align-self:flex-start;">
        GET — Lister les dossiers
      </button>
    </form>
    <p id="list-badge" style="margin-top:1rem;display:none;"></p>
    <pre id="list-result" style="margin-top:0.5rem;padding:1rem;background:var(--surface);border:1px solid var(--border);border-radius:4px;white-space:pre-wrap;font-size:0.875rem;min-height:3rem;"></pre>
  </section>

  <section aria-labelledby="attach-heading" style="margin-top:2.5rem;">
    <h2 id="attach-heading" style="margin-bottom:1rem;">Rattacher un patient</h2>
    <form id="patients-attach-form" style="display:flex;flex-direction:column;gap:0.75rem;max-width:480px;">
      <label>
        Access token (Bearer, rôle pro)
        <input type="text" name="access_token" required
          style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
      </label>
      <label>
        patient_account_id (UUID)
        <input type="text" name="patient_account_id" required placeholder="00000000-0000-0000-0000-000000000001"
          style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
      </label>
      <button type="submit"
        style="padding:0.5rem 1rem;background:var(--accent);color:#fff;border:none;border-radius:4px;cursor:pointer;align-self:flex-start;">
        POST — Rattacher un patient
      </button>
    </form>
    <p id="attach-badge" style="margin-top:1rem;display:none;"></p>
    <pre id="attach-result" style="margin-top:0.5rem;padding:1rem;background:var(--surface);border:1px solid var(--border);border-radius:4px;white-space:pre-wrap;font-size:0.875rem;min-height:3rem;"></pre>
  </section>
</Default>

<style>
  pre.success { border-left: 4px solid green; }
  pre.error   { border-left: 4px solid red; }
  .badge { display:inline-block;padding:0.25rem 0.6rem;border-radius:4px;font-size:0.85rem;font-weight:600; }
  .badge-ok  { background:#166534;color:#bbf7d0; }
  .badge-err { background:#7f1d1d;color:#fecaca; }
</style>

<script>
  import { apiFetch } from '../../../lib/api.ts';

  function showResult(
    resultEl: HTMLPreElement,
    badgeEl: HTMLParagraphElement,
    httpStatus: number,
    data: unknown,
  ): void {
    resultEl.className = httpStatus < 300 ? 'success' : 'error';
    resultEl.textContent = `HTTP ${httpStatus}\n${data !== null ? JSON.stringify(data, null, 2) : '(aucun contenu)'}`;
    badgeEl.innerHTML = `<span class="badge ${httpStatus < 300 ? 'badge-ok' : 'badge-err'}">HTTP ${httpStatus}</span>`;
    badgeEl.style.display = 'block';
  }

  const listForm = document.getElementById('patients-list-form') as HTMLFormElement;
  const listResult = document.getElementById('list-result') as HTMLPreElement;
  const listBadge = document.getElementById('list-badge') as HTMLParagraphElement;

  listForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(listForm);
    const access_token = fd.get('access_token') as string;
    const q = fd.get('q') as string;
    const filter = fd.get('filter') as string;

    const params = new URLSearchParams();
    if (q) params.set('q', q);
    if (filter) params.set('filter', filter);
    const qs = params.toString() ? `?${params.toString()}` : '';

    listResult.className = '';
    listResult.textContent = 'Chargement…';
    listBadge.style.display = 'none';

    try {
      const { status, data } = await apiFetch(`/v1/cabinet/patients${qs}`, {
        method: 'GET',
        headers: { 'Authorization': `Bearer ${access_token}` },
      });
      showResult(listResult, listBadge, status, data);
    } catch (err) {
      listResult.className = 'error';
      listResult.textContent = `Erreur réseau : ${err instanceof Error ? err.message : String(err)}`;
    }
  });

  const attachForm = document.getElementById('patients-attach-form') as HTMLFormElement;
  const attachResult = document.getElementById('attach-result') as HTMLPreElement;
  const attachBadge = document.getElementById('attach-badge') as HTMLParagraphElement;

  attachForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(attachForm);
    const access_token = fd.get('access_token') as string;
    const patient_account_id = fd.get('patient_account_id') as string;

    attachResult.className = '';
    attachResult.textContent = 'Chargement…';
    attachBadge.style.display = 'none';

    try {
      const { status, data } = await apiFetch('/v1/cabinet/patients', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Authorization': `Bearer ${access_token}`,
        },
        body: JSON.stringify({ patient_account_id }),
      });
      showResult(attachResult, attachBadge, status, data);
    } catch (err) {
      attachResult.className = 'error';
      attachResult.textContent = `Erreur réseau : ${err instanceof Error ? err.message : String(err)}`;
    }
  });
</script>
