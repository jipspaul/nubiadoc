---
import Default from '../../../../layouts/Default.astro';
const { id } = Astro.props.params ?? Astro.params;

// FDI tooth numbers by quadrant
const QUADRANTS: [string, number[]][] = [
  ['Q1 (sup. droit)', [18,17,16,15,14,13,12,11]],
  ['Q2 (sup. gauche)', [21,22,23,24,25,26,27,28]],
  ['Q3 (inf. gauche)', [31,32,33,34,35,36,37,38]],
  ['Q4 (inf. droit)', [48,47,46,45,44,43,42,41]],
];
---
<Default title="Odontogramme — Nubia Console">
  <h1 style="margin-bottom:0.5rem;">Odontogramme — GET/PUT /v1/cabinet/patients/{id}/dental-chart</h1>
  <p style="color:var(--muted);font-size:0.875rem;margin-bottom:1.5rem;">
    <strong>practitioner only</strong> (R.4127-72) — <code>403</code> pour <code>secretary</code>. Clés FDI 11-48.
  </p>

  <!-- Token + Patient ID -->
  <section style="margin-bottom:1.5rem;display:flex;flex-direction:column;gap:0.75rem;">
    <label style="font-size:0.875rem;font-weight:600;">
      Access token (Bearer)
      <input id="access-token" type="text" placeholder="eyJ…"
        style="display:block;width:100%;max-width:600px;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
    </label>
    <label style="font-size:0.875rem;font-weight:600;">
      Patient ID <span style="color:red">*</span>
      <input id="patient-id" type="text" placeholder="uuid" value={id ?? ''}
        style="display:block;width:100%;max-width:600px;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
    </label>
  </section>

  <!-- GET section -->
  <section aria-labelledby="h-get" style="margin-bottom:2rem;border:1px solid var(--border);border-radius:6px;padding:1rem;">
    <h2 id="h-get" style="margin:0 0 1rem;font-size:1rem;">GET /v1/cabinet/patients/{id}/dental-chart</h2>
    <form id="form-get" style="display:flex;gap:0.75rem;align-items:flex-end;">
      <button type="submit"
        style="padding:0.5rem 1rem;background:var(--accent);color:#fff;border:none;border-radius:4px;cursor:pointer;">
        GET
      </button>
    </form>
    <p id="badge-get" style="margin-top:0.75rem;display:none;"></p>
    <pre id="result-get" style="margin-top:0.5rem;padding:1rem;background:var(--surface);border:1px solid var(--border);border-radius:4px;white-space:pre-wrap;font-size:0.875rem;min-height:2.5rem;"></pre>
  </section>

  <!-- Grille FDI -->
  <section aria-labelledby="h-grid" style="margin-bottom:2rem;border:1px solid var(--border);border-radius:6px;padding:1rem;">
    <h2 id="h-grid" style="margin:0 0 1rem;font-size:1rem;">Grille odontogramme (FDI)</h2>
    <p style="color:var(--muted);font-size:0.8rem;margin-bottom:1rem;">Statuts : <code>sain</code>, <code>carie</code>, <code>obturation</code>, <code>absent</code>, <code>implant</code>, <code>couronne</code>, <code>bridge</code>.</p>

    {QUADRANTS.map(([label, teeth]) => (
      <fieldset style="border:1px solid var(--border);border-radius:4px;padding:0.75rem;margin-bottom:0.75rem;">
        <legend style="font-size:0.8rem;color:var(--muted);padding:0 0.25rem;">{label}</legend>
        <div style="display:flex;flex-wrap:wrap;gap:0.5rem;">
          {teeth.map((tooth) => (
            <label style="display:flex;flex-direction:column;align-items:center;gap:0.25rem;font-size:0.75rem;min-width:3.5rem;">
              <span style="font-weight:600;">{tooth}</span>
              <select
                id={`tooth-${tooth}`}
                name={`tooth_${tooth}`}
                data-fdi={String(tooth)}
                style="padding:0.2rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;font-size:0.75rem;width:100%;"
              >
                <option value="sain">sain</option>
                <option value="carie">carie</option>
                <option value="obturation">obturation</option>
                <option value="absent">absent</option>
                <option value="implant">implant</option>
                <option value="couronne">couronne</option>
                <option value="bridge">bridge</option>
              </select>
            </label>
          ))}
        </div>
      </fieldset>
    ))}
  </section>

  <!-- PUT section -->
  <section aria-labelledby="h-put" style="margin-bottom:2rem;border:1px solid var(--border);border-radius:6px;padding:1rem;">
    <h2 id="h-put" style="margin:0 0 1rem;font-size:1rem;">PUT /v1/cabinet/patients/{id}/dental-chart</h2>
    <form id="form-put" style="display:flex;gap:0.75rem;align-items:flex-end;">
      <button type="submit"
        style="padding:0.5rem 1rem;background:var(--accent);color:#fff;border:none;border-radius:4px;cursor:pointer;">
        Save (PUT)
      </button>
    </form>
    <p id="badge-put" style="margin-top:0.75rem;display:none;"></p>
    <pre id="result-put" style="margin-top:0.5rem;padding:1rem;background:var(--surface);border:1px solid var(--border);border-radius:4px;white-space:pre-wrap;font-size:0.875rem;min-height:2.5rem;"></pre>
  </section>

  <nav aria-label="Navigation patient" style="margin-top:1rem;">
    <a href={`/clinical/patients/${id ?? ''}`}>← Fiche patient</a>
    &nbsp;|&nbsp;
    <a href="/clinical/patients">← Liste des patients</a>
  </nav>
</Default>

<style>
  pre.success { border-left: 4px solid green; }
  pre.error   { border-left: 4px solid red; }
  .badge { display:inline-block;padding:0.25rem 0.6rem;border-radius:4px;font-size:0.85rem;font-weight:600; }
  .badge-ok  { background:#166534;color:#bbf7d0; }
  .badge-err { background:#7f1d1d;color:#fecaca; }
</style>

<script>
  import { apiFetch } from '../../../../lib/api.ts';

  // All FDI teeth (11-18, 21-28, 31-38, 41-48)
  const FDI_TEETH: number[] = [
    18,17,16,15,14,13,12,11,
    21,22,23,24,25,26,27,28,
    31,32,33,34,35,36,37,38,
    48,47,46,45,44,43,42,41,
  ];

  function getToken(): string {
    return (document.getElementById('access-token') as HTMLInputElement).value;
  }

  function getPatientId(): string {
    return (document.getElementById('patient-id') as HTMLInputElement).value;
  }

  function renderResult(
    resultEl: HTMLPreElement,
    badgeEl: HTMLParagraphElement,
    httpStatus: number,
    data: unknown,
  ): void {
    resultEl.className = httpStatus < 300 ? 'success' : 'error';
    resultEl.textContent = `HTTP ${httpStatus}\n${data !== null ? JSON.stringify(data, null, 2) : '(aucun contenu)'}`;
    badgeEl.innerHTML = `<span class="badge ${httpStatus < 300 ? 'badge-ok' : 'badge-err'}">HTTP ${httpStatus}</span>`;
    badgeEl.style.display = 'block';
  }

  function renderError(resultEl: HTMLPreElement, err: unknown): void {
    resultEl.className = 'error';
    resultEl.textContent = `Erreur réseau : ${err instanceof Error ? err.message : String(err)}`;
  }

  function populateGrid(chart: Record<string, string>): void {
    for (const tooth of FDI_TEETH) {
      const sel = document.getElementById(`tooth-${tooth}`) as HTMLSelectElement | null;
      if (sel && chart[String(tooth)]) {
        sel.value = chart[String(tooth)];
      }
    }
  }

  function collectGrid(): Record<string, string> {
    const result: Record<string, string> = {};
    for (const tooth of FDI_TEETH) {
      const sel = document.getElementById(`tooth-${tooth}`) as HTMLSelectElement | null;
      if (sel) result[String(tooth)] = sel.value;
    }
    return result;
  }

  // --- GET ---
  const formGet = document.getElementById('form-get') as HTMLFormElement;
  const resultGet = document.getElementById('result-get') as HTMLPreElement;
  const badgeGet = document.getElementById('badge-get') as HTMLParagraphElement;

  formGet.addEventListener('submit', async (e) => {
    e.preventDefault();
    resultGet.className = '';
    resultGet.textContent = 'Chargement…';
    badgeGet.style.display = 'none';
    try {
      const { status, data } = await apiFetch(
        `/v1/cabinet/patients/${encodeURIComponent(getPatientId())}/dental-chart`,
        { method: 'GET', headers: { 'Authorization': `Bearer ${getToken()}` } },
      );
      renderResult(resultGet, badgeGet, status, data);
      if (status === 200 && data !== null && typeof data === 'object') {
        populateGrid(data as Record<string, string>);
      }
    } catch (err) {
      renderError(resultGet, err);
    }
  });

  // --- PUT ---
  const formPut = document.getElementById('form-put') as HTMLFormElement;
  const resultPut = document.getElementById('result-put') as HTMLPreElement;
  const badgePut = document.getElementById('badge-put') as HTMLParagraphElement;

  formPut.addEventListener('submit', async (e) => {
    e.preventDefault();
    resultPut.className = '';
    resultPut.textContent = 'Chargement…';
    badgePut.style.display = 'none';
    try {
      const { status, data } = await apiFetch(
        `/v1/cabinet/patients/${encodeURIComponent(getPatientId())}/dental-chart`,
        {
          method: 'PUT',
          headers: {
            'Authorization': `Bearer ${getToken()}`,
            'Content-Type': 'application/json',
          },
          body: JSON.stringify(collectGrid()),
        },
      );
      renderResult(resultPut, badgePut, status, data);
    } catch (err) {
      renderError(resultPut, err);
    }
  });
</script>
