---
import Default from '../../../../layouts/Default.astro';
const { id } = Astro.props.params ?? Astro.params;
---
<Default title="Dossier médical — Nubia Console">
  <h1 style="margin-bottom:0.5rem;">Dossier médical — GET/PATCH /v1/cabinet/patients/{id}/medical-record</h1>
  <p style="color:var(--muted);font-size:0.875rem;margin-bottom:1.5rem;">
    <strong>practitioner only</strong> (R.4127-72) — <code>403</code> pour <code>secretary</code>.
  </p>

  <!-- Token partagé -->
  <section style="margin-bottom:1.5rem;">
    <label style="font-size:0.875rem;font-weight:600;">
      Access token (Bearer)
      <input id="access-token" type="text" placeholder="eyJ…"
        style="display:block;width:100%;max-width:600px;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
    </label>
  </section>

  <!-- Patient ID partagé -->
  <section style="margin-bottom:2rem;">
    <label style="font-size:0.875rem;font-weight:600;">
      Patient ID <span style="color:red">*</span>
      <input id="patient-id" type="text" placeholder="uuid" value={id ?? ''}
        style="display:block;width:100%;max-width:600px;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
    </label>
  </section>

  <!-- Section GET -->
  <section aria-labelledby="h-get" style="margin-bottom:2rem;border:1px solid var(--border);border-radius:6px;padding:1rem;">
    <h2 id="h-get" style="margin:0 0 1rem;font-size:1rem;">GET /v1/cabinet/patients/{id}/medical-record</h2>
    <form id="form-get" style="display:flex;gap:0.75rem;align-items:flex-end;">
      <button type="submit"
        style="padding:0.5rem 1rem;background:var(--accent);color:#fff;border:none;border-radius:4px;cursor:pointer;">
        GET
      </button>
    </form>
    <p id="badge-get" style="margin-top:0.75rem;display:none;"></p>
    <pre id="result-get" style="margin-top:0.5rem;padding:1rem;background:var(--surface);border:1px solid var(--border);border-radius:4px;white-space:pre-wrap;font-size:0.875rem;min-height:2.5rem;"></pre>
  </section>

  <!-- Section PATCH -->
  <section aria-labelledby="h-patch" style="margin-bottom:2rem;border:1px solid var(--border);border-radius:6px;padding:1rem;">
    <h2 id="h-patch" style="margin:0 0 1rem;font-size:1rem;">PATCH /v1/cabinet/patients/{id}/medical-record</h2>
    <form id="form-patch" style="display:flex;flex-direction:column;gap:0.75rem;max-width:500px;">
      <label style="font-size:0.875rem;">
        Allergies
        <textarea id="field-allergies" name="allergies" rows="3" placeholder="Pénicilline, latex…"
          style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;font-family:inherit;font-size:0.875rem;"></textarea>
      </label>
      <label style="font-size:0.875rem;">
        Traitements en cours
        <textarea id="field-current-treatments" name="current_treatments" rows="3" placeholder="Metformine 500 mg…"
          style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;font-family:inherit;font-size:0.875rem;"></textarea>
      </label>
      <label style="font-size:0.875rem;">
        Antécédents médicaux
        <textarea id="field-medical-history" name="medical_history" rows="3" placeholder="Diabète type 2, HTA…"
          style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;font-family:inherit;font-size:0.875rem;"></textarea>
      </label>
      <button type="submit"
        style="padding:0.5rem 1rem;background:var(--accent);color:#fff;border:none;border-radius:4px;cursor:pointer;align-self:flex-start;">
        PATCH (mettre à jour)
      </button>
    </form>
    <p id="badge-patch" style="margin-top:0.75rem;display:none;"></p>
    <pre id="result-patch" style="margin-top:0.5rem;padding:1rem;background:var(--surface);border:1px solid var(--border);border-radius:4px;white-space:pre-wrap;font-size:0.875rem;min-height:2.5rem;"></pre>
  </section>

  <nav aria-label="Navigation patient" style="margin-top:1rem;">
    <a href={`/clinical/patients/${id ?? ''}`}>← Fiche patient</a>
    &nbsp;|&nbsp;
    <a href="/clinical/patients">← Liste des patients</a>
  </nav>
</Default>

<style>
  pre.success { border-left: 4px solid green; }
  pre.error   { border-left: 4px solid red; }
  .badge { display:inline-block;padding:0.25rem 0.6rem;border-radius:4px;font-size:0.85rem;font-weight:600; }
  .badge-ok  { background:#166534;color:#bbf7d0; }
  .badge-err { background:#7f1d1d;color:#fecaca; }
</style>

<script>
  import { apiFetch } from '../../../../lib/api.ts';

  function getToken(): string {
    return (document.getElementById('access-token') as HTMLInputElement).value;
  }

  function getPatientId(): string {
    return (document.getElementById('patient-id') as HTMLInputElement).value;
  }

  function renderResult(
    resultEl: HTMLPreElement,
    badgeEl: HTMLParagraphElement,
    httpStatus: number,
    data: unknown,
  ): void {
    resultEl.className = httpStatus < 300 ? 'success' : 'error';
    resultEl.textContent = `HTTP ${httpStatus}\n${data !== null ? JSON.stringify(data, null, 2) : '(aucun contenu)'}`;
    badgeEl.innerHTML = `<span class="badge ${httpStatus < 300 ? 'badge-ok' : 'badge-err'}">HTTP ${httpStatus}</span>`;
    badgeEl.style.display = 'block';
  }

  function renderError(resultEl: HTMLPreElement, err: unknown): void {
    resultEl.className = 'error';
    resultEl.textContent = `Erreur réseau : ${err instanceof Error ? err.message : String(err)}`;
  }

  // --- GET medical-record ---
  const formGet = document.getElementById('form-get') as HTMLFormElement;
  const resultGet = document.getElementById('result-get') as HTMLPreElement;
  const badgeGet = document.getElementById('badge-get') as HTMLParagraphElement;

  formGet.addEventListener('submit', async (e) => {
    e.preventDefault();
    const patientId = getPatientId();
    resultGet.className = '';
    resultGet.textContent = 'Chargement…';
    badgeGet.style.display = 'none';
    try {
      const { status, data } = await apiFetch(
        `/v1/cabinet/patients/${encodeURIComponent(patientId)}/medical-record`,
        { method: 'GET', headers: { 'Authorization': `Bearer ${getToken()}` } },
      );
      renderResult(resultGet, badgeGet, status, data);

      // Pré-remplir le formulaire PATCH si 200
      if (status === 200 && data !== null && typeof data === 'object') {
        const rec = data as Record<string, unknown>;
        const allergiesEl = document.getElementById('field-allergies') as HTMLTextAreaElement;
        const treatmentsEl = document.getElementById('field-current-treatments') as HTMLTextAreaElement;
        const historyEl = document.getElementById('field-medical-history') as HTMLTextAreaElement;
        if (typeof rec.allergies === 'string') allergiesEl.value = rec.allergies;
        if (typeof rec.current_treatments === 'string') treatmentsEl.value = rec.current_treatments;
        if (typeof rec.medical_history === 'string') historyEl.value = rec.medical_history;
      }
    } catch (err) {
      renderError(resultGet, err);
    }
  });

  // --- PATCH medical-record ---
  const formPatch = document.getElementById('form-patch') as HTMLFormElement;
  const resultPatch = document.getElementById('result-patch') as HTMLPreElement;
  const badgePatch = document.getElementById('badge-patch') as HTMLParagraphElement;

  formPatch.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(formPatch);
    const patientId = getPatientId();
    const body: Record<string, string> = {};
    const allergies = (fd.get('allergies') as string).trim();
    const currentTreatments = (fd.get('current_treatments') as string).trim();
    const medicalHistory = (fd.get('medical_history') as string).trim();
    if (allergies) body.allergies = allergies;
    if (currentTreatments) body.current_treatments = currentTreatments;
    if (medicalHistory) body.medical_history = medicalHistory;

    resultPatch.className = '';
    resultPatch.textContent = 'Chargement…';
    badgePatch.style.display = 'none';
    try {
      const { status, data } = await apiFetch(
        `/v1/cabinet/patients/${encodeURIComponent(patientId)}/medical-record`,
        {
          method: 'PATCH',
          headers: {
            'Authorization': `Bearer ${getToken()}`,
            'Content-Type': 'application/json',
          },
          body: JSON.stringify(body),
        },
      );
      renderResult(resultPatch, badgePatch, status, data);
    } catch (err) {
      renderError(resultPatch, err);
    }
  });
</script>
