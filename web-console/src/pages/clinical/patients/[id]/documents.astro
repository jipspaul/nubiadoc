---
import Default from '../../../../layouts/Default.astro';
const { id } = Astro.params;

const categories = [
  'devis',
  'facture',
  'ordonnance',
  'radio',
  'cbct',
  'photo',
  'cr',
  'consigne',
  'attestation',
  'carte_mutuelle',
  'passeport_implantaire',
  'consentement',
];
---
<Default title="Documents patient — Nubia Console">
  <h1 style="margin-bottom:0.5rem;">Documents patient — GET/POST /v1/cabinet/patients/{id}/documents</h1>
  <p style="color:var(--muted);margin-bottom:1.5rem;">
    Rôle <code>pro</code> requis. Secrétariat : documents administratifs. Praticien/admin : accès complet.
  </p>

  <section aria-labelledby="list-heading">
    <h2 id="list-heading" style="margin-bottom:1rem;">Lister les documents</h2>
    <form id="list-form" style="display:flex;flex-direction:column;gap:0.75rem;max-width:480px;">
      <label>
        Access token (Bearer, rôle pro)
        <input type="text" name="access_token" required
          style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
      </label>
      <label>
        Patient ID
        <input type="text" name="patient_id" required value={id ?? ''}
          style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
      </label>
      <button type="submit"
        style="padding:0.5rem 1rem;background:var(--accent);color:#fff;border:none;border-radius:4px;cursor:pointer;align-self:flex-start;">
        GET — Lister les documents
      </button>
    </form>
    <p id="list-badge" style="margin-top:1rem;display:none;"></p>
    <pre id="list-result" style="margin-top:0.5rem;padding:1rem;background:var(--surface);border:1px solid var(--border);border-radius:4px;white-space:pre-wrap;font-size:0.875rem;min-height:3rem;"></pre>
  </section>

  <section aria-labelledby="upload-heading" style="margin-top:2.5rem;">
    <h2 id="upload-heading" style="margin-bottom:1rem;">Uploader un document</h2>
    <form id="upload-form" style="display:flex;flex-direction:column;gap:0.75rem;max-width:480px;">
      <label>
        Access token (Bearer, rôle pro)
        <input type="text" name="access_token" required
          style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
      </label>
      <label>
        Patient ID
        <input type="text" name="patient_id" required value={id ?? ''}
          style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
      </label>
      <label>
        Catégorie
        <select name="category" required
          style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;">
          <option value="">— choisir —</option>
          {categories.map(c => <option value={c}>{c}</option>)}
        </select>
      </label>
      <label>
        Fichier
        <input type="file" name="file" required accept="application/pdf,image/*"
          style="display:block;width:100%;padding:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);border-radius:4px;margin-top:0.25rem;" />
      </label>
      <button type="submit" id="upload-btn"
        style="padding:0.5rem 1rem;background:var(--accent);color:#fff;border:none;border-radius:4px;cursor:pointer;align-self:flex-start;">
        POST — Uploader
      </button>
    </form>
    <p id="upload-badge" style="margin-top:1rem;display:none;"></p>
    <pre id="upload-result" style="margin-top:0.5rem;padding:1rem;background:var(--surface);border:1px solid var(--border);border-radius:4px;white-space:pre-wrap;font-size:0.875rem;min-height:3rem;"></pre>
  </section>

  <nav aria-label="Navigation patient" style="margin-top:2.5rem;">
    <a href={`/clinical/patients/${id ?? ''}`}>← Fiche patient</a>
    &nbsp;|&nbsp;
    <a href="/clinical/patients">← Liste des patients</a>
  </nav>
</Default>

<style>
  pre.success { border-left: 4px solid green; }
  pre.error   { border-left: 4px solid red; }
  .badge { display:inline-block;padding:0.25rem 0.6rem;border-radius:4px;font-size:0.85rem;font-weight:600; }
  .badge-ok  { background:#166534;color:#bbf7d0; }
  .badge-err { background:#7f1d1d;color:#fecaca; }
</style>

<script>
  import { apiFetch } from '../../../../lib/api.ts';

  function showResult(
    resultEl: HTMLPreElement,
    badgeEl: HTMLParagraphElement,
    httpStatus: number,
    data: unknown,
  ): void {
    resultEl.className = httpStatus < 300 ? 'success' : 'error';
    resultEl.textContent = `HTTP ${httpStatus}\n${data !== null ? JSON.stringify(data, null, 2) : '(aucun contenu)'}`;
    badgeEl.innerHTML = `<span class="badge ${httpStatus < 300 ? 'badge-ok' : 'badge-err'}">HTTP ${httpStatus}</span>`;
    badgeEl.style.display = 'block';
  }

  const listForm = document.getElementById('list-form') as HTMLFormElement;
  const listResult = document.getElementById('list-result') as HTMLPreElement;
  const listBadge = document.getElementById('list-badge') as HTMLParagraphElement;

  listForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(listForm);
    const access_token = fd.get('access_token') as string;
    const patient_id = fd.get('patient_id') as string;

    listResult.className = '';
    listResult.textContent = 'Chargement…';
    listBadge.style.display = 'none';

    try {
      const { status, data } = await apiFetch(`/v1/cabinet/patients/${patient_id}/documents`, {
        method: 'GET',
        headers: { 'Authorization': `Bearer ${access_token}` },
      });
      showResult(listResult, listBadge, status, data);
    } catch (err) {
      listResult.className = 'error';
      listResult.textContent = `Erreur réseau : ${err instanceof Error ? err.message : String(err)}`;
    }
  });

  const uploadForm = document.getElementById('upload-form') as HTMLFormElement;
  const uploadResult = document.getElementById('upload-result') as HTMLPreElement;
  const uploadBadge = document.getElementById('upload-badge') as HTMLParagraphElement;

  uploadForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(uploadForm);
    const access_token = fd.get('access_token') as string;
    const patient_id = fd.get('patient_id') as string;
    fd.delete('access_token');
    fd.delete('patient_id');

    uploadResult.className = '';
    uploadResult.textContent = 'Envoi…';
    uploadBadge.style.display = 'none';

    try {
      const { status, data } = await apiFetch(`/v1/cabinet/patients/${patient_id}/documents`, {
        method: 'POST',
        headers: { 'Authorization': `Bearer ${access_token}` },
        body: fd,
      });
      showResult(uploadResult, uploadBadge, status, data);
    } catch (err) {
      uploadResult.className = 'error';
      uploadResult.textContent = `Erreur réseau : ${err instanceof Error ? err.message : String(err)}`;
    }
  });
</script>
