---
interface Props {
  title?: string;
  description?: string;
  icon?: string;
  id?: string;
}
const {
  title = 'Aucun élément',
  description,
  icon = '○',
  id,
} = Astro.props;
---

<section {id} class="empty-state" aria-live="polite">
  <p class="empty-state__icon" aria-hidden="true">{icon}</p>
  <p class="empty-state__title">{title}</p>
  {description && <p class="empty-state__description">{description}</p>}
  <div class="empty-state__actions">
    <slot />
  </div>
</section>

<style>
  .empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-8) var(--space-4);
    text-align: center;
    color: var(--color-muted);
  }
  .empty-state__icon {
    font-size: 2.5rem;
    line-height: 1;
    margin: 0;
  }
  .empty-state__title {
    font-size: var(--font-size-base);
    font-weight: 600;
    color: var(--color-text);
    margin: 0;
  }
  .empty-state__description {
    font-size: var(--font-size-sm);
    max-width: 36ch;
    margin: 0;
  }
  .empty-state__actions { display: flex; gap: var(--space-3); flex-wrap: wrap; justify-content: center; }
  .empty-state__actions:empty { display: none; }
</style>
