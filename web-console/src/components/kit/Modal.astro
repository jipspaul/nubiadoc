---
interface Props {
  id: string;
  title: string;
  open?: boolean;
}
const { id, title, open = false } = Astro.props;
---

<dialog
  {id}
  class="modal"
  aria-modal="true"
  aria-labelledby={`${id}-title`}
  aria-hidden={open ? 'false' : 'true'}
>
  <article class="modal__content">
    <header class="modal__header">
      <h2 id={`${id}-title`} class="modal__title">{title}</h2>
      <button
        type="button"
        class="modal__close"
        data-modal-close={id}
        aria-label="Fermer"
      >&#x2715;</button>
    </header>
    <div class="modal__body">
      <slot />
    </div>
    <footer class="modal__footer">
      <slot name="footer" />
    </footer>
  </article>
</dialog>

<script>
  // Gestion ouverture/fermeture déclarative
  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    const openId = target.dataset.modalOpen;
    const closeId = target.dataset.modalClose;

    if (openId) {
      const dialog = document.getElementById(openId) as HTMLDialogElement | null;
      if (dialog) {
        dialog.removeAttribute('aria-hidden');
        dialog.showModal();
      }
    }
    if (closeId) {
      const dialog = document.getElementById(closeId) as HTMLDialogElement | null;
      if (dialog) {
        dialog.setAttribute('aria-hidden', 'true');
        dialog.close();
      }
    }
  });

  // Fermeture sur clic fond
  document.querySelectorAll('dialog.modal').forEach((dialog) => {
    dialog.addEventListener('click', (e) => {
      if (e.target === dialog) {
        (dialog as HTMLDialogElement).close();
        dialog.setAttribute('aria-hidden', 'true');
      }
    });
  });
</script>

<style>
  .modal {
    padding: 0;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    background: var(--color-surface);
    color: var(--color-text);
    max-width: min(90vw, 560px);
    width: 100%;
  }
  .modal::backdrop {
    background: rgba(0, 0, 0, 0.7);
  }
  .modal__content { display: flex; flex-direction: column; }
  .modal__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-4) var(--space-6);
    border-bottom: 1px solid var(--color-border);
  }
  .modal__title {
    font-size: var(--font-size-lg);
    font-weight: 600;
    margin: 0;
  }
  .modal__close {
    background: transparent;
    border: none;
    color: var(--color-muted);
    cursor: pointer;
    font-size: var(--font-size-base);
    line-height: 1;
    padding: var(--space-1);
    border-radius: var(--radius-sm);
  }
  .modal__close:hover { color: var(--color-text); }
  .modal__body { padding: var(--space-6); }
  .modal__footer {
    padding: var(--space-4) var(--space-6);
    border-top: 1px solid var(--color-border);
    display: flex;
    gap: var(--space-3);
    justify-content: flex-end;
  }
  .modal__footer:empty { display: none; }
</style>
