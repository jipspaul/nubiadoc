---
interface Props {
  label: string;
  id: string;
  name?: string;
  type?: 'text' | 'email' | 'password' | 'number' | 'tel' | 'date' | 'search' | 'url';
  value?: string;
  placeholder?: string;
  required?: boolean;
  disabled?: boolean;
  hint?: string;
  error?: string;
}
const {
  label,
  id,
  name,
  type = 'text',
  value,
  placeholder,
  required = false,
  disabled = false,
  hint,
  error,
} = Astro.props;
---

<div class:list={['field', { 'field--error': !!error }]}>
  <label for={id} class="field__label">
    {label}
    {required && <span class="field__required" aria-hidden="true">*</span>}
  </label>
  <input
    {id}
    name={name ?? id}
    {type}
    value={value}
    {placeholder}
    required={required}
    disabled={disabled}
    class="field__input"
    aria-describedby={hint ? `${id}-hint` : error ? `${id}-error` : undefined}
    aria-invalid={error ? 'true' : undefined}
  />
  {hint && !error && <p id={`${id}-hint`} class="field__hint">{hint}</p>}
  {error && <p id={`${id}-error`} class="field__error" role="alert">{error}</p>}
</div>

<style>
  .field { display: flex; flex-direction: column; gap: var(--space-1); }
  .field__label {
    font-size: var(--font-size-sm);
    font-weight: 500;
    color: var(--color-text);
  }
  .field__required { color: var(--color-error-fg); margin-left: 2px; }
  .field__input {
    padding: var(--space-2) var(--space-3);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    color: var(--color-text);
    font-family: var(--font-sans);
    font-size: var(--font-size-sm);
    transition: border-color 0.15s;
    width: 100%;
  }
  .field__input:focus {
    outline: none;
    border-color: var(--color-accent);
  }
  .field__input:disabled { opacity: 0.5; cursor: not-allowed; }
  .field--error .field__input { border-color: var(--color-error-fg); }
  .field__hint { font-size: var(--font-size-xs); color: var(--color-muted); }
  .field__error { font-size: var(--font-size-xs); color: var(--color-error-fg); }
</style>
