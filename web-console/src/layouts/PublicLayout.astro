---
import '../styles/global.css';

interface Props {
  title?: string;
}
const { title = 'Nubia' } = Astro.props;
---
<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
  </head>
  <body>
    <header style="background:var(--surface);border-bottom:1px solid var(--border);padding:0.5rem 2rem;display:flex;align-items:center;gap:1rem;">
      <a href="/" style="font-weight:bold;text-decoration:none;color:var(--text);">Nubia</a>
      <nav id="public-nav" aria-label="Navigation principale"></nav>
    </header>
    <main style="flex:1;padding:2rem;max-width:960px;width:100%;margin:0 auto;">
      <slot />
    </main>
    <footer style="padding:0.5rem 2rem;text-align:center;font-size:0.75rem;color:var(--muted);border-top:1px solid var(--border);">
      Nubia dev console — données fictives uniquement
    </footer>
  </body>
</html>

<script>
  import { isAuthenticated } from '../lib/session.ts';

  const nav = document.getElementById('public-nav');
  if (nav) {
    if (isAuthenticated()) {
      nav.innerHTML = '<a href="/app">Mon espace</a>';
    } else {
      nav.innerHTML = '<a href="/login">Se connecter</a> <a href="/register">Créer un compte</a>';
    }
  }
</script>
