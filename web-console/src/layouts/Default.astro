---
import NavMenu from '../components/NavMenu.astro';
import '../styles/global.css';

interface Props {
  title?: string;
}
const { title = 'Nubia Web Console' } = Astro.props;
---
<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
  </head>
  <body>
    <header style="background:var(--surface);border-bottom:1px solid var(--border);padding:0.5rem 2rem;display:flex;align-items:center;gap:1rem;">
      <strong>Nubia Web Console</strong>
      <nav>
        <a href="/">← Accueil</a>
      </nav>
    </header>
    <div style="flex:1;display:flex;min-height:0;">
      <NavMenu />
      <main style="flex:1;padding:2rem;max-width:960px;width:100%;margin:0 auto;overflow-x:auto;">
        <slot />
      </main>
    </div>
    <footer style="padding:0.5rem 2rem;text-align:center;font-size:0.75rem;color:var(--muted);border-top:1px solid var(--border);">
      Nubia dev console — données fictives uniquement
    </footer>
  </body>
</html>
