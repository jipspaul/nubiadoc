# ─── API ────────────────────────────────────────────────────────────────────
# URL de l'API Nubia — exposée côté client (préfixe PUBLIC_ requis par Astro)
PUBLIC_API_BASE=http://localhost:38030

# URL de l'API Nubia côté serveur uniquement (SSR) — prioritaire sur PUBLIC_API_BASE
API_BASE=http://localhost:38030

# ─── TESTS / PLAYWRIGHT ─────────────────────────────────────────────────────
# URL de base utilisée par les projets Playwright "flows", "patient", etc.
FLOWS_BASE_URL=http://localhost:38040

# Chemin vers l'exécutable Chromium (laisser vide = détection automatique en local)
CHROMIUM_PATH=

# Positionner à "true" en CI (désactive la réutilisation du serveur de dev Playwright)
CI=
